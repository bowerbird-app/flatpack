# frozen_string_literal: true

# Rails and core dependencies
gem "rails", ">= 8.1.2.1", "< 8.2"
gem "puma", ">= 5.0"
gem "propshaft", "~> 1.0"
gem "sidekiq"
gem "redis"
gem "sqlite3", ">= 2.1"

# Asset pipeline and frontend
gem "tailwindcss-rails", "~> 4.0"
gem "importmap-rails"
gem "stimulus-rails"
gem "turbo-rails"

# View components
gem "view_component"
gem "devise"

group :development, :test do
  gem "debug", platforms: %i[mri mingw x64_mingw]
end

group :development do
  gem "web-console"
end

group :test do
  gem "capybara"
  gem "selenium-webdriver"
end