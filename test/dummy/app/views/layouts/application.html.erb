<!DOCTYPE html>
<html class="h-full overflow-hidden overscroll-none">
  <head>
    <title>FlatPack Demo</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="m-0 h-full overflow-hidden overscroll-none bg-[var(--surface-page-background-color)] text-[var(--surface-content-color)]" data-controller="dark-mode">
    <%= render "layouts/icon_sprite" %>

    <% sidebar_side = params[:side].in?(%w[left right]) ? params[:side].to_sym : :left %>
    <%= render FlatPack::SidebarLayout::Component.new(
      side: sidebar_side,
      storage_key: "flatpack-dummy-shell"
    ) do |layout| %>
      <% layout.sidebar do %>
        <% cache ["dummy/sidebar-shell", request.fullpath, sidebar_side] do %>
          <%= render FlatPack::Sidebar::Component.new(side: sidebar_side) do |sidebar| %>
          <% sidebar.header do %>
            <%= render FlatPack::Sidebar::Header::Component.new(
              brand_abbr: "FP",
              title: "FlatPack",
              subtitle: "Dummy App"
            ) %>
          <% end %>

          <% sidebar.items do %>
            <nav class="py-4 space-y-1" aria-label="Main navigation">
              <% themes_section_active = current_page?(themes_path) ||
                                         current_page?(theme_demo_path(theme: "system")) ||
                                         current_page?(theme_demo_path(theme: "light")) ||
                                         current_page?(theme_demo_path(theme: "dark")) ||
                                         current_page?(theme_demo_path(theme: "ocean")) ||
                                         current_page?(theme_demo_path(theme: "rounded")) %>

              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Overview",
                href: demo_path,
                icon: :home,
                active: current_page?(demo_path)
              ) %>
              <%= render FlatPack::Sidebar::Group::Component.new(
                label: "Themes",
                icon: :cog,
                default_open: themes_section_active
              ) do |group| %>
                <% group.items do %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Theme Variables",
                    href: themes_path,
                    icon: :type,
                    active: current_page?(themes_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "System theme",
                    href: theme_demo_path(theme: "system"),
                    icon: :monitor,
                    active: current_page?(theme_demo_path(theme: "system"))
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Light theme",
                    href: theme_demo_path(theme: "light"),
                    icon: :monitor,
                    active: current_page?(theme_demo_path(theme: "light"))
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Dark theme",
                    href: theme_demo_path(theme: "dark"),
                    icon: :monitor,
                    active: current_page?(theme_demo_path(theme: "dark"))
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Ocean theme",
                    href: theme_demo_path(theme: "ocean"),
                    icon: :monitor,
                    active: current_page?(theme_demo_path(theme: "ocean"))
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Rounded theme",
                    href: theme_demo_path(theme: "rounded"),
                    icon: :monitor,
                    active: current_page?(theme_demo_path(theme: "rounded"))
                  ) %>
                <% end %>
              <% end %>
              
              <%= render FlatPack::Sidebar::Divider::Component.new %>
              
              <!-- Interactive Components -->
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Buttons",
                href: demo_buttons_path,
                icon: :square,
                active: current_page?(demo_buttons_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Modals",
                href: demo_modals_path,
                icon: :box,
                active: current_page?(demo_modals_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Popovers",
                href: demo_popovers_path,
                icon: :question,
                active: current_page?(demo_popovers_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Tooltips",
                href: demo_tooltips_path,
                icon: :question,
                active: current_page?(demo_tooltips_path)
              ) %>
              <% tabs_section_active = current_page?(demo_tabs_path) || current_page?(demo_tabs_pills_path) || current_page?(demo_tabs_stacked_pills_path) %>
              <%= render FlatPack::Sidebar::Group::Component.new(
                label: "Tabs",
                icon: :folder,
                default_open: tabs_section_active
              ) do |group| %>
                <% group.items do %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Underline Tabs",
                    href: demo_tabs_path,
                    icon: :folder,
                    active: current_page?(demo_tabs_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Pills tabs",
                    href: demo_tabs_pills_path,
                    icon: :folder,
                    active: current_page?(demo_tabs_pills_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Stacked pills",
                    href: demo_tabs_stacked_pills_path,
                    icon: :folder,
                    active: current_page?(demo_tabs_stacked_pills_path)
                  ) %>
                <% end %>
              <% end %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Toasts",
                href: demo_toasts_path,
                icon: :bell,
                active: current_page?(demo_toasts_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Collapse",
                href: demo_collapse_path,
                icon: :chevron_down,
                active: current_page?(demo_collapse_path)
              ) %>
              
              <%= render FlatPack::Sidebar::Divider::Component.new %>
              
              <!-- Form Components -->
              <% forms_section_active = current_page?(demo_forms_path) ||
                                        current_page?(demo_forms_text_input_path) ||
                                        current_page?(demo_forms_password_input_path) ||
                                        current_page?(demo_forms_email_input_path) ||
                                        current_page?(demo_forms_phone_input_path) ||
                                        current_page?(demo_forms_search_input_path) ||
                                        current_page?(demo_forms_url_input_path) ||
                                        current_page?(demo_forms_text_area_path) ||
                                        current_page?(demo_forms_number_input_path) ||
                                        current_page?(demo_forms_date_input_path) ||
                                        current_page?(demo_forms_file_input_path) ||
                                        current_page?(demo_forms_checkbox_path) ||
                                        current_page?(demo_forms_radio_group_path) ||
                                        current_page?(demo_forms_select_path) ||
                                        current_page?(demo_forms_switch_path) ||
                                        current_page?(demo_range_input_path) ||
                                        current_page?(demo_forms_combined_path) %>
              <%= render FlatPack::Sidebar::Group::Component.new(
                label: "Forms",
                icon: :edit_3,
                default_open: forms_section_active
              ) do |group| %>
                <% group.items do %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Submit Buttons",
                    href: demo_forms_path,
                    icon: :square,
                    active: current_page?(demo_forms_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Text Input",
                    href: demo_forms_text_input_path,
                    icon: :type,
                    active: current_page?(demo_forms_text_input_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Password Input",
                    href: demo_forms_password_input_path,
                    icon: :settings,
                    active: current_page?(demo_forms_password_input_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Email Input",
                    href: demo_forms_email_input_path,
                    icon: :type,
                    active: current_page?(demo_forms_email_input_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Phone Input",
                    href: demo_forms_phone_input_path,
                    icon: :type,
                    active: current_page?(demo_forms_phone_input_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Search Input",
                    href: demo_forms_search_input_path,
                    icon: :search,
                    active: current_page?(demo_forms_search_input_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "URL Input",
                    href: demo_forms_url_input_path,
                    icon: :type,
                    active: current_page?(demo_forms_url_input_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Text Area",
                    href: demo_forms_text_area_path,
                    icon: :align_left,
                    active: current_page?(demo_forms_text_area_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Number Input",
                    href: demo_forms_number_input_path,
                    icon: :type,
                    active: current_page?(demo_forms_number_input_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Date Input",
                    href: demo_forms_date_input_path,
                    icon: :calendar,
                    active: current_page?(demo_forms_date_input_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "File Input",
                    href: demo_forms_file_input_path,
                    icon: :box,
                    active: current_page?(demo_forms_file_input_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Checkbox",
                    href: demo_forms_checkbox_path,
                    icon: :square,
                    active: current_page?(demo_forms_checkbox_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Radio Group",
                    href: demo_forms_radio_group_path,
                    icon: :square,
                    active: current_page?(demo_forms_radio_group_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Select",
                    href: demo_forms_select_path,
                    icon: :chevron_down,
                    active: current_page?(demo_forms_select_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Picker",
                    href: demo_picker_path,
                    icon: :image,
                    active: current_page?(demo_picker_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Switch",
                    href: demo_forms_switch_path,
                    icon: :settings,
                    active: current_page?(demo_forms_switch_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Range Input",
                    href: demo_range_input_path,
                    icon: :settings,
                    active: current_page?(demo_range_input_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Combined Form",
                    href: demo_forms_combined_path,
                    icon: :edit_3,
                    active: current_page?(demo_forms_combined_path)
                  ) %>
                <% end %>
              <% end %>
              
              <%= render FlatPack::Sidebar::Divider::Component.new %>
              
              <!-- Data Display -->
              <% tables_section_active = [
                demo_tables_basic_path,
                demo_tables_empty_path,
                demo_tables_sortable_path,
                demo_tables_draggable_path
              ].any? { |path| current_page?(path) } %>
              <%= render FlatPack::Sidebar::Group::Component.new(
                label: "Tables",
                icon: :table,
                default_open: tables_section_active
              ) do |group| %>
                <% group.items do %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Basic",
                    href: demo_tables_basic_path,
                    icon: :table,
                    active: current_page?(demo_tables_basic_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Empty",
                    href: demo_tables_empty_path,
                    icon: :inbox,
                    active: current_page?(demo_tables_empty_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Sortable",
                    href: demo_tables_sortable_path,
                    icon: :chevron_down,
                    active: current_page?(demo_tables_sortable_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Draggable",
                    href: demo_tables_draggable_path,
                    icon: :dashboard,
                    active: current_page?(demo_tables_draggable_path)
                  ) %>
                <% end %>
              <% end %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Pagination",
                href: demo_pagination_path,
                icon: :chevron_right,
                active: current_page?(demo_pagination_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Infinite Scroll",
                href: demo_pagination_infinite_path,
                icon: :chevron_down,
                active: current_page?(demo_pagination_infinite_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Charts",
                href: demo_charts_path,
                icon: :dashboard,
                active: current_page?(demo_charts_path)
              ) %>
              <% grid_section_active = [
                demo_grid_path,
                demo_grid_two_columns_path,
                demo_grid_movable_cards_path
              ].any? { |path| current_page?(path) } %>
              <%= render FlatPack::Sidebar::Group::Component.new(
                label: "Grid",
                icon: :dashboard,
                default_open: grid_section_active
              ) do |group| %>
                <% group.items do %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Layouts",
                    href: demo_grid_path,
                    icon: :dashboard,
                    active: current_page?(demo_grid_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Two Columns",
                    href: demo_grid_two_columns_path,
                    icon: :dashboard,
                    active: current_page?(demo_grid_two_columns_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Movable Cards",
                    href: demo_grid_movable_cards_path,
                    icon: :chevron_down,
                    active: current_page?(demo_grid_movable_cards_path)
                  ) %>
                <% end %>
              <% end %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Code Blocks",
                href: demo_code_blocks_path,
                icon: :type,
                active: current_page?(demo_code_blocks_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Avatars",
                href: demo_avatars_path,
                icon: :user,
                active: current_page?(demo_avatars_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Comments",
                href: demo_comments_path,
                icon: :users,
                active: current_page?(demo_comments_path)
              ) %>
              <% chat_section_active = [
                demo_chat_demo_path,
                demo_chat_layout_path,
                demo_chat_panel_path,
                demo_chat_message_list_path,
                demo_chat_message_group_path,
                demo_chat_sent_message_path,
                demo_chat_received_message_path,
                demo_chat_file_message_path,
                demo_chat_images_path,
                demo_chat_system_message_path,
                demo_chat_inbox_row_path,
                demo_chat_attachment_path,
                demo_chat_date_divider_path,
                demo_chat_typing_indicator_path,
                demo_chat_composer_path
              ].any? { |path| current_page?(path) } %>
              <%= render FlatPack::Sidebar::Group::Component.new(
                label: "Chat",
                icon: :message_circle,
                default_open: chat_section_active
              ) do |group| %>
                <% group.items do %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Chat Demo",
                    href: demo_chat_demo_path,
                    icon: :message_circle,
                    active: current_page?(demo_chat_demo_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Layout",
                    href: demo_chat_layout_path,
                    icon: :dashboard,
                    active: current_page?(demo_chat_layout_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Panel",
                    href: demo_chat_panel_path,
                    icon: :box,
                    active: current_page?(demo_chat_panel_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Message List",
                    href: demo_chat_message_list_path,
                    icon: :align_left,
                    active: current_page?(demo_chat_message_list_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Message Group",
                    href: demo_chat_message_group_path,
                    icon: :users,
                    active: current_page?(demo_chat_message_group_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Sent Message",
                    href: demo_chat_sent_message_path,
                    icon: :message_circle,
                    active: current_page?(demo_chat_sent_message_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Received Message",
                    href: demo_chat_received_message_path,
                    icon: :message_circle,
                    active: current_page?(demo_chat_received_message_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "File Message",
                    href: demo_chat_file_message_path,
                    icon: :file,
                    active: current_page?(demo_chat_file_message_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Images",
                    href: demo_chat_images_path,
                    icon: :image,
                    active: current_page?(demo_chat_images_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "System Message",
                    href: demo_chat_system_message_path,
                    icon: :info,
                    active: current_page?(demo_chat_system_message_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Inbox Row",
                    href: demo_chat_inbox_row_path,
                    icon: :align_left,
                    active: current_page?(demo_chat_inbox_row_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Attachment",
                    href: demo_chat_attachment_path,
                    icon: :file,
                    active: current_page?(demo_chat_attachment_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Date Divider",
                    href: demo_chat_date_divider_path,
                    icon: :calendar,
                    active: current_page?(demo_chat_date_divider_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Typing Indicator",
                    href: demo_chat_typing_indicator_path,
                    icon: :edit_3,
                    active: current_page?(demo_chat_typing_indicator_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Composer",
                    href: demo_chat_composer_path,
                    icon: :edit_3,
                    active: current_page?(demo_chat_composer_path)
                  ) %>
                <% end %>
              <% end %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Carousel",
                href: demo_carousel_path(anchor: "component-method-variables-carousel-0"),
                icon: :image,
                active: current_page?(demo_carousel_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Progress",
                href: demo_progress_path,
                icon: :dashboard,
                active: current_page?(demo_progress_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Skeletons",
                href: demo_skeletons_path,
                icon: :square,
                active: current_page?(demo_skeletons_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "List",
                href: demo_list_path,
                icon: :align_left,
                active: current_page?(demo_list_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Timeline",
                href: demo_timeline_path,
                icon: :calendar,
                active: current_page?(demo_timeline_path)
              ) %>
              
              <%= render FlatPack::Sidebar::Divider::Component.new %>
              
              <!-- Layout Components -->
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Cards",
                href: demo_cards_path,
                icon: :box,
                active: current_page?(demo_cards_path)
              ) %>
              <% text_section_active = [
                demo_page_header_path,
                demo_text_quote_path
              ].any? { |path| current_page?(path) } %>
              <%= render FlatPack::Sidebar::Group::Component.new(
                label: "Text",
                icon: :align_left,
                default_open: text_section_active
              ) do |group| %>
                <% group.items do %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Page Title",
                    href: demo_page_header_path,
                    icon: :type,
                    active: current_page?(demo_page_header_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Quote",
                    href: demo_text_quote_path,
                    icon: :message_circle,
                    active: current_page?(demo_text_quote_path)
                  ) %>
                <% end %>
              <% end %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Articles",
                href: articles_path,
                icon: :edit_3,
                active: request.path.start_with?("/demo/articles")
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Empty State",
                href: demo_empty_state_path,
                icon: :folder,
                active: current_page?(demo_empty_state_path)
              ) %>
              
              <%= render FlatPack::Sidebar::Divider::Component.new %>
              
              <!-- Feedback Components -->
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Alerts",
                href: demo_alerts_path,
                icon: :alert,
                active: current_page?(demo_alerts_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Badges",
                href: demo_badges_path,
                icon: :dashboard,
                active: current_page?(demo_badges_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Chips",
                href: demo_chips_path,
                icon: :dashboard,
                active: current_page?(demo_chips_path)
              ) %>
              
              <%= render FlatPack::Sidebar::Divider::Component.new %>
              
              <!-- Navigation Components -->
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Breadcrumbs",
                href: demo_breadcrumbs_path,
                icon: :chevron_right,
                active: current_page?(demo_breadcrumbs_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Top Nav",
                href: demo_navbar_path,
                icon: :monitor,
                active: current_page?(demo_navbar_path)
              ) %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Search",
                href: demo_search_path,
                icon: :search,
                active: current_page?(demo_search_path)
              ) %>
              <% sidebar_section_active = [
                demo_sidebar_layout_path,
                demo_sidebar_basic_path,
                demo_sidebar_header_path,
                demo_sidebar_footer_path,
                demo_sidebar_badges_path,
                demo_sidebar_grouped_path,
                demo_sidebar_collapsible_path,
                demo_sidebar_collapsed_path,
                demo_sidebar_complete_path
              ].any? { |path| current_page?(path) } %>
              <%= render FlatPack::Sidebar::Group::Component.new(
                label: "Sidebar",
                icon: :laptop,
                default_open: sidebar_section_active
              ) do |group| %>
                <% group.items do %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Layout",
                    href: demo_sidebar_layout_path,
                    icon: :monitor,
                    active: current_page?(demo_sidebar_layout_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Basic",
                    href: demo_sidebar_basic_path,
                    icon: :home,
                    active: current_page?(demo_sidebar_basic_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Header",
                    href: demo_sidebar_header_path,
                    icon: :type,
                    active: current_page?(demo_sidebar_header_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Footer",
                    href: demo_sidebar_footer_path,
                    icon: :align_left,
                    active: current_page?(demo_sidebar_footer_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Badges",
                    href: demo_sidebar_badges_path,
                    icon: :dashboard,
                    active: current_page?(demo_sidebar_badges_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Grouped",
                    href: demo_sidebar_grouped_path,
                    icon: :folder,
                    active: current_page?(demo_sidebar_grouped_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Collapsible",
                    href: demo_sidebar_collapsible_path,
                    icon: :chevron_down,
                    active: current_page?(demo_sidebar_collapsible_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Collapsed",
                    href: demo_sidebar_collapsed_path,
                    icon: :menu,
                    active: current_page?(demo_sidebar_collapsed_path)
                  ) %>
                  <%= render FlatPack::Sidebar::Item::Component.new(
                    label: "Complete",
                    href: demo_sidebar_complete_path,
                    icon: :box,
                    active: current_page?(demo_sidebar_complete_path)
                  ) %>
                <% end %>
              <% end %>
              <%= render FlatPack::Sidebar::Item::Component.new(
                label: "Mobile",
                href: mobile_bottom_nav_path,
                icon: :menu,
                active: current_page?(mobile_path) || current_page?(mobile_bottom_nav_path)
              ) %>
            </nav>
          <% end %>

          <% sidebar.footer do %>
            <%= render FlatPack::Sidebar::Footer::Component.new(class: "text-sm text-[var(--surface-muted-content-color)]") do %>
              FlatPack Demo Components
            <% end %>
          <% end %>

          <% end %>
        <% end %>
      <% end %>

      <% layout.top_nav do %>
        <%= render FlatPack::TopNav::Component.new do |nav| %>
          <% nav.left do %>
            <%= render FlatPack::Button::Component.new(
              icon: "menu",
              icon_only: true,
              style: :ghost,
              size: :md,
              aria: { label: "Toggle sidebar" },
              data: {
                "flat-pack--sidebar-layout-target": "mobileToggle",
                action: "click->flat-pack--sidebar-layout#toggleMobile"
              },
              class: "md:hidden border-0 shadow-none text-(--top-nav-item-icon-color) hover:bg-(--top-nav-item-hover-background-color) hover:text-(--top-nav-item-hover-text-color) transition-colors"
            ) %>
            <span class="text-sm font-medium text-[var(--surface-muted-content-color)]">FlatPack Demo</span>
          <% end %>

          <% nav.center do %>
            <%= render FlatPack::Search::Component.new(
              search_url: demo_search_results_path,
              placeholder: "Search demo pages...",
              no_results_text: "No demo pages found",
              min_characters: 1,
              debounce: 150,
              class: "max-w-xl"
            ) %>
          <% end %>

          <% nav.right do %>
            <div class="ml-auto flex items-center gap-3" data-controller="flat-pack--theme">
              <%= render FlatPack::Button::Dropdown::Component.new(
                text: "Theme",
                style: :ghost,
                size: :sm,
                position: :bottom_right,
                icon: "cog"
              ) do |dropdown| %>
                <% dropdown.menu_item(
                  text: "System",
                  data: { action: "click->flat-pack--theme#switch click->flat-pack--button-dropdown#toggle", theme_value: "system" }
                ) %>
                <% dropdown.menu_item(
                  text: "Light",
                  data: { action: "click->flat-pack--theme#switch click->flat-pack--button-dropdown#toggle", theme_value: "light" }
                ) %>
                <% dropdown.menu_item(
                  text: "Dark",
                  data: { action: "click->flat-pack--theme#switch click->flat-pack--button-dropdown#toggle", theme_value: "dark" }
                ) %>
                <% dropdown.menu_item(
                  text: "Ocean",
                  data: { action: "click->flat-pack--theme#switch click->flat-pack--button-dropdown#toggle", theme_value: "ocean" }
                ) %>
                <% dropdown.menu_item(
                  text: "Rounded",
                  data: { action: "click->flat-pack--theme#switch click->flat-pack--button-dropdown#toggle", theme_value: "rounded" }
                ) %>
              <% end %>

            <%= render FlatPack::Button::Component.new(
              icon: "bell",
              icon_only: true,
              style: :ghost,
              size: :sm,
              aria: { label: "Notifications" }
            ) %>
            </div>
          <% end %>

        <% end %>
      <% end %>

      <% layout.main do %>
        <main class="p-4 sm:p-8 bg-[var(--surface-page-background-color)] text-[var(--surface-content-color)]">
          <div class="max-w-4xl mx-auto pb-24">
            <% if notice.present? %>
              <%= render FlatPack::Alert::Component.new(description: notice, style: :success, dismissible: true, class: "mb-4") %>
            <% end %>
            <% if alert.present? %>
              <%= render FlatPack::Alert::Component.new(description: alert, style: :danger, dismissible: true, class: "mb-4") %>
            <% end %>

            <%= yield %>

            <% if @demo_theme_token_rows.present? %>
              <%= render "pages/theme_token_reference", title: @demo_theme_token_title, rows: @demo_theme_token_rows %>
            <% end %>

          </div>
        </main>
      <% end %>
    <% end %>
  </body>
</html>
