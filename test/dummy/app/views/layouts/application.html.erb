    <%= stylesheet_link_tag "flat_pack/rich_text", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "flat_pack/content_editor", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      // Activate the sidebar nav item matching the current URL.
      // Runs on every Turbo navigation (turbo:load). Registered once here in
      // <head> so Turbo Drive does not re-register it on subsequent navigations.
      (function () {
        function activateSidebarNav() {
          var path = window.location.pathname;

          // Find the item whose stripped href is the longest prefix of (or exact
          // match to) the current pathname — this avoids false positives from
          // short paths like "/demo" matching every "/demo/*" page.
          var bestLink = null;
          var bestLen  = 0;

          document.querySelectorAll('[data-flat-pack-sidebar-item="true"]').forEach(function (link) {
            var href = link.getAttribute('href');
            if (!href) return;
            var hrefPath = href.split('?')[0].split('#')[0];
            if (!hrefPath || hrefPath === '/') return;

            if ((path === hrefPath || path.startsWith(hrefPath + '/')) && hrefPath.length > bestLen) {
              bestLink = link;
              bestLen  = hrefPath.length;
            }
          });

          if (!bestLink) return;

          // Swap inactive → active CSS classes on the link element
          bestLink.classList.remove(
            'text-[var(--sidebar-item-text-color)]',
            'hover:bg-[var(--sidebar-item-hover-background-color)]',
            'hover:text-[var(--sidebar-item-hover-text-color)]'
          );
          bestLink.classList.add(
            'bg-[var(--sidebar-item-active-background-color)]',
            'text-[var(--sidebar-item-active-text-color)]'
          );
          bestLink.setAttribute('aria-current', 'page');

          // Swap inactive → active CSS class on the icon wrapper
          var iconEl = bestLink.querySelector('[data-flat-pack-sidebar-item-icon="true"]');
          if (iconEl) {
            iconEl.classList.remove('text-[var(--sidebar-item-icon-color)]');
            iconEl.classList.add('text-[var(--sidebar-item-active-icon-color)]');
          }

          // Open the nearest parent sidebar group if it is currently collapsed.
          // Clicking the toggle button also persists open state to localStorage,
          // so subsequent visits to pages in the same group stay open.
          var groupEl = bestLink.closest('[data-controller*="flat-pack--sidebar-group"]');
          if (groupEl) {
            var btn = groupEl.querySelector('[data-flat-pack--sidebar-group-target="button"]');
            if (btn && btn.getAttribute('aria-expanded') === 'false') {
              btn.click();
            }
          }
        }

        document.addEventListener('turbo:load', activateSidebarNav);
      })();
    </script>
  </head>

