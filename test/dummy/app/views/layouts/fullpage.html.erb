<!DOCTYPE html>
<html class="h-full">
  <head>
    <title>FlatPack Demo</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "flat_pack/variables", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "flat_pack/rich_text", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "flat_pack/content_editor", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="m-0 min-h-screen bg-[var(--surface-page-background-color)] text-[var(--surface-content-color)]" data-controller="dark-mode">
    <%= render "layouts/icon_sprite" %>

    <%= yield %>
  </body>
</html>
