<div data-controller="theme-demo-page" data-theme-demo-page-theme-value="<%= @demo_theme %>"></div>

<div class="space-y-8">
  <%= render FlatPack::PageTitle::Component.new(
    title: "#{@demo_theme_label} Theme Demo",
    description: "Live preview for the #{@demo_theme_label.downcase} theme tokens and component surfaces."
  ) %>

  <%= render "themes/demo_showcase" %>

  <div class="space-y-6">
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Variables Used By This Theme",
      subtitle: "Complete token list sourced from the canonical FlatPack theme variables file.",
      anchor_link: true
    ) %>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "#{@demo_theme_label} Theme Variables",
      language: "css",
      code: @theme_variables_code
    ) %>
  </div>
</div>
