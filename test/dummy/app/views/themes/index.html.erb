            <%= render FlatPack::Button::Component.new(text: "Open Demo", url: theme_demo_path(theme: "dark"), style: :secondary, size: :sm) %>
          </div>
        <% end %>
      <% end %>

      <%= render FlatPack::Card::Component.new do |card| %>
        <% card.body do %>
          <h3 class="text-base font-medium text-[var(--surface-content-color)]">Ocean Theme</h3>
          <p class="text-sm text-[var(--surface-muted-content-color)] mt-1">Blue-leaning palette with cool accent contrast.</p>
          <div class="mt-4">
            <%= render FlatPack::Button::Component.new(text: "Open Demo", url: theme_demo_path(theme: "ocean"), style: :secondary, size: :sm) %>
          </div>
        <% end %>
      <% end %>

      <%= render FlatPack::Card::Component.new do |card| %>
        <% card.body do %>
          <h3 class="text-base font-medium text-[var(--surface-content-color)]">Rounded Theme</h3>
          <p class="text-sm text-[var(--surface-muted-content-color)] mt-1">Soft corners and muted neutrals for a friendly style.</p>
          <div class="mt-4">
            <%= render FlatPack::Button::Component.new(text: "Open Demo", url: theme_demo_path(theme: "rounded"), style: :secondary, size: :sm) %>
