<div class="space-y-8">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Themes",
    description: "Explore FlatPack's color palettes, semantic tokens, and theme switching capabilities."
  ) %>

  <!-- How Theming Works -->
  <div class="space-y-6">
    <%= render FlatPack::SectionTitle::Component.new(
      title: "How Theming Works",
      subtitle: "FlatPack uses Tailwind v4 @theme tokens and per-theme variable overrides.",
      anchor_link: true
    ) %>

    <div class="p-4 border border-[var(--surface-border-color)] rounded-lg bg-[var(--surface-background-color)] space-y-3">
      <p class="text-sm text-[var(--surface-muted-content-color)]">
        Themes are defined with Tailwind v4 tokens (for example <code class="font-mono text-xs">--color-primary</code>,
        <code class="font-mono text-xs">--radius-md</code>, <code class="font-mono text-xs">--search-input-background-color</code>,
        and <code class="font-mono text-xs">--shadow-md</code>).
        Tailwind then generates semantic utilities like <code class="font-mono text-xs">bg-primary</code>,
        <code class="font-mono text-xs">text-[var(--surface-content-color)]</code>, and <code class="font-mono text-xs">border-[var(--surface-border-color)]</code>.
      </p>
      <p class="text-sm text-[var(--surface-muted-content-color)]">
        To add a new theme, define the same variable names under a new selector
        (for example <code class="font-mono text-xs">[data-theme=\"forest\"]</code>) and provide different values.
        Components keep the same class names, and only token values change.
      </p>
    </div>
  </div>

  <!-- Theme Variable Reference -->
  <div class="space-y-6">
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Theme Variable Reference",
      subtitle: "Grouped Tailwind v4 @theme tokens with plain-language descriptions.",
      anchor_link: true
    ) %>

    <div class="p-4 border border-[var(--surface-border-color)] rounded-lg bg-[var(--surface-background-color)] space-y-3">
      <p class="text-sm text-[var(--surface-muted-content-color)]">
        Keep the same token names across every theme and only change values.
        Suffixes: <code class="font-mono text-xs">-bg</code> is the base feedback surface,
        <code class="font-mono text-xs">-bg-hover</code> is interactive hover state,
        <code class="font-mono text-xs">-text</code> is text/icon color on that surface, and
        <code class="font-mono text-xs">-border</code> controls feedback borders.
      </p>
      <p class="text-xs text-[var(--surface-muted-content-color)]">
        Tip: these variables map to semantic utilities like <code class="font-mono">bg-primary</code>,
        <code class="font-mono">text-[var(--surface-content-color)]</code>, and <code class="font-mono">border-[var(--surface-border-color)]</code>.
        Search component tokens use the <code class="font-mono">--search-*</code> prefix for input, dropdown, and result row styling.
      </p>
    </div>

    <div class="space-y-4">
      <% @theme_token_groups.each do |group| %>
        <div class="space-y-3">
          <%= render FlatPack::SectionTitle::Component.new(
            title: group.fetch(:title),
            subtitle: group.fetch(:subtitle),
            anchor_link: true
          ) %>
          <div class="rounded-lg bg-[var(--surface-background-color)]">
            <%= render "themes/token_table", rows: group.fetch(:rows) %>
          </div>
        </div>
      <% end %>
    </div>
  </div>


  <div class="space-y-6">
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Theme Demos",
      subtitle: "Compare both light and dark demos inline, with dedicated pages still available.",
      anchor_link: true
    ) %>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
      <div class="space-y-3 p-4 border border-[var(--surface-border-color)] rounded-lg bg-[var(--surface-background-color)]" data-theme="light">
        <div class="flex items-center justify-between gap-2">
          <h3 class="text-base font-medium text-[var(--surface-content-color)]">Light Demo</h3>
          <%= render FlatPack::Button::Component.new(text: "Open Full Demo", url: theme_demo_path(theme: "light"), style: :secondary, size: :sm) %>
        </div>
        <%= render "themes/demo_showcase" %>
      </div>

      <div class="space-y-3 p-4 border border-[var(--surface-border-color)] rounded-lg bg-[var(--surface-background-color)]" data-theme="dark">
        <div class="flex items-center justify-between gap-2">
          <h3 class="text-base font-medium text-[var(--surface-content-color)]">Dark Demo</h3>
          <%= render FlatPack::Button::Component.new(text: "Open Full Demo", url: theme_demo_path(theme: "dark"), style: :secondary, size: :sm) %>
        </div>
        <%= render "themes/demo_showcase" %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%= render FlatPack::Card::Component.new do |card| %>
        <% card.body do %>
          <h3 class="text-base font-medium text-[var(--surface-content-color)]">System Theme</h3>
          <p class="text-sm text-[var(--surface-muted-content-color)] mt-1">Follows OS preference with automatic light/dark resolution.</p>
          <div class="mt-4">
            <%= render FlatPack::Button::Component.new(text: "Open Demo", url: theme_demo_path(theme: "system"), style: :secondary, size: :sm) %>
          </div>
        <% end %>
      <% end %>

      <%= render FlatPack::Card::Component.new do |card| %>
        <% card.body do %>
          <h3 class="text-base font-medium text-[var(--surface-content-color)]">Light Theme</h3>
          <p class="text-sm text-[var(--surface-muted-content-color)] mt-1">Neutral, high-contrast daytime palette.</p>
          <div class="mt-4">
            <%= render FlatPack::Button::Component.new(text: "Open Demo", url: theme_demo_path(theme: "light"), style: :secondary, size: :sm) %>
          </div>
        <% end %>
      <% end %>

      <%= render FlatPack::Card::Component.new do |card| %>
        <% card.body do %>
          <h3 class="text-base font-medium text-[var(--surface-content-color)]">Dark Theme</h3>
          <p class="text-sm text-[var(--surface-muted-content-color)] mt-1">Low-luminance palette tuned for dark surfaces.</p>
          <div class="mt-4">
            <%= render FlatPack::Button::Component.new(text: "Open Demo", url: theme_demo_path(theme: "dark"), style: :secondary, size: :sm) %>
          </div>
        <% end %>
      <% end %>

      <%= render FlatPack::Card::Component.new do |card| %>
        <% card.body do %>
          <h3 class="text-base font-medium text-[var(--surface-content-color)]">Ocean Theme</h3>
          <p class="text-sm text-[var(--surface-muted-content-color)] mt-1">Blue-leaning palette with cool accent contrast.</p>
          <div class="mt-4">
            <%= render FlatPack::Button::Component.new(text: "Open Demo", url: theme_demo_path(theme: "ocean"), style: :secondary, size: :sm) %>
          </div>
        <% end %>
      <% end %>

      <%= render FlatPack::Card::Component.new do |card| %>
        <% card.body do %>
          <h3 class="text-base font-medium text-[var(--surface-content-color)]">Rounded Theme</h3>
          <p class="text-sm text-[var(--surface-muted-content-color)] mt-1">Soft corners and muted neutrals for a friendly style.</p>
          <div class="mt-4">
            <%= render FlatPack::Button::Component.new(text: "Open Demo", url: theme_demo_path(theme: "rounded"), style: :secondary, size: :sm) %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
