    { variable: "--color-primary-hover", description: "Hover state for primary actions." },
    { variable: "--color-primary-text", description: "Text/icon color shown on primary surfaces." },
    { variable: "--color-secondary", description: "Secondary action/background surface." },
    { variable: "--color-secondary-hover", description: "Hover state for secondary surfaces." },
    { variable: "--color-secondary-text", description: "Text/icon color on secondary surfaces." },
