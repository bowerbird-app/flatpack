      ] %>
      <div class="p-4 rounded-lg bg-[var(--surface-background-color)]">
        <%= render "themes/token_table", rows: token_rows %>
      </div>
      </div>

      <div class="space-y-3">
          <%= render FlatPack::SectionTitle::Component.new(title: "Spacing Tokens", subtitle: "Reusable spacing tokens for cards, form controls, and table cell rhythm.", anchor_link: true) %>
                <% token_rows = [
    { variable: "--card-padding-sm", description: "Compact padding for card sections." },
    { variable: "--card-padding-md", description: "Default padding for card sections." },
    { variable: "--card-padding-lg", description: "Spacious padding for card sections." },
    { variable: "--form-control-padding", description: "Baseline padding for form controls." },
    { variable: "--table-padding", description: "Baseline table cell padding." }
      ] %>
      <div class="p-4 rounded-lg bg-[var(--surface-background-color)]">
        <%= render "themes/token_table", rows: token_rows %>
      </div>
      </div>

      <div class="space-y-3">
          <%= render FlatPack::SectionTitle::Component.new(title: "Shadows", subtitle: "Elevation tokens defining subtle to strong depth and pressed button states.", anchor_link: true) %>
                <% token_rows = [
    { variable: "--shadow-sm", description: "Subtle elevation shadow." },
    { variable: "--shadow-md", description: "Medium elevation shadow." },
    { variable: "--shadow-lg", description: "High elevation shadow." },
    { variable: "--shadow-button", description: "Default button shadow." },
    { variable: "--shadow-button-active", description: "Pressed/active button shadow." }
      ] %>
      <div class="p-4 rounded-lg bg-[var(--surface-background-color)]">
        <%= render "themes/token_table", rows: token_rows %>
      </div>
      </div>

      <div class="space-y-3">
          <%= render FlatPack::SectionTitle::Component.new(title: "Motion", subtitle: "Animation duration tokens for fast, standard, and emphasized UI transitions.", anchor_link: true) %>
                <% token_rows = [
    { variable: "--duration-fast", description: "Fast transition timing." },
    { variable: "--duration-base", description: "Default transition timing." },
    { variable: "--duration-slow", description: "Slow/emphasized transition timing." }
      ] %>
      <div class="p-4 rounded-lg bg-[var(--surface-background-color)]">
        <%= render "themes/token_table", rows: token_rows %>
      </div>
      </div>
    </div>
  </div>


