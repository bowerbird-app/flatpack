<%= render FlatPack::Table::Component.new(data: rows, class: "text-sm") do |table| %>
  <% table.column(
    title: "Variable",
    html: ->(row) { content_tag(:span, sanitize(row[:variable], tags: %w[code], attributes: %w[class]), class: "font-mono text-xs") }
  ) %>
  <% table.column(
    title: "Default value",
    html: ->(row) { content_tag(:span, row[:default_value], class: "font-mono text-xs break-all") }
  ) %>
<% end %>
