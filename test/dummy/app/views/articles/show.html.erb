<div class="max-w-3xl mx-auto p-8">
  <%= render FlatPack::PageTitle::Component.new(
    title: @article.title,
    subtitle: "Published #{@article.created_at.strftime("%B %d, %Y")}"
  ) %>

  <% if flash[:notice] %>
    <%= render FlatPack::Alert::Component.new(
      title: "Success",
      description: flash[:notice],
      variant: :success,
      dismissible: true
    ) %>
  <% end %>

  <div data-controller="article-editor"
       data-article-editor-update-url-value="<%= article_path(@article) %>"
       data-article-editor-upload-url-value="<%= article_upload_image_url %>">

    <%# Balloon toolbar – shown above selected text in edit mode %>
    <style>[data-article-editor-target="displayContent"] a{text-decoration:underline;}</style>
    <div data-article-editor-target="balloonToolbar"
         hidden
         data-action="mousedown->article-editor#keepSelection"
         class="flat-pack-richtext-bubble-menu"
         style="position:fixed;z-index:9999;display:none;">
      <%# Text formatting %>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="bold" title="Bold">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M15.6 10.79c.97-.67 1.65-1.77 1.65-2.79 0-2.26-1.75-4-4-4H7v14h7.04c2.09 0 3.71-1.7 3.71-3.79 0-1.52-.86-2.82-2.15-3.42zM10 6.5h3c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5h-3v-3zm3.5 9H10v-3h3.5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5z"/></svg>
      </button>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="italic" title="Italic">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M10 4v3h2.21l-3.42 8H6v3h8v-3h-2.21l3.42-8H18V4z"/></svg>
      </button>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="underline" title="Underline">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 17c3.31 0 6-2.69 6-6V3h-2.5v8c0 1.93-1.57 3.5-3.5 3.5S8.5 12.93 8.5 11V3H6v8c0 3.31 2.69 6 6 6zm-7 2v2h14v-2H5z"/></svg>
      </button>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="strikeThrough" title="Strikethrough">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M10 19h4v-3h-4v3zM5 4v3h5v3h4V7h5V4H5zM3 14h18v-2H3v2z"/></svg>
      </button>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="removeFormat" title="Clear formatting">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M3.27 5L2 6.27l6.97 6.97L6.5 19h3l1.57-3.66L16.73 21 18 19.73 3.55 5.27 3.27 5zM6 5v.18L8.82 8h2.4l-.72 1.68 2.1 2.1L14.21 8H20V5H6z"/></svg>
      </button>
      <span class="flat-pack-richtext-bubble-sep"></span>
      <%# Headings %>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="h1" title="Heading 1" style="font-size:11px;font-weight:700;width:28px;">H1</button>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="h2" title="Heading 2" style="font-size:11px;font-weight:700;width:28px;">H2</button>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="h3" title="Heading 3" style="font-size:11px;font-weight:700;width:28px;">H3</button>
      <span class="flat-pack-richtext-bubble-sep"></span>
      <%# Lists %>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="insertUnorderedList" title="Bullet list">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M4 10.5c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5 1.5-.67 1.5-1.5-.67-1.5-1.5-1.5zm0-6c-.83 0-1.5.67-1.5 1.5S3.17 7.5 4 7.5 5.5 6.83 5.5 6 4.83 4.5 4 4.5zm0 12c-.83 0-1.5.68-1.5 1.5s.68 1.5 1.5 1.5 1.5-.68 1.5-1.5-.67-1.5-1.5-1.5zM7 19h14v-2H7v2zm0-6h14v-2H7v2zm0-8v2h14V5H7z"/></svg>
      </button>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="insertOrderedList" title="Ordered list">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M2 17h2v.5H3v1h1v.5H2v1h3v-4H2v1zm1-9h1V4H2v1h1v3zm-1 3h1.8L2 13.1v.9h3v-1H3.2L5 10.9V10H2v1zm5-6v2h14V5H7zm0 14h14v-2H7v2zm0-6h14v-2H7v2z"/></svg>
      </button>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="blockquote" title="Blockquote">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/></svg>
      </button>
      <span class="flat-pack-richtext-bubble-sep"></span>
      <%# Link %>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#format" data-command="link" title="Insert / edit link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/></svg>
      </button>
      <span class="flat-pack-richtext-bubble-sep"></span>
      <%# Image upload %>
      <button type="button" class="flat-pack-richtext-bubble-btn" data-action="article-editor#triggerImageUpload" title="Insert image">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
      </button>
      <input data-article-editor-target="imageInput" data-action="change->article-editor#imageInputChanged" type="file" accept="image/*" hidden>
    </div>

    <div class="flex justify-end gap-2 mb-4">
      <button data-article-editor-target="editBtn"
              data-action="article-editor#enableEditing"
              class="flat-pack-btn flat-pack-btn--primary">
        Edit page
      </button>
      <button data-article-editor-target="saveBtn"
              data-action="article-editor#save"
              hidden
              class="flat-pack-btn flat-pack-btn--primary">
        Save
      </button>
      <button data-article-editor-target="cancelBtn"
              data-action="article-editor#cancel"
              hidden
              class="flat-pack-btn flat-pack-btn--secondary">
        Cancel
      </button>
      <%= render FlatPack::Button::Component.new(
        text: "Full Edit",
        url: edit_article_path(@article),
        style: :ghost,
        size: :sm
      ) %>
    </div>

    <div data-article-editor-target="displayContent"
         class="prose max-w-none py-4 focus:outline-none">
      <%= raw @article.body %>
    </div>
  </div>
</div>
