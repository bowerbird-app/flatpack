<div class="container mx-auto max-w-5xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::Images",
    subtitle: "Single-image attachments and multi-image galleries using chat messages plus the carousel lightbox."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_images, anchor: "component-method-variables" %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Single Image Attachment",
      anchor_link: true,
      subtitle: "Use a one-slide carousel inside the message media attachment when you want the same lightbox behavior as gallery posts."
    ) %>

    <div class="mb-4 mt-6 space-y-4 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <%= render FlatPack::Chat::Images::Component.new(
        direction: :incoming,
        state: :sent,
        timestamp: "10:24 AM",
        body: "Draft hero image for launch day. Open the lightbox from the carousel control.",
        carousel: {
          slides: @chat_images_single_incoming_slides,
          show_controls: true,
          show_indicators: false,
          show_thumbs: false,
          show_captions: false,
          aspect_ratio: "4/3",
          aria_label: "Incoming single image message",
          class: "overflow-hidden rounded-2xl"
        }
      ) %>

      <%= render FlatPack::Chat::Images::Component.new(
        direction: :outgoing,
        state: :read,
        timestamp: "10:25 AM",
        body: "Looks good on mobile too.",
        carousel: {
          slides: @chat_images_single_outgoing_slides,
          show_controls: true,
          show_indicators: false,
          show_thumbs: false,
          show_captions: false,
          aspect_ratio: "4/3",
          aria_label: "Outgoing single image message",
          class: "overflow-hidden rounded-2xl"
        }
      ) %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::Images::Component.new(
          direction: :incoming,
          state: :sent,
          timestamp: "10:24 AM",
          body: "Draft hero image for launch day.",
          carousel: {
            slides: [
              { type: :image, src: "https://images.example.com/hero-1.jpg", thumb_src: "https://images.example.com/hero-1-thumb.jpg", lightbox: true }
            ],
            show_controls: true,
            show_indicators: false,
            show_thumbs: false,
            show_captions: false,
            aspect_ratio: "4/3"
          }
        ) %&gt;
      CODE
    ) %>
  </section>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Gallery Using Carousel",
      anchor_link: true,
      subtitle: "For multi-image posts, render the carousel inside a message media attachment and keep lightbox enabled on each slide."
    ) %>

    <div class="mb-4 mt-6 space-y-6 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <%= render FlatPack::Chat::Images::Component.new(
        direction: :incoming,
        state: :sent,
        timestamp: "10:27 AM",
        body: "Sharing the listing set. Use the expand control to inspect each photo in the lightbox.",
        carousel: {
          slides: @chat_images_incoming_slides,
          show_thumbs: true,
          thumbs_position: :bottom,
          thumbs_alignment: :start,
          show_controls: true,
          show_indicators: true,
          show_captions: false,
          aspect_ratio: "4/3",
          aria_label: "Incoming chat image gallery",
          class: "overflow-hidden rounded-2xl"
        }
      ) %>

      <%= render FlatPack::Chat::Images::Component.new(
        direction: :outgoing,
        state: :read,
        timestamp: "10:31 AM",
        body: "Sent the revised mockups as a swipeable gallery instead of stacking separate image cards.",
        carousel: {
          slides: @chat_images_outgoing_slides,
          show_thumbs: true,
          thumbs_position: :bottom,
          thumbs_alignment: :end,
          show_controls: true,
          show_indicators: true,
          show_captions: false,
          aspect_ratio: "4/3",
          aria_label: "Outgoing chat image gallery",
          class: "overflow-hidden rounded-2xl"
        }
      ) %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::Images::Component.new(
          direction: :incoming,
          state: :sent,
          timestamp: "10:27 AM",
          body: "Sharing the listing set.",
          carousel: {
            slides: [
              { type: :image, src: "https://images.example.com/hero-1.jpg", thumb_src: "https://images.example.com/hero-1-thumb.jpg", lightbox: true },
              { type: :image, src: "https://images.example.com/hero-2.jpg", thumb_src: "https://images.example.com/hero-2-thumb.jpg", lightbox: true }
            ],
            show_thumbs: true,
            show_captions: false,
            aspect_ratio: "4/3"
          }
        ) %&gt;
      CODE
    ) %>
  </section>
</div>