<div class="container mx-auto max-w-5xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::MessageList",
    subtitle: "Scrollable message container with jump-to-latest behavior."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_message_list, anchor: "component-method-variables" %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo", anchor_link: true, subtitle: "Scrollable message list with mixed directions.") %>

    <div class="mb-4 mt-6 h-[560px] overflow-hidden rounded-lg border border-(--surface-border-color) bg-(--surface-background-color)">
      <%= render FlatPack::Chat::MessageList::Component.new(stick_to_bottom: true) do %>
        <%= render FlatPack::Chat::DateDivider::Component.new(label: "Earlier") %>
        <% 12.times do |index| %>
          <%= render FlatPack::Chat::Message::Component.new(direction: (index.even? ? :incoming : :outgoing), timestamp: "9:#{format('%02d', index)} AM") do %>
            Message <%= index + 1 %> inside the message list component.
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::MessageList::Component.new(stick_to_bottom: true) do %&gt;
          &lt;%= render FlatPack::Chat::DateDivider::Component.new(label: "Earlier") %&gt;
          &lt;% 12.times do |index| %&gt;
            &lt;%= render FlatPack::Chat::Message::Component.new(
              direction: (index.even? ? :incoming : :outgoing),
              timestamp: "9:#{format('%02d', index)} AM"
            ) do %&gt;
              Message &lt;%= index + 1 %&gt; inside the message list component.
            &lt;% end %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>
</div>