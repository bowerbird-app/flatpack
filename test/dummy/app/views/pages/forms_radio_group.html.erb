<%= render FlatPack::PageTitle::Component.new(
  title: "Radio Group",
  subtitle: "Single-select choice lists using grouped radio inputs."
) %>

<%= render "pages/component_method_variables_table", component: :text_input %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Radio Group Examples", anchor_link: true) %>

  <%= render FlatPack::Card::Component.new do |card| %>
    <% card.body(class: "space-y-[var(--stack-gap-md)]") do %>
      <%= render FlatPack::RadioGroup::Component.new(
        name: "size",
        options: ["Small", "Medium", "Large"],
        label: "Choose a size",
        value: "Medium"
      ) %>

      <%= render FlatPack::RadioGroup::Component.new(
        name: "payment_method",
        options: ["Credit Card", "PayPal", "Bank Transfer"],
        label: "Payment Method",
        required: true
      ) %>
    <% end %>
  <% end %>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;%= render FlatPack::Card::Component.new do |card| %&gt;
        &lt;% card.body do %&gt;
        &lt;%= render FlatPack::RadioGroup::Component.new(
          name: &quot;size&quot;,
          options: [&quot;Small&quot;, &quot;Medium&quot;, &quot;Large&quot;],
          label: &quot;Choose a size&quot;,
          value: &quot;Medium&quot;
        ) %&gt;
    
        &lt;%= render FlatPack::RadioGroup::Component.new(
          name: &quot;payment_method&quot;,
          options: [&quot;Credit Card&quot;, &quot;PayPal&quot;, &quot;Bank Transfer&quot;],
          label: &quot;Payment Method&quot;,
          required: true
        ) %&gt;
        &lt;% end %&gt;
      &lt;% end %&gt;
    CODE
    language: "erb",
    title: "Radio Group Examples"
  ) %>
</section>
