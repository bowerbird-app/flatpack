<div class="container mx-auto max-w-4xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::Message",
    subtitle: "Message bubbles for incoming, outgoing, system, and delivery states."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_message, anchor: "component-method-variables" %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo", anchor_link: true, subtitle: "Message bubble variants and delivery states.") %>

    <div class="mb-4 mt-6 space-y-3 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <%= render FlatPack::Chat::Message::Component.new(direction: :incoming, state: :sent) do %>
        Could you share the latest launch checklist when you have a minute?
      <% end %>
      <%= render FlatPack::Chat::Message::Component.new(direction: :outgoing, state: :sending) do %>
        Uploading now — I just added rollout notes for support and QA.
      <% end %>
      <%= render FlatPack::Chat::Message::Component.new(direction: :outgoing, state: :failed) do %>
        Looks like that message didn’t go through. I’ll retry with the attachment compressed.
      <% end %>
      <%= render FlatPack::Chat::Message::Component.new(variant: :system) do %>
        Alex renamed the channel to Product Launch
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::Message::Component.new(direction: :incoming, state: :sent) do %&gt;
          Could you share the latest launch checklist when you have a minute?
        &lt;% end %&gt;
        &lt;%= render FlatPack::Chat::Message::Component.new(direction: :outgoing, state: :sending) do %&gt;
          Uploading now — I just added rollout notes for support and QA.
        &lt;% end %&gt;
        &lt;%= render FlatPack::Chat::Message::Component.new(direction: :outgoing, state: :failed) do %&gt;
          Looks like that message didn’t go through. I’ll retry with the attachment compressed.
        &lt;% end %&gt;
        &lt;%= render FlatPack::Chat::Message::Component.new(variant: :system) do %&gt;
          Alex renamed the channel to Product Launch
        &lt;% end %&gt;
      CODE
    ) %>
  </section>
</div>