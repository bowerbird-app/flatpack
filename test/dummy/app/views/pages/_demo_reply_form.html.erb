<div class="pt-2">
  <%= form_with url: replies_demo_comment_path(parent_comment), method: :post, local: true do %>
    <%= render FlatPack::Comments::Composer::Component.new(
        name: "comment[body]",
        placeholder: "Write a reply...",
        submit_label: "Reply",
        compact: true,
        rows: 2
      ) do |composer| %>
      <% composer.actions do %>
        <div class="flex items-center justify-end w-full gap-2">
          <%= render FlatPack::Button::Component.new(
            text: "Cancel",
            url: demo_comments_path(anchor: "comment-#{parent_comment.id}"),
            style: :ghost,
            size: :sm
          ) %>

          <%= render FlatPack::Button::Component.new(
            text: "Reply",
            type: "submit",
            style: :primary,
            size: :sm
          ) %>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
