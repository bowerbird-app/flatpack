<div class="container mx-auto max-w-5xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat Demo",
    subtitle: "A complete chat panel with message bubbles and composer input."
  ) %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo", anchor_link: true, subtitle: "End-to-end chat panel composition.") %>

    <div class="mb-4 mt-6 h-[620px] overflow-hidden rounded-lg border border-(--surface-border-color) bg-(--surface-background-color)">
      <%= render(FlatPack::Chat::Panel::Component.new) do |panel| %>
        <% panel.with_header do %>
          <div class="flex items-center justify-between p-4">
            <div>
              <h2 class="text-base font-semibold text-(--surface-content-color)">Design Team</h2>
              <p class="text-sm text-(--surface-muted-content-color)">4 people online</p>
            </div>
            <%= render(FlatPack::AvatarGroup::Component.new(
              items: [
                {name: "Alex Rivera", initials: "AR"},
                {name: "Mina Cho", initials: "MC"},
                {name: "Sam Lee", initials: "SL"},
                {name: "Jo Kim", initials: "JK"}
              ],
              size: :sm,
              max: 4
            )) %>
          </div>
        <% end %>

        <% panel.with_messages do %>
          <%= render FlatPack::Chat::MessageList::Component.new do %>
            <%= render FlatPack::Chat::DateDivider::Component.new(label: "Today") %>

            <%= render FlatPack::Chat::MessageGroup::Component.new(
              direction: :incoming,
              show_avatar: true,
              show_name: true,
              sender_name: "Mina"
            ) do |group| %>
              <% group.with_avatar do %>
                <%= render FlatPack::Avatar::Component.new(name: "Mina Cho", initials: "MC", size: :sm) %>
              <% end %>
              <% group.with_message do %>
                <%= render FlatPack::Chat::Message::Component.new(direction: :incoming, timestamp: "10:12 AM") do |message| %>
                  I pushed the homepage copy updates. Can someone review?
                  <% message.with_meta do %>
                    <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "10:12 AM", state: :read) %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>

            <%= render FlatPack::Chat::MessageGroup::Component.new(direction: :outgoing, show_avatar: false) do |group| %>
              <% group.with_message do %>
                <%= render FlatPack::Chat::Message::Component.new(direction: :outgoing, timestamp: "10:13 AM") do |message| %>
                  Reviewed. Tone is solid — can you also add a shorter hero variant for mobile?
                  <% message.with_meta do %>
                    <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "10:13 AM", state: :read) %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>

            <%= render FlatPack::Chat::MessageGroup::Component.new(direction: :outgoing, show_avatar: false) do |group| %>
              <% group.with_message do %>
                <%= render FlatPack::Chat::Message::Component.new(direction: :outgoing, timestamp: "10:14 AM") do |message| %>
                  Looks good. I will handle the final QA pass.
                  <% message.with_meta do %>
                    <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "10:14 AM", state: :read) %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>

            <%= render FlatPack::Chat::MessageGroup::Component.new(
              direction: :incoming,
              show_avatar: true,
              show_name: true,
              sender_name: "Sam"
            ) do |group| %>
              <% group.with_avatar do %>
                <%= render FlatPack::Avatar::Component.new(name: "Sam Lee", initials: "SL", size: :sm) %>
              <% end %>
              <% group.with_message do %>
                <%= render FlatPack::Chat::Message::Component.new(direction: :incoming, timestamp: "10:15 AM") do |message| %>
                  I added both hero lengths and updated CTA spacing.
                  <% message.with_meta do %>
                    <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "10:15 AM", state: :read) %>
                  <% end %>
                <% end %>
              <% end %>
              <% group.with_message do %>
                <%= render FlatPack::Chat::Message::Component.new(direction: :incoming, timestamp: "10:16 AM") do |message| %>
                  Sharing the latest visual snapshot below.
                  <% message.with_attachment do %>
                    <%= render FlatPack::Chat::Attachment::Component.new(
                      type: :image,
                      name: "homepage-preview.png",
                      thumbnail_url: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=640&h=360&fit=crop",
                      href: "#"
                    ) %>
                  <% end %>
                  <% message.with_meta do %>
                    <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "10:16 AM", state: :read) %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>

            <%= render FlatPack::Chat::MessageGroup::Component.new(
              direction: :incoming,
              show_avatar: true,
              show_name: true,
              sender_name: "Alex"
            ) do |group| %>
              <% group.with_avatar do %>
                <%= render FlatPack::Avatar::Component.new(name: "Alex Rivera", initials: "AR", size: :sm) %>
              <% end %>
              <% group.with_message do %>
                <%= render FlatPack::Chat::Message::Component.new(direction: :incoming, timestamp: "10:17 AM") do |message| %>
                  Added the sprint board screenshot for context.
                  <% message.with_attachment do %>
                    <%= render FlatPack::Chat::Attachment::Component.new(
                      type: :file,
                      name: "sprint-board.png",
                      meta: "1.1 MB"
                    ) %>
                  <% end %>
                  <% message.with_meta do %>
                    <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "10:17 AM", state: :read) %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>

            <%= render FlatPack::Chat::MessageGroup::Component.new(direction: :outgoing, show_avatar: false) do |group| %>
              <% group.with_message do %>
                <%= render FlatPack::Chat::Message::Component.new(direction: :outgoing, timestamp: "10:18 AM") do |message| %>
                  Perfect, thanks. I also need the editable source file in case we adjust copy after legal review.
                  <% message.with_meta do %>
                    <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "10:18 AM", state: :read) %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>

            <%= render FlatPack::Chat::MessageGroup::Component.new(
              direction: :incoming,
              show_avatar: true,
              show_name: false,
              sender_name: "Mina"
            ) do |group| %>
              <% group.with_avatar do %>
                <%= render FlatPack::Avatar::Component.new(name: "Mina Cho", initials: "MC", size: :sm) %>
              <% end %>
              <% group.with_message do %>
                <%= render FlatPack::Chat::Message::Component.new(direction: :incoming, timestamp: "10:19 AM") do |message| %>
                  Uploaded. It includes all revised headings and alt-text notes.
                  <% message.with_attachment do %>
                    <%= render FlatPack::Chat::Attachment::Component.new(
                      type: :file,
                      name: "homepage-copy-v4.docx",
                      meta: "248 KB",
                      href: "#"
                    ) %>
                  <% end %>
                  <% message.with_meta do %>
                    <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "10:19 AM", state: :read) %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>

            <%= render FlatPack::Chat::MessageGroup::Component.new(direction: :outgoing, show_avatar: false) do |group| %>
              <% group.with_message do %>
                <%= render FlatPack::Chat::Message::Component.new(direction: :outgoing, timestamp: "10:21 AM") do |message| %>
                  Great. Queueing final pass now.
                  <% message.with_meta do %>
                    <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "10:21 AM", state: :read) %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>

            <%= render FlatPack::Chat::MessageGroup::Component.new(
              direction: :incoming,
              show_avatar: true,
              show_name: false,
              sender_name: "Alex"
            ) do |group| %>
              <% group.with_avatar do %>
                <%= render FlatPack::Avatar::Component.new(name: "Alex Rivera", initials: "AR", size: :sm) %>
              <% end %>
              <% group.with_message do %>
                <%= render FlatPack::Chat::Message::Component.new(direction: :incoming, timestamp: "10:22 AM") do |message| %>
                  I will monitor launch metrics and post updates every 15 minutes once we ship.
                  <% message.with_meta do %>
                    <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "10:22 AM", state: :read) %>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>

            <%= render FlatPack::Chat::TypingIndicator::Component.new(label: "Sam is typing") do |indicator| %>
              <% indicator.with_avatar do %>
                <%= render FlatPack::Avatar::Component.new(name: "Sam Lee", initials: "SL", size: :sm) %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>

        <% panel.with_composer do %>
          <%= form_with url: "#", method: :post, local: true,
              data: {
                controller: "flat-pack--chat-sender",
                action: "submit->flat-pack--chat-sender#submit",
                flat_pack__chat_sender_thread_selector_value: "[data-flat-pack--chat-scroll-target='messages']"
              } do %>
            <%= render FlatPack::Chat::Composer::Component.new(style: "border-top: 0") do |composer| %>
              <% composer.left do %>
                <%= render FlatPack::Button::Dropdown::Component.new(
                  text: "",
                  icon: "plus",
                  style: :default,
                  size: :md,
                  show_chevron: false,
                  position: :top_left,
                  aria: {label: "Attach options"}
                ) do |dropdown| %>
                  <% dropdown.with_menu_item(text: "Upload file", icon: "file", href: "#") %>
                  <% dropdown.with_menu_item(text: "Attach from library", icon: "folder", href: "#") %>
                <% end %>
              <% end %>

              <% composer.center do %>
                <%= render FlatPack::Chat::Textarea::Component.new(
                  name: "chat[message]",
                  placeholder: "Write a message...",
                  autogrow: true,
                  submit_on_enter: true
                ) %>
              <% end %>
              <% composer.right do %>
                <%= render FlatPack::Chat::SendButton::Component.new %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render(FlatPack::Chat::Panel::Component.new) do |panel| %&gt;
          &lt;% panel.with_header do %&gt;
            &lt;div class="flex items-center justify-between p-4"&gt;...&lt;/div&gt;
          &lt;% end %&gt;

          &lt;% panel.with_messages do %&gt;
            &lt;%= render FlatPack::Chat::MessageList::Component.new do %&gt;
              &lt;%= render FlatPack::Chat::DateDivider::Component.new(label: "Today") %&gt;
              &lt;%= render FlatPack::Chat::MessageGroup::Component.new(direction: :incoming, show_avatar: true, show_name: true, sender_name: "Mina") do |group| %&gt;
                &lt;% group.with_message do %&gt;
                  &lt;%= render FlatPack::Chat::Message::Component.new(direction: :incoming, timestamp: "10:12 AM") { "I pushed the homepage copy updates." } %&gt;
                &lt;% end %&gt;
              &lt;% end %&gt;
            &lt;% end %&gt;
          &lt;% end %&gt;

          &lt;% panel.with_composer do %&gt;
            &lt;%= form_with url: &quot;#&quot;, method: :post, local: true,
                data: {
                  controller: &quot;flat-pack--chat-sender&quot;,
                  action: &quot;submit-&gt;flat-pack--chat-sender#submit&quot;,
                  flat_pack__chat_sender_thread_selector_value: &quot;[data-flat-pack--chat-scroll-target='messages']&quot;
                } do %&gt;
            &lt;%= render FlatPack::Chat::Composer::Component.new(style: &quot;border-top: 0&quot;) do |composer| %&gt;
              &lt;% composer.left do %&gt;
                &lt;%= render FlatPack::Button::Dropdown::Component.new(
                  text: &quot;&quot;,
                  icon: &quot;plus&quot;,
                  style: :default,
                  size: :md,
                  show_chevron: false,
                  position: :top_left,
                  aria: {label: &quot;Attach options&quot;}
                ) do |dropdown| %&gt;
                  &lt;% dropdown.with_menu_item(text: &quot;Upload file&quot;, icon: &quot;file&quot;, href: &quot;#&quot;) %&gt;
                  &lt;% dropdown.with_menu_item(text: &quot;Attach from library&quot;, icon: &quot;folder&quot;, href: &quot;#&quot;) %&gt;
                &lt;% end %&gt;
              &lt;% end %&gt;

              &lt;% composer.center do %&gt;
                &lt;%= render FlatPack::Chat::Textarea::Component.new(name: "chat[message]", autogrow: true, submit_on_enter: true) %&gt;
              &lt;% end %&gt;
              &lt;% composer.right do %&gt;
                &lt;%= render FlatPack::Chat::SendButton::Component.new %&gt;
              &lt;% end %&gt;
            &lt;% end %&gt;
            &lt;% end %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>
</div>