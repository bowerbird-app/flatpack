<%= render FlatPack::PageTitle::Component.new(
  title: "URL Input",
  subtitle: "URL field examples with valid and invalid values."
) %>

<%= render "pages/component_method_variables_table", component: :text_input %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "URL Input Examples", anchor_link: true) %>

  <%= render FlatPack::Card::Component.new do |card| %>
    <% card.body(class: "space-y-[var(--stack-gap-md)]") do %>
      <%= render FlatPack::UrlInput::Component.new(
        name: "website",
        label: "Website URL",
        placeholder: "https://example.com"
      ) %>

      <%= render FlatPack::UrlInput::Component.new(
        name: "website_error",
        label: "Website (with error)",
        value: "not-a-url",
        error: "Please enter a valid URL"
      ) %>
    <% end %>
  <% end %>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;%= render FlatPack::Card::Component.new do |card| %&gt;
        &lt;% card.body do %&gt;
        &lt;%= render FlatPack::UrlInput::Component.new(
          name: &quot;website&quot;,
          label: &quot;Website URL&quot;,
          placeholder: &quot;https://example.com&quot;
        ) %&gt;
    
        &lt;%= render FlatPack::UrlInput::Component.new(
          name: &quot;website_error&quot;,
          label: &quot;Website (with error)&quot;,
          value: &quot;not-a-url&quot;,
          error: &quot;Please enter a valid URL&quot;
        ) %&gt;
        &lt;% end %&gt;
      &lt;% end %&gt;
    CODE
    language: "erb",
    title: "URL Input Examples"
  ) %>
</section>
