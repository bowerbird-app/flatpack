<%= render FlatPack::PageTitle::Component.new(
  title: "Progress Bar Component",
  subtitle: "Display task completion or loading progress with customizable variants and sizes."
) %>

<%= render "pages/component_method_variables_table", component: :progress %>

<%
  progress_theme_token_rows = [
    { variable: "--surface-content-color", default_value: "var(--surface-content-color)" },
    { variable: "--surface-muted-background-color", default_value: "var(--surface-muted-background-color)" },
    { variable: "--color-primary", default_value: "var(--color-primary)" },
    { variable: "--color-success-background-color", default_value: "var(--color-success-background-color)" },
    { variable: "--color-warning-background-color", default_value: "var(--color-warning-background-color)" },
    { variable: "--color-danger-background-color", default_value: "var(--color-danger-background-color)" }
  ]
%>

<%= render "pages/theme_token_reference", title: "Progress", rows: progress_theme_token_rows %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Basic Progress Bars", anchor_link: true) %>
  
  <div class="space-y-6 p-6 bg-[var(--surface-background-color)] border border-[var(--surface-border-color)] rounded-lg">
    <div>
      <p class="text-sm text-[var(--surface-muted-content-color)] mb-2">Default (50%)</p>
      <%= render FlatPack::Progress::Component.new(value: 50) %>
    </div>

    <div>
      <p class="text-sm text-[var(--surface-muted-content-color)] mb-2">With Label</p>
      <%= render FlatPack::Progress::Component.new(value: 75, label: "Upload Progress") %>
    </div>

    <div>
      <p class="text-sm text-[var(--surface-muted-content-color)] mb-2">Show Percentage</p>
      <%= render FlatPack::Progress::Component.new(value: 80, show_label: true) %>
    </div>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;space-y-6 p-6 bg-[var(--surface-background-color)] border border-[var(--surface-border-color)] rounded-lg&quot;&gt;
        &lt;div&gt;
          &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)] mb-2&quot;&gt;Default (50%)&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(value: 50) %&gt;
        &lt;/div&gt;
    
        &lt;div&gt;
          &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)] mb-2&quot;&gt;With Label&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(value: 75, label: &quot;Upload Progress&quot;) %&gt;
        &lt;/div&gt;
    
        &lt;div&gt;
          &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)] mb-2&quot;&gt;Show Percentage&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(value: 80, show_label: true) %&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Basic Progress Bars"
  ) %>
</section>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Variants", anchor_link: true) %>
  
  <div class="space-y-6 p-6 bg-[var(--surface-background-color)] border border-[var(--surface-border-color)] rounded-lg">
    <div>
      <p class="text-sm text-[var(--surface-muted-content-color)] mb-2">Default</p>
      <%= render FlatPack::Progress::Component.new(value: 60, variant: :default) %>
    </div>

    <div>
      <p class="text-sm text-[var(--surface-muted-content-color)] mb-2">Success</p>
      <%= render FlatPack::Progress::Component.new(value: 100, variant: :success) %>
    </div>

    <div>
      <p class="text-sm text-[var(--surface-muted-content-color)] mb-2">Warning</p>
      <%= render FlatPack::Progress::Component.new(value: 60, variant: :warning) %>
    </div>

    <div>
      <p class="text-sm text-[var(--surface-muted-content-color)] mb-2">Danger</p>
      <%= render FlatPack::Progress::Component.new(value: 30, variant: :danger) %>
    </div>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;space-y-6 p-6 bg-[var(--surface-background-color)] border border-[var(--surface-border-color)] rounded-lg&quot;&gt;
        &lt;div&gt;
          &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)] mb-2&quot;&gt;Default&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(value: 60, variant: :default) %&gt;
        &lt;/div&gt;
    
        &lt;div&gt;
          &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)] mb-2&quot;&gt;Success&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(value: 100, variant: :success) %&gt;
        &lt;/div&gt;
    
        &lt;div&gt;
          &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)] mb-2&quot;&gt;Warning&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(value: 60, variant: :warning) %&gt;
        &lt;/div&gt;
    
        &lt;div&gt;
          &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)] mb-2&quot;&gt;Danger&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(value: 30, variant: :danger) %&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Variants"
  ) %>
</section>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Sizes", anchor_link: true) %>
  
  <div class="space-y-6 p-6 bg-[var(--surface-background-color)] border border-[var(--surface-border-color)] rounded-lg">
    <div>
      <p class="text-sm text-[var(--surface-muted-content-color)] mb-2">Small</p>
      <%= render FlatPack::Progress::Component.new(value: 65, size: :sm) %>
    </div>

    <div>
      <p class="text-sm text-[var(--surface-muted-content-color)] mb-2">Medium</p>
      <%= render FlatPack::Progress::Component.new(value: 65, size: :md) %>
    </div>

    <div>
      <p class="text-sm text-[var(--surface-muted-content-color)] mb-2">Large</p>
      <%= render FlatPack::Progress::Component.new(value: 65, size: :lg) %>
    </div>

    <div>
      <p class="text-sm text-[var(--surface-muted-content-color)] mb-2">Extra Large</p>
      <%= render FlatPack::Progress::Component.new(value: 65, size: :xl) %>
    </div>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;space-y-6 p-6 bg-[var(--surface-background-color)] border border-[var(--surface-border-color)] rounded-lg&quot;&gt;
        &lt;div&gt;
          &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)] mb-2&quot;&gt;Small&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(value: 65, size: :sm) %&gt;
        &lt;/div&gt;
    
        &lt;div&gt;
          &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)] mb-2&quot;&gt;Medium&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(value: 65, size: :md) %&gt;
        &lt;/div&gt;
    
        &lt;div&gt;
          &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)] mb-2&quot;&gt;Large&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(value: 65, size: :lg) %&gt;
        &lt;/div&gt;
    
        &lt;div&gt;
          &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)] mb-2&quot;&gt;Extra Large&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(value: 65, size: :xl) %&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Sizes"
  ) %>
</section>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Use Cases", anchor_link: true) %>
  
  <div class="space-y-6 p-6 bg-[var(--surface-background-color)] border border-[var(--surface-border-color)] rounded-lg">
    <div>
      <p class="text-sm font-medium mb-2">File Upload</p>
      <%= render FlatPack::Progress::Component.new(
        value: 45,
        label: "uploading-document.pdf (4.5 MB / 10 MB)",
        variant: :default,
        size: :md
      ) %>
    </div>

    <div>
      <p class="text-sm font-medium mb-2">Multi-Step Form</p>
      <%= render FlatPack::Progress::Component.new(
        value: 3,
        max: 5,
        label: "Step 3 of 5",
        variant: :default
      ) %>
    </div>

    <div>
      <p class="text-sm font-medium mb-2">Task Completion</p>
      <%= render FlatPack::Progress::Component.new(
        value: 85,
        show_label: true,
        label: "Project Tasks",
        variant: :success
      ) %>
    </div>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;space-y-6 p-6 bg-[var(--surface-background-color)] border border-[var(--surface-border-color)] rounded-lg&quot;&gt;
        &lt;div&gt;
          &lt;p class=&quot;text-sm font-medium mb-2&quot;&gt;File Upload&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(
            value: 45,
            label: &quot;uploading-document.pdf (4.5 MB / 10 MB)&quot;,
            variant: :default,
            size: :md
          ) %&gt;
        &lt;/div&gt;
    
        &lt;div&gt;
          &lt;p class=&quot;text-sm font-medium mb-2&quot;&gt;Multi-Step Form&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(
            value: 3,
            max: 5,
            label: &quot;Step 3 of 5&quot;,
            variant: :default
          ) %&gt;
        &lt;/div&gt;
    
        &lt;div&gt;
          &lt;p class=&quot;text-sm font-medium mb-2&quot;&gt;Task Completion&lt;/p&gt;
          &lt;%= render FlatPack::Progress::Component.new(
            value: 85,
            show_label: true,
            label: &quot;Project Tasks&quot;,
            variant: :success
          ) %&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Use Cases"
  ) %>
</section>
