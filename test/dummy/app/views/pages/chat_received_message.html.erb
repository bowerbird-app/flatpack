<div class="container mx-auto max-w-4xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::ReceivedMessage",
    subtitle: "Incoming message bubble with optional click-to-reveal actions."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_received_message, anchor: "component-method-variables" %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo", anchor_link: true, subtitle: "Simple incoming message using click-to-slide reveal actions.") %>

    <div class="mb-4 mt-6 space-y-4 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <%= render FlatPack::Chat::ReceivedMessage::Component.new(
        state: :sent,
        reveal_actions: true,
        timestamp: Time.current.change(hour: 10, min: 12)
      ) do %>
        Received and reviewed — click this bubble to slide and reveal message details.
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::ReceivedMessage::Component.new(state: :sent, reveal_actions: true, timestamp: Time.current) do %&gt;
          Received and reviewed — click this bubble to slide and reveal message details.
        &lt;% end %&gt;
      CODE
    ) %>
  </section>
</div>
