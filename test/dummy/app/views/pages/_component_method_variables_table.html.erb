        { variable: "name", accepts: "String (required)", example: "name: \"volume\"" },
        { variable: "id", accepts: "String or nil", example: "id: \"volume-slider\"" },
        { variable: "value", accepts: "Numeric or nil", example: "value: 50" },
        { variable: "min", accepts: "Numeric", example: "min: 0" },
        { variable: "max", accepts: "Numeric", example: "max: 100" },
        { variable: "step", accepts: "Numeric", example: "step: 1" },
        { variable: "label", accepts: "String or nil", example: "label: \"Volume\"" },
        { variable: "show_value", accepts: "true, false", example: "show_value: true" },
        { variable: "disabled", accepts: "true, false", example: "disabled: true" },
        { variable: "**system_arguments", accepts: "Hash", example: "class: \"w-full\", data: { testid: \"range-input\" }" }
      ]
    },
    grid: {
      label: "Grid",
      method_call: "render FlatPack::Grid::Component.new(cols: :auto, gap: :md) do ... end",
      variables: [
        { variable: "cols", accepts: ":auto, Integer", example: "cols: 3" },
        { variable: "gap", accepts: ":none, :xs, :sm, :md, :lg, :xl", example: "gap: :lg" },
        { variable: "align", accepts: ":start, :center, :end, :stretch", example: "align: :stretch" }
      ]
    },
    list: {
      label: "List",
      method_call: "render FlatPack::List::Component.new(ordered: false, spacing: :comfortable, divider: false, selectable: false) do ... end",
      variables: [
        { variable: "ordered", accepts: "true, false", example: "ordered: true" },
        { variable: "spacing", accepts: ":comfortable, :dense", example: "spacing: :dense" },
        { variable: "divider", accepts: "true, false", example: "divider: true" },
        { variable: "selectable", accepts: "true, false", example: "selectable: true" },
        { variable: "**system_arguments", accepts: "Hash", example: "class: \"mt-4\", id: \"settings-list\"" }
      ]
    },
    list_item: {
      label: "List Item",
      method_call: "render FlatPack::List::Item.new(icon: :check, href: demo_buttons_path, hover: true, active: false) { \"Task completed\" }",
      variables: [
        { variable: "icon", accepts: "Symbol/String/SVG String or nil", example: "icon: :check" },
        { variable: "leading", accepts: "String/HTML or nil", example: "leading: content_tag(:strong, \"1\")" },
        { variable: "trailing", accepts: "String/HTML or nil", example: "trailing: render(FlatPack::Badge::Component.new(text: \"New\"))" },
        { variable: "href", accepts: "String URL or nil", example: "href: demo_tables_basic_path" },
        { variable: "hover", accepts: "true, false", example: "hover: true" },
        { variable: "active", accepts: "true, false", example: "active: true" },
        { variable: "link_arguments", accepts: "Hash", example: "link_arguments: { data: { turbo: true }, class: \"group\" }" },
        { variable: "**system_arguments", accepts: "Hash", example: "class: \"py-1\", id: \"list-item-1\"" }
      ]
    },
    text_input: {
      label: "Input",
      method_call: "render FlatPack::TextInput::Component.new(name: \"username\", label: \"Username\")",
      variables: [
        { variable: "name", accepts: "String (required)", example: "name: \"user[email]\"" },
        { variable: "value", accepts: "String, Numeric, Date, Time, DateTime, nil", example: "value: \"john.doe\"" },
        { variable: "placeholder", accepts: "String or nil", example: "placeholder: \"you@example.com\"" },
        { variable: "disabled", accepts: "true, false", example: "disabled: true" },
        { variable: "required", accepts: "true, false", example: "required: true" },
        { variable: "label", accepts: "String or nil", example: "label: \"Email\"" },
        { variable: "error", accepts: "String or nil", example: "error: \"Email is invalid\"" },
        { variable: "**system_arguments", accepts: "Hash", example: "id: \"email\", class: \"w-full\", data: { testid: \"email-input\" }" }
      ]
    },
    modal: {
      label: "Modal",
      method_call: "render FlatPack::Modal::Component.new(id: \"confirm-delete\", size: :md) do |modal| ... end",
      variables: [
        { variable: "id", accepts: "String (required)", example: "id: \"edit-profile-modal\"" },
        { variable: "size", accepts: ":sm, :md, :lg, :xl, :\"2xl\"", example: "size: :lg" },
        { variable: "close_on_escape", accepts: "true, false", example: "close_on_escape: true" }
      ]
    },
    top_nav: {
      label: "Top Nav",
      method_call: "render FlatPack::TopNav::Component.new do |nav| ... end",
      variables: [
        { variable: "left", accepts: "slot block", example: "nav.left { \"Brand\" }" },
        { variable: "center", accepts: "slot block", example: "nav.center { render FlatPack::Search::Component.new }" },
        { variable: "right", accepts: "slot block", example: "nav.right { render FlatPack::Avatar::Component.new(...) }" }
      ]
    },
    page_title: {
      label: "Page Title",
      method_call: "render FlatPack::PageTitle::Component.new(title: \"Dashboard\", subtitle: \"Overview\", variant: :h2)",
      variables: [
        { variable: "title", accepts: "String (required)", example: "title: \"Account Settings\"" },
        { variable: "subtitle", accepts: "String or nil", example: "subtitle: \"Manage your profile and preferences.\"" },
        { variable: "variant", accepts: ":h1, :h2, :h3, :h4, :h5, :h6", example: "variant: :h3" },
        { variable: "**system_arguments", accepts: "Hash", example: "class: \"mb-8\", id: \"settings-title\"" }
      ]
    },
    quote: {
      label: "Quote",
      method_call: "render FlatPack::Quote::Component.new(text: \"Good design is as little design as possible.\", cite: \"Dieter Rams\")",
      variables: [
        { variable: "text", accepts: "String or block content", example: "text: \"Good design is as little design as possible.\"" },
        { variable: "cite", accepts: "String or nil", example: "cite: \"Dieter Rams\"" },
        { variable: "size", accepts: ":sm, :md, :lg", example: "size: :lg" }
      ]
    },
    pagination: {
      label: "Pagination",
      method_call: "render FlatPack::Pagination::Component.new(pagy: @pagy)",
      variables: [
        { variable: "pagy", accepts: "Pagy instance (required)", example: "pagy: @pagy" },
        { variable: "size", accepts: ":compact, :normal", example: "size: :compact" },
        { variable: "class", accepts: "String or nil", example: "class: \"mt-6\"" }
      ]
    },
    popover: {
      label: "Popover",
      method_call: "render FlatPack::Popover::Component.new(trigger_id: \"help-btn\", placement: :right) do |popover| popover.content { \"Help text\" } end",
      variables: [
        { variable: "trigger_id", accepts: "String (required)", example: "trigger_id: \"profile-help\"" },
        { variable: "placement", accepts: ":top, :right, :bottom, :left", example: "placement: :bottom" },
        { variable: "content", accepts: "slot block", example: "popover.content { \"Help text\" }" }
      ]
    },
    progress: {
      label: "Progress",
      method_call: "render FlatPack::Progress::Component.new(value: 72, max: 100, variant: :default, size: :md, show_label: true)",
      variables: [
        { variable: "value", accepts: "Numeric (required)", example: "value: 72" },
        { variable: "max", accepts: "Numeric", example: "max: 100" },
        { variable: "variant", accepts: ":default, :success, :warning, :danger", example: "variant: :success" },
        { variable: "size", accepts: ":sm, :md, :lg, :xl", example: "size: :lg" },
        { variable: "label", accepts: "String or nil", example: "label: \"Upload Progress\"" },
        { variable: "show_label", accepts: "true, false", example: "show_label: true" },
        { variable: "**system_arguments", accepts: "Hash", example: "class: \"w-full\", data: { testid: \"progress\" }" }
      ]
    },
    search: {
      label: "Search",
      method_call: "render FlatPack::Search::Component.new(name: \"query\", placeholder: \"Search...\")",
      variables: [
        { variable: "placeholder", accepts: "String", example: "placeholder: \"Search components...\"" },
        { variable: "name", accepts: "String", example: "name: \"query\"" },
        { variable: "value", accepts: "String or nil", example: "value: \"tabs\"" },
        { variable: "search_url", accepts: "Relative/allowed URL or nil", example: "search_url: demo_search_path" },
        { variable: "max_width", accepts: ":none, :md, :lg, :xl", example: "max_width: :lg" },
        { variable: "min_characters", accepts: "Integer", example: "min_characters: 2" },
        { variable: "debounce", accepts: "Integer (ms)", example: "debounce: 250" },
        { variable: "no_results_text", accepts: "String", example: "no_results_text: \"No matching components\"" },
        { variable: "**system_arguments", accepts: "Hash", example: "class: \"max-w-xl\", data: { testid: \"search\" }" }
      ]
    },
    skeleton: {
      label: "Skeleton",
      method_call: "render FlatPack::Skeleton::Component.new(variant: :text, width: \"240px\", shimmer: true)",
      variables: [
        { variable: "variant", accepts: ":text, :title, :avatar, :button, :rectangle", example: "variant: :title" },
        { variable: "width", accepts: "String or nil", example: "width: \"320px\"" },
        { variable: "height", accepts: "String or nil", example: "height: \"96px\"" },
        { variable: "shimmer", accepts: "true, false", example: "shimmer: false" },
        { variable: "**system_arguments", accepts: "Hash", example: "class: \"rounded-xl\", id: \"profile-skeleton\"" }
      ]
    },
    sidebar_layout: {
      label: "Sidebar Layout",
      method_call: "render FlatPack::SidebarLayout::Component.new(side: :left, default_open: true) do |layout| ... end",
      variables: [
        { variable: "side", accepts: ":left, :right", example: "side: :right" },
        { variable: "default_open", accepts: "true, false", example: "default_open: false" },
        { variable: "storage_key", accepts: "String or nil", example: "storage_key: \"demo-sidebar-state\"" }
      ]
    },
    table: {
      label: "Table",
      method_call: "render FlatPack::Table::Component.new(data: @users) do |table| ... end",
      variables: [
        { variable: "data", accepts: "Array/Enumerable", example: "data: @users" },
        { variable: "column", accepts: "title:, html:, sortable:, sort_key:", example: "table.column(title: \"Email\", sortable: true, sort_key: :email)" },
        { variable: "direction", accepts: ":asc, :desc", example: "direction: :desc" }
      ]
    },
    tabs: {
      label: "Tabs",
      method_call: "render FlatPack::Tabs::Component.new(variant: :pills) do |tabs| ... end",
      variables: [
        { variable: "variant", accepts: ":underline, :pills, :stacked", example: "variant: :stacked" },
        { variable: "default_tab", accepts: "Integer", example: "default_tab: 1" },
        { variable: "tab / panel", accepts: "id:, label:, block", example: "tabs.tab(id: \"overview\", label: \"Overview\")" }
      ]
    },
    timeline: {
      label: "Timeline",
      method_call: "render FlatPack::Timeline::Component.new(class: \"max-w-2xl\") do ... end",
      variables: [
        { variable: "content", accepts: "Timeline item components via block", example: "render FlatPack::Timeline::Item.new(title: \"Created\")" },
        { variable: "class", accepts: "String or nil", example: "class: \"max-w-2xl\"" },
        { variable: "**system_arguments", accepts: "Hash", example: "id: \"project-timeline\", data: { testid: \"timeline\" }" }
      ]
    },
    timeline_item: {
      label: "Timeline Item",
      method_call: "render FlatPack::Timeline::Item.new(title: \"Build Started\", timestamp: \"10:00 AM\", variant: :default) { \"Running tests\" }",
      variables: [
        { variable: "title", accepts: "String (required)", example: "title: \"Build Started\"" },
        { variable: "timestamp", accepts: "String or nil", example: "timestamp: \"10:00 AM\"" },
        { variable: "variant", accepts: ":default, :success, :warning, :danger", example: "variant: :success" },
        { variable: "status", accepts: ":default, :success, :warning, :danger or nil", example: "status: :warning" },
        { variable: "description", accepts: "String or nil", example: "description: \"Deployment finished\"" },
        { variable: "icon", accepts: "SVG string or nil", example: "icon: '<svg ...></svg>'" },
        { variable: "last", accepts: "true, false", example: "last: true" },
        { variable: "**system_arguments", accepts: "Hash", example: "class: \"mb-2\", data: { testid: \"timeline-item\" }" }
      ]
    },
    toast: {
      label: "Toast",
      method_call: "render FlatPack::Toast::Component.new(message: \"Saved\", type: :success, timeout: 5000)",
      variables: [
        { variable: "message", accepts: "String (required)", example: "message: \"Changes saved\"" },
        { variable: "type", accepts: ":info, :success, :warning, :error", example: "type: :error" },
        { variable: "timeout", accepts: "Integer (ms)", example: "timeout: 3000" }
      ]
    },
    tooltip: {
      label: "Tooltip",
      method_call: "render FlatPack::Tooltip::Component.new(text: \"More info\", placement: :top) do ... end",
      variables: [
        { variable: "text", accepts: "String", example: "text: \"Copy to clipboard\"" },
        { variable: "placement", accepts: ":top, :right, :bottom, :left", example: "placement: :left" },
        { variable: "content", accepts: "slot block", example: "tooltip.content { \"Custom tooltip body\" }" }
      ]
    }
  }

  component_docs = component_keys.filter_map do |component_key|
    doc = docs_by_key[component_key]
    next unless doc

    doc.merge(key: component_key)
  end
%>

<section id="<%= table_anchor %>" class="mb-12 scroll-mt-24">
  <%= render FlatPack::Tabs::Component.new(variant: :pills, default_tab: 0) do |tabs| %>
    <% component_docs.each_with_index do |component_doc, index| %>
      <% tab_id = "#{table_anchor}-#{component_doc[:key]}-#{index}" %>
      <% tabs.tab(id: tab_id, label: component_doc[:label]) %>

      <% tabs.panel(id: tab_id) do %>
        <div class="pt-2">
          <%= render FlatPack::CodeBlock::Component.new(
            title: "Method Call",
            language: "erb",
            code: component_doc[:method_call],
            class: "mb-4"
          ) %>

          <%= render FlatPack::Table::Component.new(data: component_doc[:variables]) do |table| %>
            <% table.column(title: "Variable", html: ->(row) { row[:variable] }) %>
            <% table.column(title: "Accepts", html: ->(row) { row[:accepts] }) %>
            <% table.column(title: "Example", html: ->(row) { row[:example] }) %>
          <% end %>

          <% if component_doc[:slides_hash_options].present? %>
            <div class="mt-6">
              <h4 class="mb-2 text-sm font-semibold text-(--surface-content-color)">Slides Hash Options</h4>
              <%= render FlatPack::Table::Component.new(data: component_doc[:slides_hash_options]) do |table| %>
                <% table.column(title: "Key", html: ->(row) { row[:key] }) %>
                <% table.column(title: "Applies To", html: ->(row) { row[:applies_to] }) %>
                <% table.column(title: "Accepts", html: ->(row) { row[:accepts] }) %>
                <% table.column(title: "Default", html: ->(row) { row[:default] }) %>
                <% table.column(title: "Example", html: ->(row) { row[:example] }) %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <% if component_docs.empty? %>
    <p class="rounded-md border border-(--surface-border-color) bg-(--surface-muted-background-color) p-4 text-sm text-(--surface-muted-content-color)">
      No component metadata is defined for this demo yet.
    </p>
  <% end %>
</section>
