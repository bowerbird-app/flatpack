<%
  table_title = local_assigns[:title] || "Component Method & Variables"
  table_anchor = local_assigns[:anchor] || table_title.to_s.parameterize
  component_keys = Array(local_assigns[:components] || local_assigns[:component]).compact.map(&:to_sym)

  docs_by_key = {
    alert: {
      label: "Alert",
      method_call: "render FlatPack::Alert::Component.new(title: \"Success\", description: \"Saved\", style: :success)",
      variables: [
        { variable: "style", accepts: ":info, :success, :warning, :danger", example: "style: :success" },
        { variable: "dismissible", accepts: "true, false", example: "dismissible: true" },
        { variable: "icon", accepts: "true, false", example: "icon: true" }
      ]
    },
    avatar: {
      label: "Avatar",
      method_call: "render FlatPack::Avatar::Component.new(name: \"Jane Doe\", src: \"https://...\", size: :md)",
      variables: [
        { variable: "name", accepts: "String or nil", example: "name: \"Jane Doe\"" },
        { variable: "size", accepts: ":xs, :sm, :md, :lg, :xl", example: "size: :lg" },
        { variable: "shape", accepts: ":circle, :rounded, :square", example: "shape: :rounded" }
      ]
    },
    badge: {
      label: "Badge",
      method_call: "render FlatPack::Badge::Component.new(text: \"New\", style: :primary)",
      variables: [
        { variable: "text", accepts: "String (required)", example: "text: \"New\"" },
        { variable: "style", accepts: ":default, :primary, :success, :warning, :info", example: "style: :warning" },
        { variable: "size", accepts: ":sm, :md, :lg", example: "size: :sm" }
      ]
    },
    breadcrumb: {
      label: "Breadcrumb",
      method_call: "render FlatPack::Breadcrumb::Component.new(items: [{ label: \"Home\", href: \"/\" }, { label: \"Settings\" }])",
      variables: [
        { variable: "items", accepts: "Array of item hashes", example: "items: [{ label: \"Home\", href: \"/\" }, { label: \"Billing\" }]" },
        { variable: "separator", accepts: ":chevron, :slash, :arrow, :dot, :custom", example: "separator: :slash" },
        { variable: "show_home", accepts: "true, false", example: "show_home: true" }
      ]
    },
    button: {
      label: "Button",
      method_call: "render FlatPack::Button::Component.new(text: \"Save\", style: :primary, size: :md)",
      variables: [
        { variable: "text", accepts: "String", example: "text: \"Save\"" },
        { variable: "style", accepts: ":primary, :secondary, :ghost, :success, :warning, :error", example: "style: :secondary" },
        { variable: "loading", accepts: "true, false", example: "loading: true" }
      ]
    },
    card: {
      label: "Card",
      method_call: "render FlatPack::Card::Component.new(style: :default, padding: :md) do |card| ... end",
      variables: [
        { variable: "style", accepts: ":default, :elevated, :outlined, :flat, :interactive, :list", example: "style: :outlined" },
        { variable: "hover", accepts: "nil, :none, :subtle, :strong", example: "hover: :subtle" },
        { variable: "padding", accepts: ":none, :sm, :md, :lg", example: "padding: :lg" }
      ]
    },
    chart: {
      label: "Chart",
      method_call: "render FlatPack::Chart::Component.new(type: :line, series: [{ name: \"Sales\", data: [10, 20] }])",
      variables: [
        { variable: "series", accepts: "Array (required)", example: "series: [{ name: \"Revenue\", data: [12, 19, 24] }]" },
        { variable: "type", accepts: ":line, :bar, :area, :donut, :pie, :radar", example: "type: :bar" },
        { variable: "height", accepts: "Integer", example: "height: 320" }
      ]
    },
    chat_panel: {
      label: "Chat Panel",
      method_call: "render FlatPack::Chat::Panel::Component.new do |panel| ... end",
      variables: [
        { variable: "with_header", accepts: "slot block", example: "panel.with_header { ... }" },
        { variable: "with_messages", accepts: "slot block", example: "panel.with_messages { ... }" },
        { variable: "with_composer", accepts: "slot block", example: "panel.with_composer { ... }" }
      ]
    },
    chat_sent_message: {
      label: "Chat Sent Message",
      method_call: "render FlatPack::Chat::SentMessage::Component.new(state: :read, reveal_actions: true, timestamp: Time.current) { \"Message body\" }",
      variables: [
        { variable: "state", accepts: ":sent, :sending, :failed, :read", example: "state: :sending" },
        { variable: "reveal_actions", accepts: "true, false", example: "reveal_actions: true" },
        { variable: "timestamp", accepts: "Time/String/nil", example: "timestamp: Time.current" }
      ]
    },
    chat_received_message: {
      label: "Chat Received Message",
      method_call: "render FlatPack::Chat::ReceivedMessage::Component.new(state: :sent) { \"Incoming message\" }",
      variables: [
        { variable: "state", accepts: ":sent, :sending, :failed, :read", example: "state: :sent" },
        { variable: "with_attachment", accepts: "slot (many)", example: "message.with_attachment { render FlatPack::Chat::Attachment::Component.new(...) }" },
        { variable: "with_meta", accepts: "slot", example: "message.with_meta { render FlatPack::Chat::MessageMeta::Component.new(...) }" }
      ]
    },
    chat_file_message: {
      label: "Chat File Message",
      method_call: "render FlatPack::Chat::FileMessage::Component.new(direction: :outgoing, file_name: \"brief.pdf\", file_meta: \"420 KB\")",
      variables: [
        { variable: "direction", accepts: ":incoming, :outgoing", example: "direction: :incoming" },
        { variable: "file_name", accepts: "String (required)", example: "file_name: \"launch-plan.pdf\"" },
        { variable: "file_meta", accepts: "String or nil", example: "file_meta: \"840 KB\"" }
      ]
    },
    chat_image_message: {
      label: "Chat Image Message",
      method_call: "render FlatPack::Chat::ImageMessage::Component.new(direction: :incoming, image_name: \"mockup.png\", thumbnail_url: \"https://...\")",
      variables: [
        { variable: "direction", accepts: ":incoming, :outgoing", example: "direction: :outgoing" },
        { variable: "image_name", accepts: "String (required)", example: "image_name: \"hero-v2.png\"" },
        { variable: "thumbnail_url", accepts: "String (required)", example: "thumbnail_url: \"https://images...\"" }
      ]
    },
    chat_system_message: {
      label: "Chat System Message",
      method_call: "render FlatPack::Chat::SystemMessage::Component.new { \"Alex renamed the chat group\" }",
      variables: [
        { variable: "content", accepts: "block content", example: "{ \"Mina joined the chat group\" }" },
        { variable: "class", accepts: "String or nil", example: "class: \"my-2\"" },
        { variable: "id", accepts: "String or nil", example: "id: \"chat-system-event\"" }
      ]
    },
    chat_message_record: {
      label: "Chat Message Record",
      method_call: "render FlatPack::Chat::MessageRecord::Component.new(record: message)",
      variables: [
        { variable: "record", accepts: "message-like object", example: "record: message" },
        { variable: "direction", accepts: ":incoming, :outgoing, nil", example: "direction: :outgoing" },
        { variable: "show_avatar", accepts: "true, false, nil", example: "show_avatar: false" }
      ]
    },
    chat_attachment: {
      label: "Chat Attachment",
      method_call: "render FlatPack::Chat::Attachment::Component.new(type: :file, name: \"spec.pdf\", meta: \"840 KB\")",
      variables: [
        { variable: "type", accepts: ":file, :image", example: "type: :image" },
        { variable: "name", accepts: "String", example: "name: \"homepage-wireframe.png\"" },
        { variable: "meta", accepts: "String or nil", example: "meta: \"840 KB\"" }
      ]
    },
    chat_textarea: {
      label: "Chat Textarea",
      method_call: "render FlatPack::Chat::Textarea::Component.new(name: \"chat[message]\", autogrow: true)",
      variables: [
        { variable: "name", accepts: "String", example: "name: \"chat[message]\"" },
        { variable: "autogrow", accepts: "true, false", example: "autogrow: true" },
        { variable: "submit_on_enter", accepts: "true, false", example: "submit_on_enter: false" }
      ]
    },
    chat_typing_indicator: {
      label: "Chat Typing Indicator",
      method_call: "render FlatPack::Chat::TypingIndicator::Component.new(label: \"Teammate is typing\")",
      variables: [
        { variable: "label", accepts: "String", example: "label: \"Sam is typing\"" },
        { variable: "with_avatar", accepts: "slot block", example: "indicator.with_avatar { render FlatPack::Avatar::Component.new(...) }" },
        { variable: "class", accepts: "String or nil", example: "class: \"mt-2\"" }
      ]
    },
    chat_layout: {
      label: "Chat Layout",
      method_call: "render FlatPack::Chat::Layout::Component.new(variant: :split) do |layout| ... end",
      variables: [
        { variable: "variant", accepts: ":single, :split", example: "variant: :split" },
        { variable: "with_sidebar", accepts: "slot block", example: "layout.with_sidebar { ... }" },
        { variable: "with_panel", accepts: "slot block", example: "layout.with_panel { ... }" }
      ]
    },
    chat_message_list: {
      label: "Chat Message List",
      method_call: "render FlatPack::Chat::MessageList::Component.new(stick_to_bottom: true) do ... end",
      variables: [
        { variable: "stick_to_bottom", accepts: "true, false", example: "stick_to_bottom: true" },
        { variable: "jump_threshold", accepts: "Integer or nil", example: "jump_threshold: 160" },
        { variable: "class", accepts: "String or nil", example: "class: \"max-h-[420px]\"" }
      ]
    },
    chat_message_meta: {
      label: "Chat Message Meta",
      method_call: "render FlatPack::Chat::MessageMeta::Component.new(timestamp: \"11:02 AM\", state: :sent)",
      variables: [
        { variable: "timestamp", accepts: "String or nil", example: "timestamp: \"11:05 AM\"" },
        { variable: "state", accepts: ":sent, :sending, :failed, :read", example: "state: :failed" },
        { variable: "edited", accepts: "true, false", example: "edited: true" }
      ]
    },
    chip: {
      label: "Chip",
      method_call: "render FlatPack::Chip::Component.new(text: \"Backend\", style: :primary)",
      variables: [
        { variable: "text", accepts: "String", example: "text: \"Backend\"" },
        { variable: "style", accepts: ":default, :primary, :success, :warning, :danger, :info", example: "style: :info" },
        { variable: "removable", accepts: "true, false", example: "removable: true" }
      ]
    },
    code_block: {
      label: "Code Block",
      method_call: "render FlatPack::CodeBlock::Component.new(title: \"ERB\", language: \"erb\", code: \"...\")",
      variables: [
        { variable: "code", accepts: "String (required unless snippets are provided)", example: "code: \"render FlatPack::Button::Component.new(...)\"" },
        { variable: "snippets", accepts: "Array of hashes: [{ label:, code:, language: }]", example: "snippets: [{ label: \"Primary\", code: \"...\", language: \"erb\" }]" },
        { variable: "language", accepts: "String or nil", example: "language: \"ruby\"" }
      ]
    },
    comments_thread: {
      label: "Comments Thread",
      method_call: "render FlatPack::Comments::Thread::Component.new(count: 3, title: \"Discussion\") do |thread| ... end",
      variables: [
        { variable: "count", accepts: "Integer", example: "count: 4" },
        { variable: "title", accepts: "String", example: "title: \"Discussion\"" },
        { variable: "variant", accepts: ":default, :compact", example: "variant: :compact" }
      ]
    },
    comments_item: {
      label: "Comments Item",
      method_call: "render FlatPack::Comments::Item::Component.new(author_name: \"Alice\", body: \"Looks good\")",
      variables: [
        { variable: "author_name", accepts: "String", example: "author_name: \"Alice Johnson\"" },
        { variable: "body", accepts: "String or nil", example: "body: \"This is great work.\"" },
        { variable: "timestamp", accepts: "String, Time, or nil", example: "timestamp: \"2 hours ago\"" }
      ]
    },
    comments_composer: {
      label: "Comments Composer",
      method_call: "render FlatPack::Comments::Composer::Component.new(placeholder: \"Write a comment...\")",
      variables: [
        { variable: "placeholder", accepts: "String", example: "placeholder: \"Share feedback...\"" },
        { variable: "submit_label", accepts: "String", example: "submit_label: \"Post\"" },
        { variable: "disabled", accepts: "true, false", example: "disabled: false" }
      ]
    },
    chat_message_group: {
      label: "Chat Message Group",
      method_call: "render FlatPack::Chat::MessageGroup::Component.new(direction: :incoming, show_avatar: true) do |group| ... end",
      variables: [
        { variable: "direction", accepts: ":incoming, :outgoing", example: "direction: :outgoing" },
        { variable: "show_avatar", accepts: "true, false", example: "show_avatar: true" },
        { variable: "sender_name", accepts: "String or nil", example: "sender_name: \"Mina\"" }
      ]
    },
    chat_composer: {
      label: "Chat Composer",
      method_call: "render FlatPack::Chat::Composer::Component.new do |composer| ... end",
      variables: [
        { variable: "with_attachments", accepts: "slot block", example: "composer.with_attachments { ... }" },
        { variable: "left", accepts: "slot block", example: "composer.left { ... }" },
        { variable: "center", accepts: "slot block", example: "composer.center { ... }" },
        { variable: "right", accepts: "slot block", example: "composer.right { ... }" }
      ]
    },
    chat_send_button: {
      label: "Chat Send Button",
      method_call: "render FlatPack::Chat::SendButton::Component.new(loading: false, disabled: false)",
      variables: [
        { variable: "loading", accepts: "true, false", example: "loading: true" },
        { variable: "disabled", accepts: "true, false", example: "disabled: true" },
        { variable: "class", accepts: "String or nil", example: "class: \"ml-auto\"" }
      ]
    },
    chat_date_divider: {
      label: "Chat Date Divider",
      method_call: "render FlatPack::Chat::DateDivider::Component.new(label: \"Today\")",
      variables: [
        { variable: "label", accepts: "String", example: "label: \"Yesterday\"" },
        { variable: "class", accepts: "String or nil", example: "class: \"my-4\"" },
        { variable: "id", accepts: "String or nil", example: "id: \"chat-day-today\"" }
      ]
    },
    empty_state: {
      label: "Empty State",
      method_call: "render FlatPack::EmptyState::Component.new(title: \"No results\", description: \"Try another filter\")",
      variables: [
        { variable: "title", accepts: "String (required)", example: "title: \"No projects yet\"" },
        { variable: "description", accepts: "String or nil", example: "description: \"Create your first project to get started.\"" },
        { variable: "icon", accepts: "Symbol/String or nil", example: "icon: :inbox" }
      ]
    },
    form_input: {
      label: "Form Inputs",
      method_call: "form_with(...) { render FlatPack::TextInput::Component.new(...); render FlatPack::Button::Component.new(...) }",
      variables: [
        { variable: "name", accepts: "String", example: "name: \"user[email]\"" },
        { variable: "label", accepts: "String or nil", example: "label: \"Email\"" },
        { variable: "required", accepts: "true, false", example: "required: true" }
      ]
    },
    grid: {
      label: "Grid",
      method_call: "render FlatPack::Grid::Component.new(cols: :auto, gap: :md) do ... end",
      variables: [
        { variable: "cols", accepts: ":auto, Integer", example: "cols: 3" },
        { variable: "gap", accepts: ":none, :xs, :sm, :md, :lg, :xl", example: "gap: :lg" },
        { variable: "align", accepts: ":start, :center, :end, :stretch", example: "align: :stretch" }
      ]
    },
    text_input: {
      label: "Input",
      method_call: "render FlatPack::TextInput::Component.new(name: \"username\", label: \"Username\")",
      variables: [
        { variable: "name", accepts: "String", example: "name: \"user[email]\"" },
        { variable: "label", accepts: "String or nil", example: "label: \"Email\"" },
        { variable: "error", accepts: "String or nil", example: "error: \"Email is invalid\"" }
      ]
    },
    modal: {
      label: "Modal",
      method_call: "render FlatPack::Modal::Component.new(id: \"confirm-delete\", size: :md) do |modal| ... end",
      variables: [
        { variable: "id", accepts: "String (required)", example: "id: \"edit-profile-modal\"" },
        { variable: "size", accepts: ":sm, :md, :lg, :xl, :\"2xl\"", example: "size: :lg" },
        { variable: "close_on_escape", accepts: "true, false", example: "close_on_escape: true" }
      ]
    },
    top_nav: {
      label: "Top Nav",
      method_call: "render FlatPack::TopNav::Component.new do |nav| ... end",
      variables: [
        { variable: "left", accepts: "slot block", example: "nav.left { \"Brand\" }" },
        { variable: "center", accepts: "slot block", example: "nav.center { render FlatPack::Search::Component.new }" },
        { variable: "right", accepts: "slot block", example: "nav.right { render FlatPack::Avatar::Component.new(...) }" }
      ]
    },
    page_title: {
      label: "Page Title",
      method_call: "render FlatPack::PageTitle::Component.new(title: \"Dashboard\", subtitle: \"Overview\")",
      variables: [
        { variable: "title", accepts: "String (required)", example: "title: \"Account Settings\"" },
        { variable: "subtitle", accepts: "String or nil", example: "subtitle: \"Manage your profile and preferences.\"" },
        { variable: "class", accepts: "String or nil", example: "class: \"mb-8\"" }
      ]
    },
    quote: {
      label: "Quote",
      method_call: "render FlatPack::Quote::Component.new(text: \"Good design is as little design as possible.\", cite: \"Dieter Rams\")",
      variables: [
        { variable: "text", accepts: "String or block content", example: "text: \"Good design is as little design as possible.\"" },
        { variable: "cite", accepts: "String or nil", example: "cite: \"Dieter Rams\"" },
        { variable: "size", accepts: ":sm, :md, :lg", example: "size: :lg" }
      ]
    },
    pagination: {
      label: "Pagination",
      method_call: "render FlatPack::Pagination::Component.new(pagy: @pagy)",
      variables: [
        { variable: "pagy", accepts: "Pagy instance (required)", example: "pagy: @pagy" },
        { variable: "size", accepts: ":compact, :normal", example: "size: :compact" },
        { variable: "class", accepts: "String or nil", example: "class: \"mt-6\"" }
      ]
    },
    popover: {
      label: "Popover",
      method_call: "render FlatPack::Popover::Component.new(trigger_id: \"help-btn\", placement: :right) do |popover| popover.content { \"Help text\" } end",
      variables: [
        { variable: "trigger_id", accepts: "String (required)", example: "trigger_id: \"profile-help\"" },
        { variable: "placement", accepts: ":top, :right, :bottom, :left", example: "placement: :bottom" },
        { variable: "content", accepts: "slot block", example: "popover.content { \"Help text\" }" }
      ]
    },
    search: {
      label: "Search",
      method_call: "render FlatPack::Search::Component.new(name: \"query\", placeholder: \"Search...\")",
      variables: [
        { variable: "search_url", accepts: "Relative/allowed URL or nil", example: "search_url: demo_search_path" },
        { variable: "min_characters", accepts: "Integer", example: "min_characters: 2" },
        { variable: "debounce", accepts: "Integer (ms)", example: "debounce: 250" }
      ]
    },
    sidebar_layout: {
      label: "Sidebar Layout",
      method_call: "render FlatPack::SidebarLayout::Component.new(side: :left, default_open: true) do |layout| ... end",
      variables: [
        { variable: "side", accepts: ":left, :right", example: "side: :right" },
        { variable: "default_open", accepts: "true, false", example: "default_open: false" },
        { variable: "storage_key", accepts: "String or nil", example: "storage_key: \"demo-sidebar-state\"" }
      ]
    },
    table: {
      label: "Table",
      method_call: "render FlatPack::Table::Component.new(data: @users) do |table| ... end",
      variables: [
        { variable: "data", accepts: "Array/Enumerable", example: "data: @users" },
        { variable: "column", accepts: "title:, html:, sortable:, sort_key:", example: "table.column(title: \"Email\", sortable: true, sort_key: :email)" },
        { variable: "direction", accepts: ":asc, :desc", example: "direction: :desc" }
      ]
    },
    tabs: {
      label: "Tabs",
      method_call: "render FlatPack::Tabs::Component.new(variant: :pills) do |tabs| ... end",
      variables: [
        { variable: "variant", accepts: ":underline, :pills, :stacked", example: "variant: :stacked" },
        { variable: "default_tab", accepts: "Integer", example: "default_tab: 1" },
        { variable: "tab / panel", accepts: "id:, label:, block", example: "tabs.tab(id: \"overview\", label: \"Overview\")" }
      ]
    },
    toast: {
      label: "Toast",
      method_call: "render FlatPack::Toast::Component.new(message: \"Saved\", type: :success, timeout: 5000)",
      variables: [
        { variable: "message", accepts: "String (required)", example: "message: \"Changes saved\"" },
        { variable: "type", accepts: ":info, :success, :warning, :error", example: "type: :error" },
        { variable: "timeout", accepts: "Integer (ms)", example: "timeout: 3000" }
      ]
    },
    tooltip: {
      label: "Tooltip",
      method_call: "render FlatPack::Tooltip::Component.new(text: \"More info\", placement: :top) do ... end",
      variables: [
        { variable: "text", accepts: "String", example: "text: \"Copy to clipboard\"" },
        { variable: "placement", accepts: ":top, :right, :bottom, :left", example: "placement: :left" },
        { variable: "with_tooltip_content", accepts: "slot block", example: "tooltip.with_tooltip_content { \"Custom tooltip body\" }" }
      ]
    }
  }

  component_docs = component_keys.filter_map do |component_key|
    doc = docs_by_key[component_key]
    next unless doc

    doc.merge(key: component_key)
  end
%>

<section id="<%= table_anchor %>" class="mb-12 scroll-mt-24">
  <%= render FlatPack::Tabs::Component.new(variant: :pills, default_tab: 0) do |tabs| %>
    <% component_docs.each_with_index do |component_doc, index| %>
      <% tab_id = "#{table_anchor}-#{component_doc[:key]}-#{index}" %>
      <% tabs.tab(id: tab_id, label: component_doc[:label]) %>

      <% tabs.panel(id: tab_id) do %>
        <div class="pt-2">
          <%= render FlatPack::CodeBlock::Component.new(
            title: "Method Call",
            language: "erb",
            code: component_doc[:method_call],
            class: "mb-4"
          ) %>

          <%= render FlatPack::Table::Component.new(data: component_doc[:variables]) do |table| %>
            <% table.column(title: "Variable", html: ->(row) { row[:variable] }) %>
            <% table.column(title: "Accepts", html: ->(row) { row[:accepts] }) %>
            <% table.column(title: "Example", html: ->(row) { row[:example] }) %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <% if component_docs.empty? %>
    <p class="rounded-md border border-(--surface-border-color) bg-(--surface-muted-background-color) p-4 text-sm text-(--surface-muted-content-color)">
      No component metadata is defined for this demo yet.
    </p>
  <% end %>
</section>
