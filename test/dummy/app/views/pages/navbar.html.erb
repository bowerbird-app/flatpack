<%= render FlatPack::PageTitle::Component.new(
  title: "Top Nav Components",
  subtitle: "Top nav slot behavior with live examples and copyable code snippets."
) %>
<%= render "pages/component_method_variables_table", component: :top_nav %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Left Slot", anchor_link: true, subtitle: "Examples for Left Slot.") %>
  <p class="text-sm text-[var(--surface-muted-content-color)] mb-4">
    Use the left slot for navigation controls like a mobile menu toggle, back button, and page title.
  </p>
  <div class="rounded-lg overflow-hidden mb-4">
    <%= render FlatPack::TopNav::Component.new(class: "relative rounded-lg border border-[var(--surface-border-color)]") do |nav| %>
      <% nav.left do %>
        <%= render FlatPack::Button::Component.new(
          icon: "menu",
          icon_only: true,
          style: :ghost,
          size: :md,
          aria: { label: "Toggle sidebar" },
          class: "border-0 shadow-none hover:bg-[var(--surface-muted-background-color)] transition-colors"
        ) %>
        <h3 class="text-base font-semibold">Dashboard</h3>
      <% end %>

      <% nav.center do %>
        <div class="text-sm text-[var(--surface-muted-content-color)]">Page context</div>
      <% end %>

      <% nav.right do %>
        <%= render FlatPack::Button::Component.new(
          icon: "bell",
          icon_only: true,
          style: :ghost,
          size: :md,
          aria: { label: "Notifications" },
          class: "border-0 shadow-none hover:bg-[var(--surface-muted-background-color)] transition-colors"
        ) %>
      <% end %>
    <% end %>
  </div>
  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE')
      &lt;%= render FlatPack::TopNav::Component.new do |nav| %&gt;
        &lt;% nav.left do %&gt;
          &lt;%= render FlatPack::Button::Component.new(
            icon: &quot;menu&quot;,
            icon_only: true,
            style: :ghost,
            size: :md,
            aria: { label: &quot;Toggle sidebar&quot; },
            class: &quot;border-0 shadow-none hover:bg-[var(--surface-muted-background-color)]&quot;
          ) %&gt;
          <h3 class="text-base font-semibold">Dashboard</h3>
        &lt;% end %&gt;
      
        &lt;% nav.center do %&gt;
          <div class="text-sm text-[var(--surface-muted-content-color)]">Page context</div>
        &lt;% end %&gt;
      
        &lt;% nav.right do %&gt;
          &lt;%= render FlatPack::Button::Component.new(
            icon: &quot;bell&quot;,
            icon_only: true,
            style: :ghost,
            size: :md,
            aria: { label: &quot;Notifications&quot; },
            class: &quot;border-0 shadow-none hover:bg-[var(--surface-muted-background-color)]&quot;
          ) %&gt;
        &lt;% end %&gt;
      &lt;% end %&gt;
    CODE
  ) %>
</section>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Center Slot", anchor_link: true, subtitle: "Examples for Center Slot.") %>
  <p class="text-sm text-[var(--surface-muted-content-color)] mb-4">
    Use the center slot for search, tabs, or any content that should stay visually centered.
  </p>
  <div class="rounded-lg overflow-hidden mb-4">
    <%= render FlatPack::TopNav::Component.new(class: "relative rounded-lg border border-[var(--surface-border-color)]") do |nav| %>
      <% nav.left do %>
        <h3 class="text-base font-semibold">Projects</h3>
      <% end %>

      <% nav.center do %>
        <%= render FlatPack::Search::Component.new(
          placeholder: "Search projects, files, or people..."
        ) %>
      <% end %>

      <% nav.right do %>
        <%= render FlatPack::Button::Component.new(text: "New", size: :sm, style: :primary) %>
      <% end %>
    <% end %>
  </div>
  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE')
      &lt;%= render FlatPack::TopNav::Component.new do |nav| %&gt;
        &lt;% nav.left do %&gt;
          <h3 class="text-base font-semibold">Projects</h3>
        &lt;% end %&gt;
      
        &lt;% nav.center do %&gt;
          &lt;%= render FlatPack::Search::Component.new(
            placeholder: "Search projects, files, or people..."
          ) %&gt;
        &lt;% end %&gt;
      
        &lt;% nav.right do %&gt;
          &lt;%= render FlatPack::Button::Component.new(text: "New", size: :sm, style: :primary) %&gt;
        &lt;% end %&gt;
      &lt;% end %&gt;
    CODE
  ) %>
</section>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Right Slot", anchor_link: true, subtitle: "Examples for Right Slot.") %>
  <p class="text-sm text-[var(--surface-muted-content-color)] mb-4">
    Use the right slot for user actions like notifications, settings, profile, and quick-create actions.
  </p>
  <div class="rounded-lg overflow-hidden mb-4">
    <%= render FlatPack::TopNav::Component.new(class: "relative rounded-lg border border-[var(--surface-border-color)]") do |nav| %>
      <% nav.left do %>
        <h3 class="text-base font-semibold">Workspace</h3>
      <% end %>

      <% nav.center do %>
        <div class="text-sm text-[var(--surface-muted-content-color)]">Overview</div>
      <% end %>

      <% nav.right do %>
        <div class="flex items-center gap-2">
          <%= render FlatPack::Button::Component.new(
            icon: "question",
            icon_only: true,
            style: :ghost,
            size: :md,
            aria: { label: "Help" },
            class: "border-0 shadow-none hover:bg-[var(--surface-muted-background-color)] transition-colors"
          ) %>
          <%= render FlatPack::Button::Component.new(
            icon: "cog",
            icon_only: true,
            style: :ghost,
            size: :md,
            aria: { label: "Settings" },
            class: "border-0 shadow-none hover:bg-[var(--surface-muted-background-color)] transition-colors"
          ) %>
          <%= render FlatPack::Avatar::Component.new(name: "Alex Brown", initials: "AB", size: :sm) %>
        </div>
      <% end %>
    <% end %>
  </div>
  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE')
      &lt;%= render FlatPack::TopNav::Component.new do |nav| %&gt;
        &lt;% nav.left do %&gt;
          <h3 class="text-base font-semibold">Workspace</h3>
        &lt;% end %&gt;
      
        &lt;% nav.center do %&gt;
          <div class="text-sm text-[var(--surface-muted-content-color)]">Overview</div>
        &lt;% end %&gt;
      
        &lt;% nav.right do %&gt;
          <div class="flex items-center gap-2">
            &lt;%= render FlatPack::Button::Component.new(
              icon: &quot;question&quot;,
              icon_only: true,
              style: :ghost,
              size: :md,
              aria: { label: &quot;Help&quot; },
              class: &quot;border-0 shadow-none hover:bg-[var(--surface-muted-background-color)]&quot;
            ) %&gt;
            &lt;%= render FlatPack::Button::Component.new(
              icon: &quot;cog&quot;,
              icon_only: true,
              style: :ghost,
              size: :md,
              aria: { label: &quot;Settings&quot; },
              class: &quot;border-0 shadow-none hover:bg-[var(--surface-muted-background-color)]&quot;
            ) %&gt;
            &lt;%= render FlatPack::Avatar::Component.new(name: &quot;Alex Brown&quot;, initials: &quot;AB&quot;, size: :sm) %&gt;
          </div>
        &lt;% end %&gt;
      &lt;% end %&gt;
    CODE
  ) %>
</section>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Alignment Rules", anchor_link: true, subtitle: "Examples for Alignment Rules.") %>
  <p class="text-sm text-[var(--surface-muted-content-color)] mb-4">
    <code>left</code> is start-aligned, <code>center</code> is flexed and centered, and <code>right</code> sits at the far edge when center is present.
  </p>
  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE')
      &lt;%= render FlatPack::TopNav::Component.new do |nav| %&gt;
        &lt;% nav.left do %&gt;Left&lt;% end %&gt;
        &lt;% nav.center do %&gt;Centered&lt;% end %&gt;
        &lt;% nav.right do %&gt;Right&lt;% end %&gt;
      &lt;% end %&gt;
    CODE
  ) %>
</section>
