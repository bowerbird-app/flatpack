<%= render FlatPack::PageTitle::Component.new(
  title: "Sidebar Collapsed",
  subtitle: "Icon-only sidebar state for compact layouts."
) %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Icon-Only Sidebar", anchor_link: true) %>
  <div class="rounded-lg overflow-hidden h-[360px] w-16 mb-4">
    <%= render FlatPack::Sidebar::Component.new(style: "width: 4rem", class: "border border-[var(--surface-border-color)] rounded-lg") do |sidebar| %>
      <% sidebar.header do %>
        <div class="p-4 flex justify-center">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white font-bold">FP</div>
        </div>
      <% end %>

      <% sidebar.items do %>
        <nav class="py-2 space-y-1">
          <%= render FlatPack::Sidebar::Item::Component.new(label: "Overview", href: "#", icon: :home, collapsed: true, active: true) %>
          <%= render FlatPack::Sidebar::Item::Component.new(label: "Tables", href: "#", icon: :table, collapsed: true) %>
          <%= render FlatPack::Sidebar::Item::Component.new(label: "Alerts", href: "#", icon: :alert, collapsed: true) %>
          <%= render FlatPack::Sidebar::Item::Component.new(label: "Settings", href: "#", icon: :dashboard, collapsed: true) %>
        </nav>
      <% end %>
    <% end %>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;rounded-lg overflow-hidden h-[360px] w-16 mb-4&quot;&gt;
        &lt;%= render FlatPack::Sidebar::Component.new(style: &quot;width: 4rem&quot;, class: &quot;border border-[var(--surface-border-color)] rounded-lg&quot;) do |sidebar| %&gt;
          &lt;% sidebar.header do %&gt;
            &lt;div class=&quot;p-4 flex justify-center&quot;&gt;
              &lt;div class=&quot;w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white font-bold&quot;&gt;FP&lt;/div&gt;
            &lt;/div&gt;
          &lt;% end %&gt;
    
          &lt;% sidebar.items do %&gt;
            &lt;nav class=&quot;py-2 space-y-1&quot;&gt;
              &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Overview&quot;, href: &quot;#&quot;, icon: :home, collapsed: true, active: true) %&gt;
              &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Tables&quot;, href: &quot;#&quot;, icon: :table, collapsed: true) %&gt;
              &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Alerts&quot;, href: &quot;#&quot;, icon: :alert, collapsed: true) %&gt;
              &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Settings&quot;, href: &quot;#&quot;, icon: :dashboard, collapsed: true) %&gt;
            &lt;/nav&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Icon-Only Sidebar"
  ) %>
</section>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Collapsible with Groups", anchor_link: true) %>
  <p class="text-sm text-(--surface-muted-content-color) mb-4">
    Group header buttons collapse to icon-only alongside items. Click the hamburger toggle to expand and collapse.
  </p>
  <div
    data-controller="flat-pack--sidebar-layout"
    data-flat-pack--sidebar-layout-side-value="left"
    data-flat-pack--sidebar-layout-default-open-value="false"
    data-flat-pack--sidebar-layout-storage-key-value="demo-sidebar-collapsed-groups"
    class="rounded-lg overflow-hidden h-[360px] border border-[var(--surface-border-color)] grid grid-cols-[auto_1fr] mb-4"
  >
    <div data-flat-pack--sidebar-layout-target="sidebar" data-flat-pack-sidebar-collapsed="true" class="h-full min-h-0">
      <%= render FlatPack::Sidebar::Component.new do |sidebar| %>
        <% sidebar.header do %>
          <%= render FlatPack::Sidebar::Header::Component.new(brand_abbr: "FP", title: "FlatPack", collapsible: true) %>
        <% end %>

        <% sidebar.items do %>
          <nav class="py-2 space-y-1">
            <%= render FlatPack::Sidebar::SectionTitle::Component.new(label: "Main") %>
            <%= render FlatPack::Sidebar::Item::Component.new(label: "Overview", href: "#", icon: :home, active: true) %>
            <%= render FlatPack::Sidebar::Item::Component.new(label: "Alerts", href: "#", icon: :alert) %>
            <%= render FlatPack::Sidebar::Divider::Component.new %>
            <%= render FlatPack::Sidebar::SectionTitle::Component.new(label: "Settings") %>
            <%= render FlatPack::Sidebar::Group::Component.new(label: "Settings", icon: :settings, default_open: false) do |group| %>
              <% group.items do %>
                <%= render FlatPack::Sidebar::Item::Component.new(label: "Team", href: "#", icon: :users) %>
                <%= render FlatPack::Sidebar::Item::Component.new(label: "Permissions", href: "#", icon: :key) %>
              <% end %>
            <% end %>
          </nav>
        <% end %>
      <% end %>
    </div>
    <div class="min-h-0 bg-[var(--surface-background-color)] flex items-center justify-center text-sm text-[var(--surface-muted-content-color)]">
      Main content area
    </div>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div
        data-controller=&quot;flat-pack--sidebar-layout&quot;
        data-flat-pack--sidebar-layout-side-value=&quot;left&quot;
        data-flat-pack--sidebar-layout-default-open-value=&quot;false&quot;
        data-flat-pack--sidebar-layout-storage-key-value=&quot;my-sidebar&quot;
        class=&quot;grid grid-cols-[auto_1fr] h-screen overflow-hidden&quot;
      &gt;
        &lt;div data-flat-pack--sidebar-layout-target=&quot;sidebar&quot; data-flat-pack-sidebar-collapsed=&quot;true&quot;&gt;
          &lt;%= render FlatPack::Sidebar::Component.new do |sidebar| %&gt;
            &lt;% sidebar.header do %&gt;
              &lt;%= render FlatPack::Sidebar::Header::Component.new(brand_abbr: &quot;FP&quot;, title: &quot;FlatPack&quot;, collapsible: true) %&gt;
            &lt;% end %&gt;

            &lt;% sidebar.items do %&gt;
              &lt;nav class=&quot;py-2 space-y-1&quot;&gt;
                &lt;%= render FlatPack::Sidebar::SectionTitle::Component.new(label: &quot;Main&quot;) %&gt;
                &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Overview&quot;, href: &quot;#&quot;, icon: :home) %&gt;
                &lt;%= render FlatPack::Sidebar::Divider::Component.new %&gt;
                &lt;%= render FlatPack::Sidebar::SectionTitle::Component.new(label: &quot;Settings&quot;) %&gt;
                &lt;%= render FlatPack::Sidebar::Group::Component.new(label: &quot;Settings&quot;, icon: :settings) do |group| %&gt;
                  &lt;% group.items do %&gt;
                    &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Team&quot;, href: &quot;#&quot;, icon: :users) %&gt;
                  &lt;% end %&gt;
                &lt;% end %&gt;
              &lt;/nav&gt;
            &lt;% end %&gt;
          &lt;% end %&gt;
        &lt;/div&gt;
        &lt;main&gt;...&lt;/main&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Collapsible Sidebar with Groups"
  ) %>
</section>
