            <div class="w-full h-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center text-white font-bold">
              16:9 Aspect Ratio
            </div>
          &lt;% end %&gt;
          &lt;% card.body do %&gt;
            <p class="text-sm">Wide format, great for videos and banners.</p>
          &lt;% end %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>
