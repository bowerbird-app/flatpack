              <%= render FlatPack::Button::Component.new(icon: "calendar", icon_only: true, style: :ghost, size: :sm, url: "#grid-card-schedule") %>
              <%= render FlatPack::Button::Component.new(icon: "dots", icon_only: true, style: :ghost, size: :sm, url: "#grid-card-menu") %>
            </div>
          </div>
        <% end %>
      <% end %>
