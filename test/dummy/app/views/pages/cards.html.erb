        <% card.footer(divider: false) do %>
          <div class="flex items-center justify-between">
            <div class="text-xs text-[var(--surface-muted-content-color)]">Updated 2h ago</div>
            <div class="flex gap-2">
              <%= render FlatPack::Button::Component.new(icon: "bell", icon_only: true, style: :ghost, size: :sm, url: "#grid-card-notifications") %>
              <%= render FlatPack::Button::Component.new(icon: "calendar", icon_only: true, style: :ghost, size: :sm, url: "#grid-card-schedule") %>
              <%= render FlatPack::Button::Component.new(icon: "dots", icon_only: true, style: :ghost, size: :sm, url: "#grid-card-menu") %>
            </div>
          </div>
        <% end %>
      <% end %>
