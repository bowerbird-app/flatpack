  <!-- Media Slot -->
  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Media Slot", anchor_link: true, subtitle: "Examples for Media Slot.") %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
        <% card.media(aspect_ratio: "16/9") do %>
          <%= image_tag "https://picsum.photos/800/450?random=11", class: "w-full h-full object-cover", alt: "Sample media" %>
        <% end %>
        <% card.body do %>
          <h3 class="text-lg font-semibold mb-2">Standard Media Slot</h3>
          <p class="text-sm text-[var(--surface-muted-content-color)]">Media appears above content with default card body spacing.</p>
        <% end %>
      <% end %>

      <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
        <% card.media(aspect_ratio: "16/9", padding: :none) do %>
          <%= image_tag "https://picsum.photos/800/450?random=12", class: "w-full h-full object-cover", alt: "Edge to edge media" %>
        <% end %>
        <% card.body do %>
          <h3 class="text-lg font-semibold mb-2">Edge-to-Edge Top Media</h3>
          <p class="text-sm text-[var(--surface-muted-content-color)]">Using <code>card.media(..., padding: :none)</code> removes top and side media spacing so the image touches the card edges.</p>
        <% end %>
      <% end %>
    </div>
    <%= render FlatPack::CodeBlock::Component.new(
      code: CGI.unescapeHTML(<<~'CODE')
