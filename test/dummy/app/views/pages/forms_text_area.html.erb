<%= render FlatPack::PageTitle::Component.new(
  title: "Text Area",
  subtitle: "Plain text and TipTap-backed rich text examples using one TextArea API."
) %>

<%= render "pages/component_method_variables_table", component: :text_input %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Text Area Examples", anchor_link: true) %>

  <%= render FlatPack::Card::Component.new do |card| %>
    <% card.body(class: "space-y-[var(--stack-gap-md)]") do %>
      <%= render FlatPack::TextArea::Component.new(
        name: "description",
        label: "Description",
        placeholder: "Enter a detailed description...",
        rows: 3
      ) %>

      <%= render FlatPack::TextArea::Component.new(
        name: "project_summary",
        id: "project_summary",
        label: "Project Summary (with character count)",
        placeholder: "Write a short summary...",
        rows: 3,
        character_count: true,
        min_characters: 30,
        max_characters: 140
      ) %>

      <%= render FlatPack::TextArea::Component.new(
        name: "post_body_minimal",
        label: "Rich Text (minimal preset)",
        rich_text: true,
        rich_text_options: {
          preset: :minimal,
          bubble_menu: true
        }
      ) %>

      <%= render FlatPack::TextArea::Component.new(
        name: "post_body_content",
        label: "Rich Text (content preset)",
        rich_text: true,
        value: {
          type: "doc",
          content: [
            {
              type: "paragraph",
              content: [
                {type: "text", text: "FlatPack themes TipTap UI to match the component system."}
              ]
            }
          ]
        },
        rich_text_options: {
          preset: :content,
          toolbar: :standard,
          character_count: true,
          tables: true
        }
      ) %>

      <%= render FlatPack::TextArea::Component.new(
        name: "post_body_html",
        label: "Rich Text (HTML submit mode, readonly)",
        rich_text: true,
        rich_text_options: {
          preset: :full,
          format: :html,
          floating_menu: true,
          readonly: true
        },
        value: "<p><strong>Readonly</strong> rich text can still render through the shared TextArea API.</p>"
      ) %>
    <% end %>
  <% end %>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;%= render FlatPack::Card::Component.new do |card| %&gt;
        &lt;% card.body do %&gt;
        &lt;%= render FlatPack::TextArea::Component.new(
          name: &quot;description&quot;,
          label: &quot;Description&quot;,
          placeholder: &quot;Enter a detailed description...&quot;,
          rows: 3
        ) %&gt;
    
        &lt;%= render FlatPack::TextArea::Component.new(
          name: &quot;project_summary&quot;,
          id: &quot;project_summary&quot;,
          label: &quot;Project Summary (with character count)&quot;,
          placeholder: &quot;Write a short summary...&quot;,
          rows: 3,
          character_count: true,
          min_characters: 30,
          max_characters: 140
        ) %&gt;

        &lt;%= render FlatPack::TextArea::Component.new(
          name: &quot;post_body_minimal&quot;,
          label: &quot;Rich Text (minimal preset)&quot;,
          rich_text: true,
          rich_text_options: { preset: :minimal, bubble_menu: true }
        ) %&gt;

        &lt;%= render FlatPack::TextArea::Component.new(
          name: &quot;post_body_content&quot;,
          label: &quot;Rich Text (content preset)&quot;,
          rich_text: true,
          rich_text_options: { preset: :content, toolbar: :standard, character_count: true, tables: true }
        ) %&gt;
        &lt;% end %&gt;
      &lt;% end %&gt;
    CODE
    language: "erb",
    title: "Text Area Examples"
  ) %>
</section>
