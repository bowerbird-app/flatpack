<div class="container mx-auto max-w-4xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::MessageRecord",
    subtitle: "Render a full chat row from a message record without custom partials."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_message_record, anchor: "component-method-variables" %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo", anchor_link: true, subtitle: "Incoming/outgoing rows inferred from the message record.") %>

    <% message_struct = Struct.new(:id, :sender_name, :body, :state, :created_at, keyword_init: true) %>

    <% incoming_message = message_struct.new(
      id: 101,
      sender_name: "Mina Cho",
      body: "I finished the updated launch copy and pushed it for review.",
      state: "sent",
      created_at: Time.current.change(hour: 10, min: 12)
    ) %>

    <% outgoing_message = message_struct.new(
      id: 102,
      sender_name: "You",
      body: "Great — I will review now and leave feedback in this chat group.",
      state: "read",
      created_at: Time.current.change(hour: 10, min: 14)
    ) %>

    <div class="mb-4 mt-6 space-y-4 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <%= render FlatPack::Chat::MessageRecord::Component.new(record: incoming_message) %>
      <%= render FlatPack::Chat::MessageRecord::Component.new(record: outgoing_message) %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;% message_struct = Struct.new(:sender_name, :body, :state, :created_at, keyword_init: true) %&gt;

        &lt;% incoming_message = message_struct.new(
          sender_name: "Mina Cho",
          body: "I finished the updated launch copy and pushed it for review.",
          state: "sent",
          created_at: Time.current
        ) %&gt;

        &lt;% outgoing_message = message_struct.new(
          sender_name: "You",
          body: "Great — I will review now and leave feedback in this chat group.",
          state: "read",
          created_at: Time.current
        ) %&gt;

        &lt;%= render FlatPack::Chat::MessageRecord::Component.new(record: incoming_message) %&gt;
        &lt;%= render FlatPack::Chat::MessageRecord::Component.new(record: outgoing_message) %&gt;
      CODE
    ) %>
  </section>
</div>
