<%= render FlatPack::Table::Component.new(
  data: records,
  class: "mb-4",
  tbody_data: {pagination_content: true}
) do |table| %>
  <% table.column(title: "#", html: ->(record) { record.id.to_s }) %>
  <% table.column(title: "Name", html: ->(record) { record.name }) %>
  <% table.column(title: "Email", html: ->(record) { record.email }) %>
  <% table.column(title: "Status", html: ->(record) { record.status.to_s.capitalize }) %>
  <% table.column(title: "Category", html: ->(record) { record.category.to_s.titleize }) %>
  <% table.column(title: "Views", html: ->(record) { number_with_delimiter(record.views_count) }) %>
  <% table.column(title: "Published", html: ->(record) { record.published_at&.strftime("%b %d, %Y") }) %>
<% end %>

<% unless has_more %>
  <div class="py-12 text-center">
    <%= render FlatPack::Badge::Component.new(
      text: "End",
      style: :default,
      size: :lg
    ) %>
  </div>
<% end %>

<%= render FlatPack::Pagination::Component.new(
  mode: :infinite,
  infinite_url: infinite_url,
  has_more: has_more
) %>
