<div class="container mx-auto max-w-4xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::Textarea",
    subtitle: "Single-line starting textarea with optional auto-grow and submit-on-enter."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_textarea, anchor: "component-method-variables" %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo: Auto-grow + Submit on Enter", anchor_link: true, subtitle: "Textarea starts as a single line, auto-grows, and submits on Enter.") %>

    <div class="mb-4 mt-6 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <%= form_with url: demo_chat_textarea_path, method: :get, local: true, class: "space-y-3" do %>
        <%= render FlatPack::Chat::Textarea::Component.new(
          name: "message[default]",
          placeholder: "Auto-grow and submit on Enter",
          autogrow: true,
          submit_on_enter: true
        ) %>

        <div class="flex items-center justify-between gap-3">
          <p class="text-xs text-(--text-secondary-color)">Press Enter to submit, Shift+Enter for a new line.</p>
          <%= render FlatPack::Button::Component.new(
            icon: "send",
            icon_only: true,
            style: :primary,
            size: :md,
            type: "submit",
            aria: {label: "Send message"},
            class: "border-transparent bg-[var(--chat-send-button-background-color)] text-[var(--chat-send-button-text-color)] hover:bg-[var(--chat-send-button-hover-background-color)] focus-visible:ring-[var(--chat-send-button-focus-ring-color)] shrink-0"
          ) %>
        </div>
      <% end %>

      <% submitted_message = params.dig(:message, :default).to_s.strip %>
      <% if submitted_message.present? %>
        <div class="mt-4">
          <%= render FlatPack::Alert::Component.new(
            title: "Submitted message",
            description: submitted_message,
            variant: :success
          ) %>
        </div>
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= form_with url: demo_chat_textarea_path, method: :get, local: true do %&gt;
          &lt;%= render FlatPack::Chat::Textarea::Component.new(
            name: "message[default]",
            placeholder: "Auto-grow and submit on Enter",
            autogrow: true,
            submit_on_enter: true
          ) %&gt;
          &lt;%= render FlatPack::Button::Component.new(
            icon: "send",
            icon_only: true,
            style: :primary,
            size: :md,
            type: "submit",
            aria: {label: "Send message"},
            class: "border-transparent bg-[var(--chat-send-button-background-color)] text-[var(--chat-send-button-text-color)] hover:bg-[var(--chat-send-button-hover-background-color)] focus-visible:ring-[var(--chat-send-button-focus-ring-color)] shrink-0"
          ) %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo: Multiline (No Submit on Enter)", anchor_link: true, subtitle: "Textarea allows Enter for new lines and does not auto-submit.") %>

    <div class="mb-4 mt-6 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <%= render FlatPack::Chat::Textarea::Component.new(
        name: "message[multiline]",
        placeholder: "Multiline mode without submit on Enter",
        autogrow: true,
        submit_on_enter: false
      ) %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::Textarea::Component.new(
          name: "message[multiline]",
          placeholder: "Multiline mode without submit on Enter",
          autogrow: true,
          submit_on_enter: false
        ) %&gt;
      CODE
    ) %>
  </section>
</div>