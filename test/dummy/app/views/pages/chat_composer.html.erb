<div class="container mx-auto max-w-4xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::Composer",
    subtitle: "Message input area with left, center, and right slots plus attachments."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_composer, anchor: "component-method-variables" %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo", anchor_link: true, subtitle: "Composer with attachment, left controls, center textarea, and right send action.") %>

    <div class="mb-4 mt-6 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <%= render FlatPack::Chat::Composer::Component.new do |composer| %>
        <% composer.attachment do %>
          <%= render FlatPack::Chat::Attachment::Component.new(type: :file, name: "draft-copy.txt", meta: "18 KB") %>
        <% end %>

        <% composer.left do %>
          <%= render FlatPack::Button::Dropdown::Component.new(
            text: "",
            icon: "plus",
            style: :default,
            size: :md,
            show_chevron: false,
            position: :top_left,
            trigger_attributes: {
              aria: {label: "Attach options"},
              title: "Attach options"
            }
          ) do |dropdown| %>
            <% dropdown.menu_item(text: "Upload file", icon: "file", href: "#") %>
            <% dropdown.menu_item(text: "Attach from library", icon: "folder", href: "#") %>
          <% end %>
        <% end %>

        <% composer.center do %>
          <%= render FlatPack::Chat::Textarea::Component.new(
            name: "composer[body]",
            placeholder: "Type your update...",
            autogrow: true,
            submit_on_enter: false
          ) %>
        <% end %>

        <% composer.right do %>
          <%= render FlatPack::Button::Component.new(
            icon: "send",
            icon_only: true,
            style: :primary,
            size: :md,
            type: "submit",
            aria: {label: "Send message"},
            class: "border-transparent bg-[var(--chat-send-button-background-color)] text-[var(--chat-send-button-text-color)] hover:bg-[var(--chat-send-button-hover-background-color)] focus-visible:ring-[var(--chat-send-button-focus-ring-color)] shrink-0"
          ) %>
        <% end %>
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::Composer::Component.new do |composer| %&gt;
          &lt;% composer.attachment do %&gt;
            &lt;%= render FlatPack::Chat::Attachment::Component.new(type: :file, name: "draft-copy.txt", meta: "18 KB") %&gt;
          &lt;% end %&gt;

          &lt;% composer.left do %&gt;
            &lt;%= render FlatPack::Button::Dropdown::Component.new(
              text: "",
              icon: "plus",
              style: :default,
              size: :md,
              show_chevron: false,
              position: :top_left,
              trigger_attributes: {
                aria: {label: "Attach options"},
                title: "Attach options"
              }
            ) do |dropdown| %&gt;
              &lt;% dropdown.menu_item(text: "Upload file", icon: "file", href: "#") %&gt;
              &lt;% dropdown.menu_item(text: "Attach from library", icon: "folder", href: "#") %&gt;
            &lt;% end %&gt;
          &lt;% end %&gt;

          &lt;% composer.center do %&gt;
            &lt;%= render FlatPack::Chat::Textarea::Component.new(
              name: "composer[body]",
              placeholder: "Type your update...",
              autogrow: true,
              submit_on_enter: false
            ) %&gt;
          &lt;% end %&gt;

          &lt;% composer.right do %&gt;
            &lt;%= render FlatPack::Button::Component.new(
              icon: "send",
              icon_only: true,
              style: :primary,
              size: :md,
              type: "submit",
              aria: {label: "Send message"},
              class: "border-transparent bg-[var(--chat-send-button-background-color)] text-[var(--chat-send-button-text-color)] hover:bg-[var(--chat-send-button-hover-background-color)] focus-visible:ring-[var(--chat-send-button-focus-ring-color)] shrink-0"
            ) %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo (Fully Rounded)", anchor: "demo-fully-rounded", anchor_link: true, subtitle: "Composer with token-driven full corner radius and round action/send buttons.") %>

    <div class="mb-4 mt-6 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <%= render FlatPack::Chat::Composer::Component.new(style: "--chat-composer-radius: 9999px;") do |composer| %>
        <% composer.left do %>
          <%= render FlatPack::Button::Component.new(
            icon: "plus",
            icon_only: true,
            style: :default,
            size: :md,
            aria: {label: "Add attachment"},
            class: "[--button-border-radius:9999px]"
          ) %>
        <% end %>

        <% composer.center do %>
          <%= render FlatPack::Chat::Textarea::Component.new(
            name: "composer[body_rounded]",
            placeholder: "Write a quick update...",
            autogrow: true,
            submit_on_enter: false
          ) %>
        <% end %>

        <% composer.right do %>
          <%= render FlatPack::Button::Component.new(
            icon: "send",
            icon_only: true,
            style: :primary,
            size: :md,
            type: "submit",
            aria: {label: "Send message"},
            class: "border-transparent bg-[var(--chat-send-button-background-color)] text-[var(--chat-send-button-text-color)] hover:bg-[var(--chat-send-button-hover-background-color)] focus-visible:ring-[var(--chat-send-button-focus-ring-color)] shrink-0 [--button-border-radius:9999px]"
          ) %>
        <% end %>
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::Composer::Component.new(style: "--chat-composer-radius: 9999px;") do |composer| %&gt;
          &lt;% composer.left do %&gt;
            &lt;%= render FlatPack::Button::Component.new(
              icon: "plus",
              icon_only: true,
              style: :default,
              size: :md,
              aria: {label: "Add attachment"},
              class: "[--button-border-radius:9999px]"
            ) %&gt;
          &lt;% end %&gt;

          &lt;% composer.center do %&gt;
            &lt;%= render FlatPack::Chat::Textarea::Component.new(
              name: "composer[body_rounded]",
              placeholder: "Write a quick update...",
              autogrow: true,
              submit_on_enter: false
            ) %&gt;
          &lt;% end %&gt;

          &lt;% composer.right do %&gt;
            &lt;%= render FlatPack::Button::Component.new(
              icon: "send",
              icon_only: true,
              style: :primary,
              size: :md,
              type: "submit",
              aria: {label: "Send message"},
              class: "border-transparent bg-[var(--chat-send-button-background-color)] text-[var(--chat-send-button-text-color)] hover:bg-[var(--chat-send-button-hover-background-color)] focus-visible:ring-[var(--chat-send-button-focus-ring-color)] shrink-0 [--button-border-radius:9999px]"
            ) %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo (No Attachment)", anchor: "demo-no-attachment", anchor_link: true, subtitle: "Composer with center textarea and right send action only.") %>

    <div class="mb-4 mt-6 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <%= render FlatPack::Chat::Composer::Component.new do |composer| %>
        <% composer.center do %>
          <%= render FlatPack::Chat::Textarea::Component.new(
            name: "composer[body_no_attachment]",
            placeholder: "Type your message...",
            autogrow: true,
            submit_on_enter: false
          ) %>
        <% end %>

        <% composer.right do %>
          <%= render FlatPack::Button::Component.new(
            icon: "send",
            icon_only: true,
            style: :primary,
            size: :md,
            type: "submit",
            aria: {label: "Send message"},
            class: "border-transparent bg-[var(--chat-send-button-background-color)] text-[var(--chat-send-button-text-color)] hover:bg-[var(--chat-send-button-hover-background-color)] focus-visible:ring-[var(--chat-send-button-focus-ring-color)] shrink-0"
          ) %>
        <% end %>
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::Composer::Component.new do |composer| %&gt;
          &lt;% composer.center do %&gt;
            &lt;%= render FlatPack::Chat::Textarea::Component.new(
              name: "composer[body_no_attachment]",
              placeholder: "Type your message...",
              autogrow: true,
              submit_on_enter: false
            ) %&gt;
          &lt;% end %&gt;

          &lt;% composer.right do %&gt;
            &lt;%= render FlatPack::Button::Component.new(
              icon: "send",
              icon_only: true,
              style: :primary,
              size: :md,
              type: "submit",
              aria: {label: "Send message"},
              class: "border-transparent bg-[var(--chat-send-button-background-color)] text-[var(--chat-send-button-text-color)] hover:bg-[var(--chat-send-button-hover-background-color)] focus-visible:ring-[var(--chat-send-button-focus-ring-color)] shrink-0"
            ) %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>
</div>