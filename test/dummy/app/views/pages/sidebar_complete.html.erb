<%= render FlatPack::PageTitle::Component.new(
  title: "Sidebar Complete",
  subtitle: "One complete sidebar example combining header, grouped nav, badges, and footer."
) %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Complete Sidebar", anchor_link: true) %>
  <div class="rounded-lg overflow-hidden h-[520px] mb-4">
    <%= render FlatPack::Sidebar::Component.new(class: "border border-[var(--surface-border-color)] rounded-lg") do |sidebar| %>
      <% sidebar.header do %>
        <%= render FlatPack::Sidebar::Header::Component.new(
          brand_abbr: "FP",
          title: "FlatPack",
          subtitle: "Complete Demo",
          collapsible: false
        ) %>
      <% end %>

      <% sidebar.items do %>
        <nav class="py-4 space-y-1">
          <%= render FlatPack::Sidebar::Item::Component.new(label: "Overview", href: "#", icon: :home, active: true) %>
          <%= render FlatPack::Sidebar::Item::Component.new(label: "Inbox", href: "#", icon: :dashboard, badge: "8") %>
          <%= render FlatPack::Sidebar::Item::Component.new(label: "Alerts", href: "#", icon: :alert, badge: "2") %>

          <%= render FlatPack::Sidebar::Divider::Component.new %>

          <%= render FlatPack::Sidebar::Group::Component.new(label: "Components", icon: :folder, default_open: true) do |group| %>
            <% group.items do %>
              <%= render FlatPack::Sidebar::Item::Component.new(label: "Buttons", href: demo_buttons_path, icon: :square) %>
              <%= render FlatPack::Sidebar::Item::Component.new(label: "Forms", href: demo_forms_path, icon: :edit_3) %>
              <%= render FlatPack::Sidebar::Item::Component.new(label: "Tables", href: demo_tables_basic_path, icon: :table) %>
            <% end %>
          <% end %>

          <%= render FlatPack::Sidebar::Group::Component.new(label: "Settings", icon: :settings, default_open: false) do |group| %>
            <% group.items do %>
              <%= render FlatPack::Sidebar::Item::Component.new(label: "Team", href: "#", icon: :users) %>
              <%= render FlatPack::Sidebar::Item::Component.new(label: "Permissions", href: "#", icon: :key) %>
            <% end %>
          <% end %>
        </nav>
      <% end %>

      <% sidebar.footer do %>
        <%= render FlatPack::Sidebar::Footer::Component.new(class: "text-sm text-[var(--surface-muted-content-color)]") do %>
          Signed in as demo@flatpack.app
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;rounded-lg overflow-hidden h-[520px] mb-4&quot;&gt;
        &lt;%= render FlatPack::Sidebar::Component.new(class: &quot;border border-[var(--surface-border-color)] rounded-lg&quot;) do |sidebar| %&gt;
          &lt;% sidebar.header do %&gt;
            &lt;%= render FlatPack::Sidebar::Header::Component.new(
              brand_abbr: &quot;FP&quot;,
              title: &quot;FlatPack&quot;,
              subtitle: &quot;Complete Demo&quot;,
              collapsible: false
            ) %&gt;
          &lt;% end %&gt;
    
          &lt;% sidebar.items do %&gt;
            &lt;nav class=&quot;py-4 space-y-1&quot;&gt;
              &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Overview&quot;, href: &quot;#&quot;, icon: :home, active: true) %&gt;
              &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Inbox&quot;, href: &quot;#&quot;, icon: :dashboard, badge: &quot;8&quot;) %&gt;
              &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Alerts&quot;, href: &quot;#&quot;, icon: :alert, badge: &quot;2&quot;) %&gt;
    
              &lt;%= render FlatPack::Sidebar::Divider::Component.new %&gt;
    
              &lt;%= render FlatPack::Sidebar::Group::Component.new(label: &quot;Components&quot;, icon: :folder, default_open: true) do |group| %&gt;
                &lt;% group.items do %&gt;
                  &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Buttons&quot;, href: demo_buttons_path, icon: :square) %&gt;
                  &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Forms&quot;, href: demo_forms_path, icon: :edit_3) %&gt;
                  &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Tables&quot;, href: demo_tables_basic_path, icon: :table) %&gt;
                &lt;% end %&gt;
              &lt;% end %&gt;
    
              &lt;%= render FlatPack::Sidebar::Group::Component.new(label: &quot;Settings&quot;, icon: :settings, default_open: false) do |group| %&gt;
                &lt;% group.items do %&gt;
                  &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Team&quot;, href: &quot;#&quot;, icon: :users) %&gt;
                  &lt;%= render FlatPack::Sidebar::Item::Component.new(label: &quot;Permissions&quot;, href: &quot;#&quot;, icon: :key) %&gt;
                &lt;% end %&gt;
              &lt;% end %&gt;
            &lt;/nav&gt;
          &lt;% end %&gt;
    
          &lt;% sidebar.footer do %&gt;
            &lt;%= render FlatPack::Sidebar::Footer::Component.new(class: &quot;text-sm text-[var(--surface-muted-content-color)]&quot;) do %&gt;
              Signed in as demo@flatpack.app
            &lt;% end %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Complete Sidebar"
  ) %>
</section>
