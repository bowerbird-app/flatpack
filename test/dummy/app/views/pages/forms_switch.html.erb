<%= render FlatPack::PageTitle::Component.new(
  title: "Switch",
  subtitle: "Boolean toggle input examples with sizes and states."
) %>

<%= render "pages/component_method_variables_table", component: :text_input %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Switch Examples", anchor_link: true) %>

  <div class="space-y-4 p-6 border border-slate-200 rounded-lg bg-white">
    <%= render FlatPack::Switch::Component.new(
      name: "feature_toggle",
      label: "Enable feature"
    ) %>

    <%= render FlatPack::Switch::Component.new(
      name: "autosave_toggle",
      label: "Auto-save",
      checked: true
    ) %>

    <%= render FlatPack::Switch::Component.new(
      name: "disabled_toggle",
      label: "Disabled toggle",
      disabled: true
    ) %>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;space-y-4 p-6 border border-slate-200 rounded-lg bg-white&quot;&gt;
        &lt;%= render FlatPack::Switch::Component.new(
          name: &quot;feature_toggle&quot;,
          label: &quot;Enable feature&quot;
        ) %&gt;
    
        &lt;%= render FlatPack::Switch::Component.new(
          name: &quot;autosave_toggle&quot;,
          label: &quot;Auto-save&quot;,
          checked: true
        ) %&gt;
    
        &lt;%= render FlatPack::Switch::Component.new(
          name: &quot;disabled_toggle&quot;,
          label: &quot;Disabled toggle&quot;,
          disabled: true
        ) %&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Switch Examples"
  ) %>
</section>
