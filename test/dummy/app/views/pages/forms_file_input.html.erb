<%= render FlatPack::PageTitle::Component.new(
  title: "File Input",
  subtitle: "Upload field examples with file constraints and previews."
) %>

<%= render "pages/component_method_variables_table", component: :text_input %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "File Input Examples", anchor_link: true) %>

  <%= render FlatPack::Card::Component.new do |card| %>
    <% card.body(class: "space-y-[var(--stack-gap-md)]") do %>
      <%= render FlatPack::FileInput::Component.new(
        name: "avatar",
        label: "Profile Picture",
        accept: "image/png,image/jpeg,image/gif",
        max_size: 2_097_152,
        preview: true
      ) %>

      <%= render FlatPack::FileInput::Component.new(
        name: "documents",
        label: "Upload Documents",
        accept: ".pdf,.doc,.docx",
        multiple: true,
        max_size: 5_242_880,
        preview: false
      ) %>
    <% end %>
  <% end %>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;%= render FlatPack::Card::Component.new do |card| %&gt;
        &lt;% card.body do %&gt;
        &lt;%= render FlatPack::FileInput::Component.new(
          name: &quot;avatar&quot;,
          label: &quot;Profile Picture&quot;,
          accept: &quot;image/png,image/jpeg,image/gif&quot;,
          max_size: 2_097_152,
          preview: true
        ) %&gt;
    
        &lt;%= render FlatPack::FileInput::Component.new(
          name: &quot;documents&quot;,
          label: &quot;Upload Documents&quot;,
          accept: &quot;.pdf,.doc,.docx&quot;,
          multiple: true,
          max_size: 5_242_880,
          preview: false
        ) %&gt;
        &lt;% end %&gt;
      &lt;% end %&gt;
    CODE
    language: "erb",
    title: "File Input Examples"
  ) %>
</section>
