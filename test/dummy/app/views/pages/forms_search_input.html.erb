<%= render FlatPack::PageTitle::Component.new(
  title: "Search Input",
  subtitle: "Search field examples with placeholder and prefilled value states."
) %>

<%= render "pages/component_method_variables_table", component: :text_input %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Search Input Examples", anchor_link: true) %>

  <%= render FlatPack::Card::Component.new do |card| %>
    <% card.body(class: "space-y-[var(--stack-gap-md)]") do %>
      <%= render FlatPack::SearchInput::Component.new(
        name: "search",
        label: "Search",
        placeholder: "Search for anything..."
      ) %>

      <%= render FlatPack::SearchInput::Component.new(
        name: "search_with_value",
        label: "Search (with value)",
        value: "sample query"
      ) %>
    <% end %>
  <% end %>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;%= render FlatPack::Card::Component.new do |card| %&gt;
        &lt;% card.body do %&gt;
        &lt;%= render FlatPack::SearchInput::Component.new(
          name: &quot;search&quot;,
          label: &quot;Search&quot;,
          placeholder: &quot;Search for anything...&quot;
        ) %&gt;
    
        &lt;%= render FlatPack::SearchInput::Component.new(
          name: &quot;search_with_value&quot;,
          label: &quot;Search (with value)&quot;,
          value: &quot;sample query&quot;
        ) %&gt;
        &lt;% end %&gt;
      &lt;% end %&gt;
    CODE
    language: "erb",
    title: "Search Input Examples"
  ) %>
</section>
