<%= render FlatPack::PageTitle::Component.new(
  title: "Carousel Component",
  subtitle: "Carousel with mixed content, controls, indicators, thumbnails, and transitions."
) %>

<%= render "pages/component_method_variables_table", component: :carousel %>

<!-- Basic Carousel -->
<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Basic Carousel", anchor_link: true, subtitle: "Examples for Basic Carousel.") %>
  <div class="mb-4 overflow-hidden rounded-xl border border-(--surface-border-color) bg-(--surface-background-color) p-4">
    <%= render FlatPack::Carousel::Component.new(
      slides: @carousel_slides,
      show_controls: true,
      show_indicators: true,
      show_captions: true,
      caption_mode: :below,
      aspect_ratio: "16/9",
      aria_label: "Basic carousel demo"
    ) %>
  </div>
  <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-(--surface-muted-content-color)">Code Example</p>
  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE')
      &lt;%= render FlatPack::Carousel::Component.new(
        slides: @carousel_slides,
        show_controls: true,
        show_indicators: true,
        show_captions: true,
        caption_mode: :below,
        aspect_ratio: "16/9"
      ) %&gt;
    CODE
  ) %>
</section>

<!-- Carousel with Thumbnails and Autoplay -->
<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Carousel with Thumbnails and Autoplay", anchor_link: true, subtitle: "Examples for Carousel with Thumbnails and Autoplay.") %>
  <div class="mb-4 overflow-hidden rounded-xl border border-(--surface-border-color) bg-(--surface-background-color) p-4">
    <%= render FlatPack::Carousel::Component.new(
      slides: @carousel_slides,
      show_thumbs: true,
      thumbs_position: :bottom,
      thumbs_alignment: :center,
      show_indicators: true,
      show_controls: true,
      autoplay: true,
      autoplay_interval_ms: 4000,
      pause_on_hover: true,
      pause_on_focus: true,
      loop: true,
      caption_mode: :overlay,
      aspect_ratio: "16/9",
      aria_label: "Carousel with thumbnails and autoplay"
    ) %>
  </div>
  <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-(--surface-muted-content-color)">Code Example</p>
  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE')
      &lt;%= render FlatPack::Carousel::Component.new(
        slides: @carousel_slides,
        show_thumbs: true,
        thumbs_position: :bottom,
        thumbs_alignment: :center,
        autoplay: true,
        autoplay_interval_ms: 4000,
        pause_on_hover: true,
        loop: true,
        caption_mode: :overlay
      ) %&gt;
    CODE
  ) %>
</section>

<!-- Fade Transition Carousel -->
<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Fade Transition", anchor_link: true, subtitle: "Examples for Fade Transition.") %>
  <div class="mb-4 overflow-hidden rounded-xl border border-(--surface-border-color) bg-(--surface-background-color) p-4">
    <%= render FlatPack::Carousel::Component.new(
      slides: @carousel_slides,
      transition: :fade,
      show_controls: true,
      show_indicators: true,
      show_captions: true,
      caption_mode: :overlay,
      aspect_ratio: "16/9",
      aria_label: "Fade transition carousel demo"
    ) %>
  </div>
  <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-(--surface-muted-content-color)">Code Example</p>
  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE')
      &lt;%= render FlatPack::Carousel::Component.new(
        slides: @carousel_slides,
        transition: :fade,
        show_controls: true,
        show_indicators: true,
        caption_mode: :overlay
      ) %&gt;
    CODE
  ) %>
</section>

<!-- Demo Notes -->
<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Demo Notes", anchor_link: true, subtitle: "Examples for Demo Notes.") %>
  <ul class="list-disc space-y-2 pl-5 text-sm text-(--surface-content-color) mb-4">
    <% @carousel_notes.each do |note| %>
      <li><%= note %></li>
    <% end %>
  </ul>
  <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-(--surface-muted-content-color)">Code Example</p>
  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE')
      # Suggested note content
      # - Uses FlatPack::Carousel::Component with mixed image, video, and sanitized HTML slides.
      # - Demonstrates autoplay, loop, indicators, controls, and thumbnail navigation.
      # - Uses secure defaults for rich content and supports keyboard plus touch interactions.
    CODE
  ) %>
</section>
