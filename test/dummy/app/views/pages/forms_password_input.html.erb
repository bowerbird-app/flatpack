<%= render FlatPack::PageTitle::Component.new(
  title: "Password Input",
  subtitle: "Masked field examples with validation messaging."
) %>

<%= render "pages/component_method_variables_table", component: :text_input %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Password Input Examples", anchor_link: true) %>

  <%= render FlatPack::Card::Component.new do |card| %>
    <% card.body(class: "space-y-[var(--stack-gap-md)]") do %>
      <%= render FlatPack::PasswordInput::Component.new(
        name: "password",
        label: "Password",
        placeholder: "Enter your password",
        required: true
      ) %>

      <%= render FlatPack::PasswordInput::Component.new(
        name: "password_live_validation",
        label: "Password (live JS validation)",
        placeholder: "At least 8 chars, 1 uppercase, 1 number",
        required: true,
        minlength: 8,
        pattern: "(?=.*[A-Z])(?=.*\\d).{8,}",
        data: {
          flat_pack_message_required: "Password is required.",
          flat_pack_message_too_short: "Use at least 8 characters.",
          flat_pack_message_pattern_mismatch: "Include at least one uppercase letter and one number."
        }
      ) %>

      <%= render FlatPack::PasswordInput::Component.new(
        name: "password_with_rules",
        label: "Password (validation rules)",
        placeholder: "At least 8 chars, 1 uppercase, 1 number",
        required: true,
        minlength: 8,
        pattern: "(?=.*[A-Z])(?=.*\\d).{8,}",
        data: {
          flat_pack_message_required: "Password is required.",
          flat_pack_message_too_short: "Use at least 8 characters.",
          flat_pack_message_pattern_mismatch: "Include at least one uppercase letter and one number."
        }
      ) %>
    <% end %>
  <% end %>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;%= render FlatPack::Card::Component.new do |card| %&gt;
        &lt;% card.body do %&gt;
        &lt;%= render FlatPack::PasswordInput::Component.new(
          name: &quot;password&quot;,
          label: &quot;Password&quot;,
          placeholder: &quot;Enter your password&quot;,
          required: true
        ) %&gt;
    
        &lt;%= render FlatPack::PasswordInput::Component.new(
          name: &quot;password_live_validation&quot;,
          label: &quot;Password (live JS validation)&quot;,
          placeholder: &quot;At least 8 chars, 1 uppercase, 1 number&quot;,
          required: true,
          minlength: 8,
          pattern: &quot;(?=.*[A-Z])(?=.*\d).{8,}&quot;,
          data: {
            flat_pack_message_required: &quot;Password is required.&quot;,
            flat_pack_message_too_short: &quot;Use at least 8 characters.&quot;,
            flat_pack_message_pattern_mismatch: &quot;Include at least one uppercase letter and one number.&quot;
          }
        ) %&gt;

        &lt;%= render FlatPack::PasswordInput::Component.new(
          name: &quot;password_with_rules&quot;,
          label: &quot;Password (validation rules)&quot;,
          placeholder: &quot;At least 8 chars, 1 uppercase, 1 number&quot;,
          required: true,
          minlength: 8,
          pattern: &quot;(?=.*[A-Z])(?=.*\d).{8,}&quot;,
          data: {
            flat_pack_message_required: &quot;Password is required.&quot;,
            flat_pack_message_too_short: &quot;Use at least 8 characters.&quot;,
            flat_pack_message_pattern_mismatch: &quot;Include at least one uppercase letter and one number.&quot;
          }
        ) %&gt;
        &lt;% end %&gt;
      &lt;% end %&gt;
    CODE
    language: "erb",
    title: "Password Input Examples"
  ) %>
</section>
