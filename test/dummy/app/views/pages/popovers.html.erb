<%= render FlatPack::PageTitle::Component.new(
  title: "Popover Component",
  subtitle: "Click-triggered floating content with smart positioning."
) %>

<!-- Basic Popover -->
<%= render "pages/component_method_variables_table", component: :popover %>
<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Basic Popover", anchor_link: true, subtitle: "Examples for Basic Popover.") %>
  <div class="mb-4">
    <%= render FlatPack::Button::Component.new(id: "popover-trigger-basic", text: "Click me", style: :secondary) %>
    <%= render FlatPack::Popover::Component.new(trigger_id: "popover-trigger-basic", placement: :bottom) do |popover| %>
      <% popover.with_popover_content do %>
        <div class="p-4 w-64">
          <h3 class="font-semibold mb-2">Popover Title</h3>
          <p class="text-sm text-[var(--surface-muted-content-color)]">
            This is a popover with some content. Click outside or press ESC to close.
          </p>
        </div>
      <% end %>
    <% end %>
  </div>
  
  <%= render FlatPack::CodeBlock::Component.new(
    code: <<~CODE
      render FlatPack::Button::Component.new(id: "popover-trigger", text: "Click me")
      render FlatPack::Popover::Component.new(trigger_id: "popover-trigger", placement: :bottom) do |popover|
        popover.with_popover_content do
          "<div class='p-4'><h3>Title</h3><p>Content...</p></div>"
        end
      end
    CODE
  ) %>
</section>

<!-- Popover Placements -->
<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Popover Placements", anchor_link: true, subtitle: "Examples for Popover Placements.") %>
  <div class="flex justify-center items-center flex-wrap gap-4 mb-4">
    <%= render FlatPack::Button::Component.new(id: "popover-trigger-left", text: "Left", style: :secondary) %>
    <%= render FlatPack::Popover::Component.new(trigger_id: "popover-trigger-left", placement: :left) do |popover| %>
      <% popover.with_popover_content do %>
        <div class="p-3 w-52 text-[var(--surface-content-color)]">
          <p class="text-sm font-semibold">Left Popover</p>
          <p class="text-xs text-[var(--surface-muted-content-color)] mt-1">Works well when space is constrained on the right.</p>
        </div>
      <% end %>
    <% end %>

    <%= render FlatPack::Button::Component.new(id: "popover-trigger-top", text: "Top", style: :secondary) %>
    <%= render FlatPack::Popover::Component.new(trigger_id: "popover-trigger-top", placement: :top) do |popover| %>
      <% popover.with_popover_content do %>
        <div class="p-3 w-52 text-[var(--surface-content-color)]">
          <p class="text-sm font-semibold">Top Popover</p>
          <p class="text-xs text-[var(--surface-muted-content-color)] mt-1">Appears above the trigger with short helper text.</p>
        </div>
      <% end %>
    <% end %>

    <%= render FlatPack::Button::Component.new(id: "popover-trigger-bottom", text: "Bottom", style: :secondary) %>
    <%= render FlatPack::Popover::Component.new(trigger_id: "popover-trigger-bottom", placement: :bottom) do |popover| %>
      <% popover.with_popover_content do %>
        <div class="p-3 w-52 text-[var(--surface-content-color)]">
          <p class="text-sm font-semibold">Bottom Popover</p>
          <p class="text-xs text-[var(--surface-muted-content-color)] mt-1">A common pattern for menus and quick actions.</p>
        </div>
      <% end %>
    <% end %>

    <%= render FlatPack::Button::Component.new(id: "popover-trigger-right", text: "Right", style: :secondary) %>
    <%= render FlatPack::Popover::Component.new(trigger_id: "popover-trigger-right", placement: :right) do |popover| %>
      <% popover.with_popover_content do %>
        <div class="p-3 w-52 text-[var(--surface-content-color)]">
          <p class="text-sm font-semibold">Right Popover</p>
          <p class="text-xs text-[var(--surface-muted-content-color)] mt-1">Useful for inline details beside controls.</p>
        </div>
      <% end %>
    <% end %>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;flex justify-center items-center flex-wrap gap-4 mb-4&quot;&gt;
        &lt;%= render FlatPack::Button::Component.new(id: &quot;popover-trigger-left&quot;, text: &quot;Left&quot;, style: :secondary) %&gt;
        &lt;%= render FlatPack::Popover::Component.new(trigger_id: &quot;popover-trigger-left&quot;, placement: :left) do |popover| %&gt;
          &lt;% popover.with_popover_content do %&gt;
            &lt;div class=&quot;p-3 w-52 text-[var(--surface-content-color)]&quot;&gt;
              &lt;p class=&quot;text-sm font-semibold&quot;&gt;Left Popover&lt;/p&gt;
              &lt;p class=&quot;text-xs text-[var(--surface-muted-content-color)] mt-1&quot;&gt;Works well when space is constrained on the right.&lt;/p&gt;
            &lt;/div&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
    
        &lt;%= render FlatPack::Button::Component.new(id: &quot;popover-trigger-top&quot;, text: &quot;Top&quot;, style: :secondary) %&gt;
        &lt;%= render FlatPack::Popover::Component.new(trigger_id: &quot;popover-trigger-top&quot;, placement: :top) do |popover| %&gt;
          &lt;% popover.with_popover_content do %&gt;
            &lt;div class=&quot;p-3 w-52 text-[var(--surface-content-color)]&quot;&gt;
              &lt;p class=&quot;text-sm font-semibold&quot;&gt;Top Popover&lt;/p&gt;
              &lt;p class=&quot;text-xs text-[var(--surface-muted-content-color)] mt-1&quot;&gt;Appears above the trigger with short helper text.&lt;/p&gt;
            &lt;/div&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
    
        &lt;%= render FlatPack::Button::Component.new(id: &quot;popover-trigger-bottom&quot;, text: &quot;Bottom&quot;, style: :secondary) %&gt;
        &lt;%= render FlatPack::Popover::Component.new(trigger_id: &quot;popover-trigger-bottom&quot;, placement: :bottom) do |popover| %&gt;
          &lt;% popover.with_popover_content do %&gt;
            &lt;div class=&quot;p-3 w-52 text-[var(--surface-content-color)]&quot;&gt;
              &lt;p class=&quot;text-sm font-semibold&quot;&gt;Bottom Popover&lt;/p&gt;
              &lt;p class=&quot;text-xs text-[var(--surface-muted-content-color)] mt-1&quot;&gt;A common pattern for menus and quick actions.&lt;/p&gt;
            &lt;/div&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
    
        &lt;%= render FlatPack::Button::Component.new(id: &quot;popover-trigger-right&quot;, text: &quot;Right&quot;, style: :secondary) %&gt;
        &lt;%= render FlatPack::Popover::Component.new(trigger_id: &quot;popover-trigger-right&quot;, placement: :right) do |popover| %&gt;
          &lt;% popover.with_popover_content do %&gt;
            &lt;div class=&quot;p-3 w-52 text-[var(--surface-content-color)]&quot;&gt;
              &lt;p class=&quot;text-sm font-semibold&quot;&gt;Right Popover&lt;/p&gt;
              &lt;p class=&quot;text-xs text-[var(--surface-muted-content-color)] mt-1&quot;&gt;Useful for inline details beside controls.&lt;/p&gt;
            &lt;/div&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Popover Placements"
  ) %>
</section>

<!-- Rich Content Popover -->
<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Rich Content Popover", anchor_link: true, subtitle: "Examples for Rich Content Popover.") %>
  <div class="mb-4">
    <%= render FlatPack::Button::Component.new(id: "popover-trigger-user-info", text: "User Info", style: :primary) %>
    <%= render FlatPack::Popover::Component.new(trigger_id: "popover-trigger-user-info", placement: :bottom) do |popover| %>
      <% popover.with_popover_content do %>
        <div class="p-4 w-72">
          <div class="flex items-start gap-3 mb-3">
            <%= render FlatPack::Avatar::Component.new(name: "John Doe", initials: "JD", size: :xl) %>
            <div>
              <h3 class="font-semibold">John Doe</h3>
              <p class="text-sm text-[var(--surface-muted-content-color)]">john@example.com</p>
            </div>
          </div>
          <div class="space-y-2">
            <%= render FlatPack::Button::Component.new(text: "View Profile", style: :secondary, class: "w-full") %>
            <%= render FlatPack::Button::Component.new(text: "Send Message", style: :ghost, class: "w-full") %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;mb-4&quot;&gt;
        &lt;%= render FlatPack::Button::Component.new(id: &quot;popover-trigger-user-info&quot;, text: &quot;User Info&quot;, style: :primary) %&gt;
        &lt;%= render FlatPack::Popover::Component.new(trigger_id: &quot;popover-trigger-user-info&quot;, placement: :bottom) do |popover| %&gt;
          &lt;% popover.with_popover_content do %&gt;
            &lt;div class=&quot;p-4 w-72&quot;&gt;
              &lt;div class=&quot;flex items-start gap-3 mb-3&quot;&gt;
                &lt;%= render FlatPack::Avatar::Component.new(name: &quot;John Doe&quot;, initials: &quot;JD&quot;, size: :xl) %&gt;
                &lt;div&gt;
                  &lt;h3 class=&quot;font-semibold&quot;&gt;John Doe&lt;/h3&gt;
                  &lt;p class=&quot;text-sm text-[var(--surface-muted-content-color)]&quot;&gt;john@example.com&lt;/p&gt;
                &lt;/div&gt;
              &lt;/div&gt;
              &lt;div class=&quot;space-y-2&quot;&gt;
                &lt;%= render FlatPack::Button::Component.new(text: &quot;View Profile&quot;, style: :secondary, class: &quot;w-full&quot;) %&gt;
                &lt;%= render FlatPack::Button::Component.new(text: &quot;Send Message&quot;, style: :ghost, class: &quot;w-full&quot;) %&gt;
              &lt;/div&gt;
            &lt;/div&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Rich Content Popover"
  ) %>
</section>

<!-- Popover with Form -->
<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Popover with Form", anchor_link: true, subtitle: "Examples for Popover with Form.") %>
  <div class="mb-4">
    <%= render FlatPack::Button::Component.new(id: "popover-trigger-add-comment", text: "Add Comment", style: :secondary) %>
    <%= render FlatPack::Popover::Component.new(trigger_id: "popover-trigger-add-comment", placement: :bottom) do |popover| %>
      <% popover.with_popover_content do %>
        <div class="p-4 w-80">
          <h3 class="font-semibold mb-3">Quick Comment</h3>
          <form class="space-y-3">
            <%= render FlatPack::TextArea::Component.new(
              name: "comment",
              placeholder: "Enter your comment...",
              rows: 3
            ) %>
            <div class="flex gap-2">
              <%= render FlatPack::Button::Component.new(text: "Cancel", style: :ghost, size: :sm) %>
              <%= render FlatPack::Button::Component.new(text: "Submit", style: :primary, size: :sm) %>
            </div>
          </form>
        </div>
      <% end %>
    <% end %>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;mb-4&quot;&gt;
        &lt;%= render FlatPack::Button::Component.new(id: &quot;popover-trigger-add-comment&quot;, text: &quot;Add Comment&quot;, style: :secondary) %&gt;
        &lt;%= render FlatPack::Popover::Component.new(trigger_id: &quot;popover-trigger-add-comment&quot;, placement: :bottom) do |popover| %&gt;
          &lt;% popover.with_popover_content do %&gt;
            &lt;div class=&quot;p-4 w-80&quot;&gt;
              &lt;h3 class=&quot;font-semibold mb-3&quot;&gt;Quick Comment&lt;/h3&gt;
              &lt;form class=&quot;space-y-3&quot;&gt;
                &lt;%= render FlatPack::TextArea::Component.new(
                  name: &quot;comment&quot;,
                  placeholder: &quot;Enter your comment...&quot;,
                  rows: 3
                ) %&gt;
                &lt;div class=&quot;flex gap-2&quot;&gt;
                  &lt;%= render FlatPack::Button::Component.new(text: &quot;Cancel&quot;, style: :ghost, size: :sm) %&gt;
                  &lt;%= render FlatPack::Button::Component.new(text: &quot;Submit&quot;, style: :primary, size: :sm) %&gt;
                &lt;/div&gt;
              &lt;/form&gt;
            &lt;/div&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Popover with Form"
  ) %>
</section>

<!-- Popover with List -->
<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Popover with List", anchor_link: true, subtitle: "Examples for Popover with List.") %>
  <div class="mb-4">
    <%= render FlatPack::Button::Component.new(id: "popover-trigger-more-actions", text: "More Actions", style: :secondary) %>
    <%= render FlatPack::Popover::Component.new(trigger_id: "popover-trigger-more-actions", placement: :bottom) do |popover| %>
      <% popover.with_popover_content do %>
        <div class="py-2 w-48">
          <%= render FlatPack::Button::Component.new(text: "Edit", url: "#", style: :ghost, size: :sm, class: "w-full justify-start") %>
          <%= render FlatPack::Button::Component.new(text: "Duplicate", url: "#", style: :ghost, size: :sm, class: "w-full justify-start") %>
          <%= render FlatPack::Button::Component.new(text: "Archive", url: "#", style: :ghost, size: :sm, class: "w-full justify-start") %>
          <div class="border-t border-[var(--surface-border-color)] my-2"></div>
          <%= render FlatPack::Button::Component.new(text: "Delete", url: "#", style: :ghost, size: :sm, class: "w-full justify-start text-red-600") %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;mb-4&quot;&gt;
        &lt;%= render FlatPack::Button::Component.new(id: &quot;popover-trigger-more-actions&quot;, text: &quot;More Actions&quot;, style: :secondary) %&gt;
        &lt;%= render FlatPack::Popover::Component.new(trigger_id: &quot;popover-trigger-more-actions&quot;, placement: :bottom) do |popover| %&gt;
          &lt;% popover.with_popover_content do %&gt;
            &lt;div class=&quot;py-2 w-48&quot;&gt;
              &lt;a href=&quot;#&quot; class=&quot;block px-4 py-2 text-sm hover:bg-[var(--surface-muted-background-color)] transition-colors&quot;&gt;
                Edit
              &lt;/a&gt;
              &lt;a href=&quot;#&quot; class=&quot;block px-4 py-2 text-sm hover:bg-[var(--surface-muted-background-color)] transition-colors&quot;&gt;
                Duplicate
              &lt;/a&gt;
              &lt;a href=&quot;#&quot; class=&quot;block px-4 py-2 text-sm hover:bg-[var(--surface-muted-background-color)] transition-colors&quot;&gt;
                Archive
              &lt;/a&gt;
              &lt;div class=&quot;border-t border-[var(--surface-border-color)] my-2&quot;&gt;&lt;/div&gt;
              &lt;a href=&quot;#&quot; class=&quot;block px-4 py-2 text-sm text-red-600 hover:bg-[var(--surface-muted-background-color)] transition-colors&quot;&gt;
                Delete
              &lt;/a&gt;
            &lt;/div&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Popover with List"
  ) %>
</section>

<!-- Features -->
<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Features", anchor_link: true, subtitle: "Examples for Features.") %>
  <%= render FlatPack::List::Component.new(spacing: :dense, class: "text-[var(--surface-content-color)]") do %>
    <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Click to Open:</strong> Opens on click, not hover<% end %>
    <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Smart Positioning:</strong> Automatically adjusts for viewport boundaries<% end %>
    <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Click Outside:</strong> Closes when clicking outside the popover<% end %>
    <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>ESC to Close:</strong> Press ESC key to dismiss<% end %>
    <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Rich Content:</strong> Support for any HTML content<% end %>
    <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>No Dependencies:</strong> Pure Stimulus implementation<% end %>
    <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Accessible:</strong> Proper ARIA attributes<% end %>
    <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Smooth Animations:</strong> Fade in/out transitions<% end %>
  <% end %>
</section>
