<%= render FlatPack::PageTitle::Component.new(
  title: "Timeline Components",
  subtitle: "Display chronological events with visual markers and connecting lines."
) %>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Basic Timeline", anchor_link: true) %>
  
  <div class="border border-[var(--surface-border-color)] rounded-lg p-6">
    <%= render FlatPack::Timeline::Component.new do %>
      <%= render FlatPack::Timeline::Item.new(
        title: "Project Created",
        timestamp: "Jan 15, 2024"
      ) do %>
        <p>The project repository was initialized and the initial commit was pushed to the main branch.</p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "First Feature Implemented",
        timestamp: "Jan 18, 2024"
      ) do %>
        <p>Core authentication system implemented with secure password hashing and JWT tokens.</p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Beta Testing Started",
        timestamp: "Jan 25, 2024"
      ) do %>
        <p>First group of beta testers invited. Collecting feedback and tracking issues.</p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Production Launch",
        timestamp: "Feb 1, 2024",
        last: true
      ) do %>
        <p>Successfully launched to production with all critical features complete and tested.</p>
      <% end %>
    <% end %>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;border border-[var(--surface-border-color)] rounded-lg p-6&quot;&gt;
        &lt;%= render FlatPack::Timeline::Component.new do %&gt;
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Project Created&quot;,
            timestamp: &quot;Jan 15, 2024&quot;
          ) do %&gt;
            &lt;p&gt;The project repository was initialized and the initial commit was pushed to the main branch.&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;First Feature Implemented&quot;,
            timestamp: &quot;Jan 18, 2024&quot;
          ) do %&gt;
            &lt;p&gt;Core authentication system implemented with secure password hashing and JWT tokens.&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Beta Testing Started&quot;,
            timestamp: &quot;Jan 25, 2024&quot;
          ) do %&gt;
            &lt;p&gt;First group of beta testers invited. Collecting feedback and tracking issues.&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Production Launch&quot;,
            timestamp: &quot;Feb 1, 2024&quot;,
            last: true
          ) do %&gt;
            &lt;p&gt;Successfully launched to production with all critical features complete and tested.&lt;/p&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Basic Timeline"
  ) %>
</section>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Deployment Timeline", anchor_link: true) %>
  
  <div class="border border-[var(--surface-border-color)] rounded-lg p-6">
    <%= render FlatPack::Timeline::Component.new do %>
      <%= render FlatPack::Timeline::Item.new(
        title: "Build Started",
        timestamp: "10:00 AM",
        variant: :default
      ) do %>
        <p>Running tests and building Docker container...</p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Tests Passed",
        timestamp: "10:05 AM",
        variant: :success
      ) do %>
        <p>All 247 tests passed successfully. Code coverage: 94%</p>
        <div class="mt-2">
          <%= render FlatPack::Badge::Component.new(text: "247 tests", style: :success, size: :sm) %>
          <%= render FlatPack::Badge::Component.new(text: "94% coverage", style: :primary, size: :sm) %>
        </div>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Security Scan Warning",
        timestamp: "10:07 AM",
        variant: :warning
      ) do %>
        <p>Dependency vulnerability detected in development dependencies (non-blocking).</p>
        <%= render FlatPack::Badge::Component.new(text: "Low Severity", style: :warning, size: :sm, class: "mt-2") %>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Deployed to Staging",
        timestamp: "10:10 AM",
        variant: :success
      ) do %>
        <p>Application successfully deployed to staging environment.</p>
        <p class="mt-1 text-sm"><a href="#" class="text-[var(--color-primary)] hover:underline">View staging: https://staging.example.com</a></p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Production Deployment",
        timestamp: "10:15 AM",
        variant: :success,
        last: true
      ) do %>
        <p>Production deployment completed. Monitoring for issues.</p>
        <div class="mt-2 space-x-2">
          <%= render FlatPack::Button::Component.new(text: "View Logs", variant: :outline, size: :sm) %>
          <%= render FlatPack::Button::Component.new(text: "Monitor", variant: :outline, size: :sm) %>
        </div>
      <% end %>
    <% end %>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;border border-[var(--surface-border-color)] rounded-lg p-6&quot;&gt;
        &lt;%= render FlatPack::Timeline::Component.new do %&gt;
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Build Started&quot;,
            timestamp: &quot;10:00 AM&quot;,
            variant: :default
          ) do %&gt;
            &lt;p&gt;Running tests and building Docker container...&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Tests Passed&quot;,
            timestamp: &quot;10:05 AM&quot;,
            variant: :success
          ) do %&gt;
            &lt;p&gt;All 247 tests passed successfully. Code coverage: 94%&lt;/p&gt;
            &lt;div class=&quot;mt-2&quot;&gt;
              &lt;%= render FlatPack::Badge::Component.new(text: &quot;247 tests&quot;, style: :success, size: :sm) %&gt;
              &lt;%= render FlatPack::Badge::Component.new(text: &quot;94% coverage&quot;, style: :primary, size: :sm) %&gt;
            &lt;/div&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Security Scan Warning&quot;,
            timestamp: &quot;10:07 AM&quot;,
            variant: :warning
          ) do %&gt;
            &lt;p&gt;Dependency vulnerability detected in development dependencies (non-blocking).&lt;/p&gt;
            &lt;%= render FlatPack::Badge::Component.new(text: &quot;Low Severity&quot;, style: :warning, size: :sm, class: &quot;mt-2&quot;) %&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Deployed to Staging&quot;,
            timestamp: &quot;10:10 AM&quot;,
            variant: :success
          ) do %&gt;
            &lt;p&gt;Application successfully deployed to staging environment.&lt;/p&gt;
            &lt;p class=&quot;mt-1 text-sm&quot;&gt;&lt;a href=&quot;#&quot; class=&quot;text-[var(--color-primary)] hover:underline&quot;&gt;View staging: https://staging.example.com&lt;/a&gt;&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Production Deployment&quot;,
            timestamp: &quot;10:15 AM&quot;,
            variant: :success,
            last: true
          ) do %&gt;
            &lt;p&gt;Production deployment completed. Monitoring for issues.&lt;/p&gt;
            &lt;div class=&quot;mt-2 space-x-2&quot;&gt;
              &lt;%= render FlatPack::Button::Component.new(text: &quot;View Logs&quot;, variant: :outline, size: :sm) %&gt;
              &lt;%= render FlatPack::Button::Component.new(text: &quot;Monitor&quot;, variant: :outline, size: :sm) %&gt;
            &lt;/div&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Deployment Timeline"
  ) %>
</section>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Order Tracking", anchor_link: true) %>
  
  <div class="border border-[var(--surface-border-color)] rounded-lg p-6">
    <%= render FlatPack::Timeline::Component.new do %>
      <%= render FlatPack::Timeline::Item.new(
        title: "Order Placed",
        timestamp: "Feb 20, 10:30 AM",
        variant: :success
      ) do %>
        <p>Your order #12345 has been confirmed and payment received.</p>
        <p class="text-sm mt-1 text-[var(--surface-muted-content-color)]">Total: $149.99</p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Processing",
        timestamp: "Feb 20, 2:15 PM",
        variant: :success
      ) do %>
        <p>Order is being prepared for shipment at our warehouse.</p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Shipped",
        timestamp: "Feb 21, 9:00 AM",
        variant: :success
      ) do %>
        <p>Package has been handed to carrier for delivery.</p>
        <p class="text-sm mt-1 text-[var(--surface-muted-content-color)]">Tracking: 1Z999AA10123456784</p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Out for Delivery",
        timestamp: "Feb 22, 8:30 AM",
        variant: :warning
      ) do %>
        <p>Your package is on the delivery vehicle and will arrive today.</p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Expected Delivery",
        timestamp: "Feb 22, by 5:00 PM",
        variant: :default,
        last: true
      ) do %>
        <p>Package scheduled to arrive by end of day.</p>
      <% end %>
    <% end %>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;border border-[var(--surface-border-color)] rounded-lg p-6&quot;&gt;
