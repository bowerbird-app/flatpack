          ) do %&gt;
            &lt;p&gt;&lt;strong&gt;John Doe&lt;/strong&gt; opened PR #123: &quot;Add user authentication&quot;&lt;/p&gt;
            &lt;div class=&quot;mt-2 space-x-2&quot;&gt;
              &lt;%= render FlatPack::Badge::Component.new(text: &quot;+350&quot;, style: :success, size: :sm) %&gt;
              &lt;%= render FlatPack::Badge::Component.new(text: &quot;-120&quot;, style: :warning, size: :sm) %&gt;
            &lt;/div&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Code Review&quot;,
            timestamp: &quot;1 hour ago&quot;
          ) do %&gt;
            &lt;p&gt;&lt;strong&gt;Jane Smith&lt;/strong&gt; reviewed and requested changes on PR #123&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Changes Committed&quot;,
            timestamp: &quot;30 minutes ago&quot;
          ) do %&gt;
            &lt;p&gt;&lt;strong&gt;John Doe&lt;/strong&gt; pushed 3 new commits addressing review feedback&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Approved&quot;,
            timestamp: &quot;15 minutes ago&quot;,
            variant: :success
          ) do %&gt;
            &lt;p&gt;&lt;strong&gt;Jane Smith&lt;/strong&gt; approved the changes&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Merged&quot;,
            timestamp: &quot;5 minutes ago&quot;,
            variant: :success,
            last: true
          ) do %&gt;
            &lt;p&gt;&lt;strong&gt;John Doe&lt;/strong&gt; merged PR #123 into main&lt;/p&gt;
            &lt;p class=&quot;text-sm mt-1 text-[var(--surface-muted-content-color)]&quot;&gt;Automatically deployed to production&lt;/p&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Activity Feed"
  ) %>
</section>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Use Cases", anchor_link: true) %>
  
  <div class="prose max-w-none">
    <%= render FlatPack::List::Component.new(spacing: :dense) do %>
      <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Activity Feeds:</strong> Display user activities and interactions<% end %>
      <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Order Tracking:</strong> Show shipment and delivery status<% end %>
      <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Project Milestones:</strong> Track project progress over time<% end %>
      <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Deployment History:</strong> Log deployments and releases<% end %>
      <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Git History:</strong> Visualize commits and branches<% end %>
      <%= render FlatPack::List::Item.new(class: "py-0 px-0") do %><strong>Audit Logs:</strong> Display system events chronologically<% end %>
    <% end %>
  </div>
</section>
