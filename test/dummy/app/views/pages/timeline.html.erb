            &lt;p class=&quot;text-sm mt-1 text-[var(--surface-muted-content-color)]&quot;&gt;Total: $149.99&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Processing&quot;,
            timestamp: &quot;Feb 20, 2:15 PM&quot;,
            variant: :success
          ) do %&gt;
            &lt;p&gt;Order is being prepared for shipment at our warehouse.&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Shipped&quot;,
            timestamp: &quot;Feb 21, 9:00 AM&quot;,
            variant: :success
          ) do %&gt;
            &lt;p&gt;Package has been handed to carrier for delivery.&lt;/p&gt;
            &lt;p class=&quot;text-sm mt-1 text-[var(--surface-muted-content-color)]&quot;&gt;Tracking: 1Z999AA10123456784&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Out for Delivery&quot;,
            timestamp: &quot;Feb 22, 8:30 AM&quot;,
            variant: :warning
          ) do %&gt;
            &lt;p&gt;Your package is on the delivery vehicle and will arrive today.&lt;/p&gt;
          &lt;% end %&gt;
    
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Expected Delivery&quot;,
            timestamp: &quot;Feb 22, by 5:00 PM&quot;,
            variant: :default,
            last: true
          ) do %&gt;
            &lt;p&gt;Package scheduled to arrive by end of day.&lt;/p&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      &lt;/div&gt;
    CODE
    language: "erb",
    title: "Order Tracking"
  ) %>
</section>

<section class="mb-12">
  <%= render FlatPack::SectionTitle::Component.new(title: "Activity Feed", anchor_link: true) %>
  
  <div class="border border-[var(--surface-border-color)] rounded-lg p-6">
    <%= render FlatPack::Timeline::Component.new do %>
      <%= render FlatPack::Timeline::Item.new(
        title: "Pull Request Opened",
        timestamp: "2 hours ago"
      ) do %>
        <p><strong>John Doe</strong> opened PR #123: "Add user authentication"</p>
        <div class="mt-2 space-x-2">
          <%= render FlatPack::Badge::Component.new(text: "+350", style: :success, size: :sm) %>
          <%= render FlatPack::Badge::Component.new(text: "-120", style: :warning, size: :sm) %>
        </div>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Code Review",
        timestamp: "1 hour ago"
      ) do %>
        <p><strong>Jane Smith</strong> reviewed and requested changes on PR #123</p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Changes Committed",
        timestamp: "30 minutes ago"
      ) do %>
        <p><strong>John Doe</strong> pushed 3 new commits addressing review feedback</p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Approved",
        timestamp: "15 minutes ago",
        variant: :success
      ) do %>
        <p><strong>Jane Smith</strong> approved the changes</p>
      <% end %>

      <%= render FlatPack::Timeline::Item.new(
        title: "Merged",
        timestamp: "5 minutes ago",
        variant: :success,
        last: true
      ) do %>
        <p><strong>John Doe</strong> merged PR #123 into main</p>
        <p class="text-sm mt-1 text-[var(--surface-muted-content-color)]">Automatically deployed to production</p>
      <% end %>
    <% end %>
  </div>

  <%= render FlatPack::CodeBlock::Component.new(
    code: CGI.unescapeHTML(<<~'CODE'),
      &lt;div class=&quot;border border-[var(--surface-border-color)] rounded-lg p-6&quot;&gt;
        &lt;%= render FlatPack::Timeline::Component.new do %&gt;
          &lt;%= render FlatPack::Timeline::Item.new(
            title: &quot;Pull Request Opened&quot;,
