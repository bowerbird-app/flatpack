<div class="container mx-auto max-w-4xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::ImageDeck",
    subtitle: "Overlapping image deck preview for multi-image uploads in chat messages."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_image_deck, anchor: "component-method-variables" %>

  <% incoming_images = [
    {name: "front-wheel-detail.jpg", thumbnail_url: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=640&h=360&fit=crop", href: "#"},
    {name: "handlebar-bag.jpg", thumbnail_url: "https://images.unsplash.com/photo-1518773553398-650c184e0bb3?w=640&h=360&fit=crop", href: "#"},
    {name: "frame-side.jpg", thumbnail_url: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=640&h=360&fit=crop", href: "#"},
    {name: "seat-closeup.jpg", thumbnail_url: "https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=640&h=360&fit=crop", href: "#"},
    {name: "rear-angle.jpg", thumbnail_url: "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?w=640&h=360&fit=crop", href: "#"}
  ] %>

  <% outgoing_images = [
    {name: "hero-v1.png", thumbnail_url: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=640&h=360&fit=crop", href: "#"},
    {name: "hero-v2.png", thumbnail_url: "https://images.unsplash.com/photo-1518773553398-650c184e0bb3?w=640&h=360&fit=crop", href: "#"},
    {name: "hero-v3.png", thumbnail_url: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=640&h=360&fit=crop", href: "#"}
  ] %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(
      title: "Demo",
      anchor_link: true,
      subtitle: "Messenger-style overlapping image cards for multi-image uploads."
    ) %>

    <div class="mb-4 mt-6 space-y-8 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <div class="space-y-2">
        <p class="text-sm font-medium text-(--surface-content-color)">Incoming batch (5 images)</p>
        <%= render FlatPack::Chat::ImageDeck::Component.new(images: incoming_images, direction: :incoming, bordered: false) %>
      </div>

      <div class="space-y-2">
        <p class="text-sm font-medium text-(--surface-content-color) text-right">Outgoing batch (3 images)</p>
        <%= render FlatPack::Chat::ImageDeck::Component.new(images: outgoing_images, direction: :outgoing, bordered: false) %>
      </div>
    </div>
  </section>
</div>
