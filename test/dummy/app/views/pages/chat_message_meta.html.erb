<div class="container mx-auto max-w-4xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::MessageMeta",
    subtitle: "Timestamp, edited marker, and state indicators for messages."
  ) %>

  <div class="mt-6 space-y-4 rounded-lg border border-[var(--surface-border-color)] bg-[var(--surface-background-color)] p-6">
    <div class="flex items-center justify-between">
      <span class="text-sm text-[var(--surface-muted-content-color)]">Sent</span>
      <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "11:02 AM", state: :sent) %>
    </div>
    <div class="flex items-center justify-between">
      <span class="text-sm text-[var(--surface-muted-content-color)]">Sending</span>
      <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "11:03 AM", state: :sending) %>
    </div>
    <div class="flex items-center justify-between">
      <span class="text-sm text-[var(--surface-muted-content-color)]">Failed</span>
      <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "11:04 AM", state: :failed) %>
    </div>
    <div class="flex items-center justify-between">
      <span class="text-sm text-[var(--surface-muted-content-color)]">Read and edited</span>
      <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "11:05 AM", state: :read, edited: true) %>
    </div>
  </div>
</div>