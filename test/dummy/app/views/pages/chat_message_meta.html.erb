<div class="container mx-auto max-w-4xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::MessageMeta",
    subtitle: "Timestamp, edited marker, and state indicators for messages."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_message_meta, anchor: "component-method-variables" %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo", anchor_link: true, subtitle: "Delivery states and edited indicator examples.") %>

    <div class="mb-4 mt-6 space-y-3 rounded-lg border border-(--surface-border-color) bg-(--surface-background-color) p-6">
      <%= render FlatPack::Chat::ReceivedMessage::Component.new do |message| %>
        Here’s the latest handoff checklist.
        <% message.with_meta do %>
          <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "11:02 AM", state: :sent) %>
        <% end %>
      <% end %>

      <%= render FlatPack::Chat::SentMessage::Component.new do |message| %>
        Thanks — uploading release notes now.
        <% message.with_meta do %>
          <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "11:03 AM", state: :sending) %>
        <% end %>
      <% end %>

      <%= render FlatPack::Chat::SentMessage::Component.new do |message| %>
        Retry attempt failed. I’ll resend once I reconnect.
        <% message.with_meta do %>
          <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "11:04 AM", state: :failed) %>
        <% end %>
      <% end %>

      <%= render FlatPack::Chat::SentMessage::Component.new do |message| %>
        Resent successfully with the final attachment.
        <% message.with_meta do %>
          <%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "11:05 AM", state: :read, edited: true) %>
        <% end %>
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::SentMessage::Component.new do |message| %&gt;
          Thanks — uploading release notes now.
          &lt;% message.with_meta do %&gt;
            &lt;%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "11:03 AM", state: :sending) %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;

        &lt;%= render FlatPack::Chat::SentMessage::Component.new do |message| %&gt;
          Resent successfully with the final attachment.
          &lt;% message.with_meta do %&gt;
            &lt;%= render FlatPack::Chat::MessageMeta::Component.new(timestamp: "11:05 AM", state: :read, edited: true) %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>
</div>