<div class="container mx-auto max-w-5xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::Layout",
    subtitle: "Single and split layout patterns for messaging interfaces."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_layout, anchor: "component-method-variables" %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Single", anchor_link: true, subtitle: "Single-column layout using only the panel slot.") %>

    <div class="mb-4 mt-6 h-[360px] overflow-hidden rounded-lg border border-(--surface-border-color) bg-(--surface-background-color)">
      <%= render FlatPack::Chat::Layout::Component.new do |layout| %>
        <% layout.panel do %>
          <%= render FlatPack::Chat::Panel::Component.new do |panel| %>
            <% panel.header do %>
              <div class="p-4 text-sm font-semibold">Product Launch</div>
            <% end %>
            <% panel.messages do %>
              <div class="flex-1 p-4 text-sm text-(--surface-muted-content-color)">Single-column panel content sits here.</div>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::Layout::Component.new do |layout| %&gt;
          &lt;% layout.panel do %&gt;
            &lt;%= render FlatPack::Chat::Panel::Component.new do |panel| %&gt;
              &lt;% panel.header do %&gt;
                &lt;div class="p-4 text-sm font-semibold"&gt;Product Launch&lt;/div&gt;
              &lt;% end %&gt;
              &lt;% panel.messages do %&gt;
                &lt;div class="flex-1 p-4 text-sm text-(--surface-muted-content-color)"&gt;Single-column panel content sits here.&lt;/div&gt;
              &lt;% end %&gt;
            &lt;% end %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Split", anchor_link: true, subtitle: "Split layout with sidebar and panel slots.") %>

    <div class="mb-4 mt-6 h-[560px] overflow-hidden rounded-lg border border-(--surface-border-color) bg-(--surface-background-color)">
      <%= render FlatPack::Chat::Layout::Component.new(variant: :split) do |layout| %>
        <% layout.sidebar do %>
          <div class="p-4">
            <h3 class="mb-3 text-sm font-semibold text-(--surface-content-color)">Conversations</h3>
            <div class="space-y-2">
              <div class="rounded-lg bg-(--surface-muted-background-color) px-3 py-2 text-sm">Product Launch</div>
              <div class="rounded-lg px-3 py-2 text-sm text-(--surface-muted-content-color)">Support Team</div>
              <div class="rounded-lg px-3 py-2 text-sm text-(--surface-muted-content-color)">Marketing</div>
            </div>
          </div>
        <% end %>

        <% layout.panel do %>
          <%= render FlatPack::Chat::Panel::Component.new do |panel| %>
            <% panel.header do %>
              <div class="p-4 text-sm font-semibold">Product Launch</div>
            <% end %>
            <% panel.messages do %>
              <div class="flex-1 p-4 text-sm text-(--surface-muted-content-color)">Panel slot content sits here.</div>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::Layout::Component.new(variant: :split) do |layout| %&gt;
          &lt;% layout.sidebar do %&gt;
            &lt;div class="p-4"&gt;
              &lt;h3 class="mb-3 text-sm font-semibold text-(--surface-content-color)"&gt;Conversations&lt;/h3&gt;
            &lt;/div&gt;
          &lt;% end %&gt;

          &lt;% layout.panel do %&gt;
            &lt;%= render FlatPack::Chat::Panel::Component.new do |panel| %&gt;
              &lt;% panel.header do %&gt;
                &lt;div class="p-4 text-sm font-semibold"&gt;Product Launch&lt;/div&gt;
              &lt;% end %&gt;
              &lt;% panel.messages do %&gt;
                &lt;div class="flex-1 p-4 text-sm text-(--surface-muted-content-color)"&gt;Panel slot content sits here.&lt;/div&gt;
              &lt;% end %&gt;
            &lt;% end %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>
</div>