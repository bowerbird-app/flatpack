<div class="container mx-auto max-w-5xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::Panel",
    subtitle: "Header, messages, and composer sections in one container."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_panel, anchor: "component-method-variables" %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo", anchor_link: true, subtitle: "Panel header, messages, and composer slots.") %>

    <div class="mb-4 mt-6 h-[560px] overflow-hidden rounded-lg border border-(--surface-border-color) bg-(--surface-background-color)">
      <%= render FlatPack::Chat::Panel::Component.new do |panel| %>
        <% panel.with_header do %>
          <div class="p-4">
            <h3 class="font-semibold">Panel Header</h3>
            <p class="text-sm text-(--surface-muted-content-color)">Use this area for participants and context.</p>
          </div>
        <% end %>

        <% panel.with_messages do %>
          <div class="flex-1 space-y-3 overflow-y-auto p-4">
            <%= render FlatPack::Chat::Message::Component.new(direction: :incoming) { "Incoming message in panel body" } %>
            <%= render FlatPack::Chat::Message::Component.new(direction: :outgoing) { "Outgoing message in panel body" } %>
          </div>
        <% end %>

        <% panel.with_composer do %>
          <%= render FlatPack::Chat::Composer::Component.new %>
        <% end %>
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::Panel::Component.new do |panel| %&gt;
          &lt;% panel.with_header do %&gt;
            &lt;div class="p-4"&gt;
              &lt;h3 class="font-semibold"&gt;Panel Header&lt;/h3&gt;
            &lt;/div&gt;
          &lt;% end %&gt;

          &lt;% panel.with_messages do %&gt;
            &lt;div class="flex-1 space-y-3 overflow-y-auto p-4"&gt;
              &lt;%= render FlatPack::Chat::Message::Component.new(direction: :incoming) { "Incoming message in panel body" } %&gt;
            &lt;/div&gt;
          &lt;% end %&gt;

          &lt;% panel.with_composer do %&gt;
            &lt;%= render FlatPack::Chat::Composer::Component.new %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>
</div>