<div class="container mx-auto max-w-5xl p-4">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Chat::Panel",
    subtitle: "Header, messages, and composer sections in one container."
  ) %>

  <%= render "pages/component_method_variables_table", component: :chat_panel, anchor: "component-method-variables" %>

  <section class="mb-12">
    <%= render FlatPack::SectionTitle::Component.new(title: "Demo", anchor_link: true, subtitle: "Panel header, messages, and composer slots.") %>

    <div class="mb-4 mt-6 h-[560px] overflow-hidden rounded-lg border border-(--surface-border-color) bg-(--surface-background-color)">
      <%= render FlatPack::Chat::Panel::Component.new do |panel| %>
        <% panel.header do %>
          <%= render FlatPack::Chat::Header::Component.new(
            title: "Alicia Chen",
            subtitle: "Online",
            back_href: "#chat-groups",
            back_label: nil,
            back_tooltip: "Back to chat groups",
            person_avatar: {name: "Alicia Chen", size: :sm}
          ) do |header| %>
            <% header.right do %>
              <%= render FlatPack::Button::Dropdown::Component.new(
                text: "",
                icon: "dots",
                style: :ghost,
                size: :sm,
                show_chevron: false,
                position: :bottom_right,
                trigger_attributes: {
                  title: "Conversation actions",
                  aria: {label: "Conversation actions"}
                }
              ) do |dropdown| %>
                <% dropdown.menu_item(text: "Search conversation", icon: "search", href: "#chat-search") %>
                <% dropdown.menu_item(text: "View details", icon: "dashboard", href: "#chat-details") %>
                <% dropdown.menu_divider %>
                <% dropdown.menu_item(text: "Notification settings", icon: "settings", href: "#chat-notifications") %>
                <% dropdown.menu_item(text: "Archive", icon: "folder", href: "#chat-archive") %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>

        <% panel.messages do %>
          <div class="flex-1 space-y-3 overflow-y-auto p-4">
            <%= render FlatPack::Chat::ReceivedMessage::Component.new { "Incoming message in panel body" } %>
            <%= render FlatPack::Chat::SentMessage::Component.new { "Outgoing message in panel body" } %>
          </div>
        <% end %>

        <% panel.composer do %>
          <%= render FlatPack::Chat::Composer::Component.new %>
        <% end %>
      <% end %>
    </div>

    <%= render FlatPack::CodeBlock::Component.new(
      title: "ERB",
      language: "erb",
      code: CGI.unescapeHTML(<<~'CODE')
        &lt;%= render FlatPack::Chat::Panel::Component.new do |panel| %&gt;
          &lt;% panel.header do %&gt;
            &lt;%= render FlatPack::Chat::Header::Component.new(
              title: "Alicia Chen",
              subtitle: "Online",
              back_href: "#chat-groups",
              back_label: nil,
              back_tooltip: "Back to chat groups",
              person_avatar: {name: "Alicia Chen", size: :sm}
            ) do |header| %&gt;
              &lt;% header.right do %&gt;
                &lt;%= render FlatPack::Button::Dropdown::Component.new(
                  text: "",
                  icon: "dots",
                  style: :ghost,
                  size: :sm,
                  show_chevron: false,
                  position: :bottom_right,
                  trigger_attributes: {
                    title: "Conversation actions",
                    aria: {label: "Conversation actions"}
                  }
                ) do |dropdown| %&gt;
                  &lt;% dropdown.menu_item(text: "Search conversation", icon: "search", href: "#chat-search") %&gt;
                  &lt;% dropdown.menu_item(text: "View details", icon: "dashboard", href: "#chat-details") %&gt;
                  &lt;% dropdown.menu_divider %&gt;
                  &lt;% dropdown.menu_item(text: "Notification settings", icon: "settings", href: "#chat-notifications") %&gt;
                  &lt;% dropdown.menu_item(text: "Archive", icon: "folder", href: "#chat-archive") %&gt;
                &lt;% end %&gt;
              &lt;% end %&gt;
            &lt;% end %&gt;
          &lt;% end %&gt;

          &lt;% panel.messages do %&gt;
            &lt;div class="flex-1 space-y-3 overflow-y-auto p-4"&gt;
              &lt;%= render FlatPack::Chat::ReceivedMessage::Component.new { "Incoming message in panel body" } %&gt;
            &lt;/div&gt;
          &lt;% end %&gt;

          &lt;% panel.composer do %&gt;
            &lt;%= render FlatPack::Chat::Composer::Component.new %&gt;
          &lt;% end %&gt;
        &lt;% end %&gt;
      CODE
    ) %>
  </section>
</div>