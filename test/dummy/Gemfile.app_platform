# frozen_string_literal: true

source "https://rubygems.org"

# App Platform cannot reliably deploy the dummy app against a mutable path gem.
# Use a git-sourced FlatPack dependency and lock it in Gemfile.app_platform.lock.
gem "flat_pack", git: "https://github.com/bowerbird-app/flatpack.git", branch: "main"

eval_gemfile "Gemfile.common"